<template>
  <view class="test-page">
    <custom-nav-bar
      :title="t('Mobile.Intervention.Test.pageTitle')"
      :show-back="true"
    />

    <view class="test-container">
      <view class="section">
        <text class="section-title">{{
          t("Mobile.Intervention.Test.acpSection")
        }}</text>
        <view class="card-list">
          <acp-permission-card
            v-for="(acp, idx) in acpMocks"
            :key="`acp-${idx}`"
            :interaction="acp"
            @respond="(resp) => onAcpRespond(acp, resp)"
          />
        </view>
      </view>

      <view class="section">
        <text class="section-title">{{
          t("Mobile.Intervention.Test.mcpSection")
        }}</text>
        <view class="card-list">
          <mcp-ask-card
            v-for="(mcp, idx) in mcpMocks"
            :key="`mcp-${idx}`"
            :interaction="mcp"
            @respond="(payload) => onMcpRespond(mcp, payload)"
          />
        </view>
      </view>

      <view class="actions">
        <button class="btn" @tap="resetAll">
          {{ t("Mobile.Intervention.Test.resetAll") }}
        </button>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
  import { ref, onMounted } from "vue";
  import CustomNavBar from "@/components/custom-nav-bar/custom-nav-bar.uvue";
  import AcpPermissionCard from "@/components/acp-permission-card/acp-permission-card.uvue";
  import McpAskCard from "@/components/mcp-ask-card/mcp-ask-card.uvue";
  import { t } from "@/utils/i18n.uts";
  import {
    mockAcpPermissionSimple,
    mockAcpPermissionMultiOption,
    mockAcpPermissionNetwork,
    mockMcpAskSurvey,
    mockMcpAskSelectForm,
    mockMcpAskSimple,
    mockMcpAskWithFile,
    mockMcpAskWithList,
    mockMcpAskWizard,
  } from "@/utils/mockInterventionData";
  import type {
    AcpPermissionInteraction,
    AcpPermissionResponse,
    McpAskInteraction,
    McpAskRespondPayload,
  } from "@/types/intervention";

  const acpMocks = ref<AcpPermissionInteraction[]>([]);
  const mcpMocks = ref<McpAskInteraction[]>([]);

  const initMocks = () => {
    acpMocks.value = [
      mockAcpPermissionSimple(),
      mockAcpPermissionMultiOption(),
      mockAcpPermissionNetwork(),
    ];
    mcpMocks.value = [
      mockMcpAskSurvey(),
      mockMcpAskSelectForm(),
      mockMcpAskSimple(),
      mockMcpAskWithFile(),
      mockMcpAskWithList(),
      mockMcpAskWizard(),
    ];
  };

  const resetAll = () => {
    initMocks();
    uni.showToast({
      title: t("Mobile.Intervention.Test.resetDone"),
      icon: "none",
    });
  };

  const onAcpRespond = (
    interaction: AcpPermissionInteraction,
    response: AcpPermissionResponse,
  ) => {
    console.log("[ACP Respond]", interaction.id, response);
    // 更新状态为 submitting
    const idx = acpMocks.value.findIndex((i) => i.id === interaction.id);
    if (idx >= 0) {
      acpMocks.value[idx] = {
        ...acpMocks.value[idx],
        responseStatus: "submitting",
        selectedOptionId:
          response.outcome.outcome === "selected"
            ? response.outcome.optionId
            : undefined,
      };
    }

    // 模拟 API 延迟
    setTimeout(() => {
      const idx2 = acpMocks.value.findIndex((i) => i.id === interaction.id);
      if (idx2 >= 0) {
        acpMocks.value[idx2] = {
          ...acpMocks.value[idx2],
          responseStatus: "submitted",
        };
      }
      uni.showToast({
        title: `已${response.outcome.outcome === "selected" ? "批准" : "拒绝"}: ${interaction.request.toolCall.title}`,
        icon: "none",
        duration: 2000,
      });
    }, 1000);
  };

  const onMcpRespond = (
    interaction: McpAskInteraction,
    payload: McpAskRespondPayload,
  ) => {
    console.log("[MCP Respond]", interaction.requestId, payload);
    const idx = mcpMocks.value.findIndex(
      (i) => i.requestId === interaction.requestId,
    );
    if (idx >= 0) {
      const resolveStatus = () => {
        if (payload.action === "cancel") return "cancelled";
        if (payload.action === "skip") return "skipped";
        return "submitted";
      };
      mcpMocks.value[idx] = {
        ...mcpMocks.value[idx],
        responseStatus: resolveStatus() as any,
        formData: payload.formData,
      };
    }
    uni.showToast({
      title: `${interaction.title}: ${payload.action}`,
      icon: "none",
      duration: 2000,
    });
  };

  onMounted(() => {
    initMocks();
  });
</script>

<style lang="scss" scoped>
  .test-page {
    min-height: 100vh;
    background-color: #f5f5f5;
  }

  .test-container {
    padding: 24rpx;
  }

  .section {
    margin-bottom: 40rpx;
  }

  .section-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 20rpx;
    display: block;
  }

  .card-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }

  .actions {
    margin-top: 40rpx;
    padding: 20rpx 0;
  }

  .btn {
    background-color: #1677ff;
    color: #fff;
    border: none;
    border-radius: 12rpx;
    padding: 24rpx 40rpx;
    font-size: 30rpx;
    font-weight: 500;
  }

  .btn:active {
    opacity: 0.8;
  }
</style>

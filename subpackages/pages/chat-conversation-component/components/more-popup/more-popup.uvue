<template>
  <drawer-popup
    ref="popup"
    :title="t('Mobile.Conversation.more')"
    direction="bottom"
    :auto-height="true"
    default-height="15%"
    max-height="40%"
  >
    <view class="menu-list">
      <view class="menu-item" @click="handleCollect">
        <text class="iconfont icon-Star" v-if="!agentCollect" />
        <text class="iconfont icon-Star-fill" v-else />
        <text class="menu-text text-ellipsis">{{
          t("Mobile.Conversation.favorite")
        }}</text>
      </view>
      <view class="menu-item" @click="handleShare">
        <text class="iconfont icon-Share" />
        <text class="menu-text text-ellipsis">{{
          t("Mobile.Conversation.share")
        }}</text>
      </view>
      <view
        class="menu-item"
        v-if="agentPaymentRequired && isSubscriptionEnabled"
        @click="handleMySubscription"
      >
        <text class="iconfont icon-member" />
        <text class="menu-text text-ellipsis">{{
          t("Mobile.Conversation.mySubscription")
        }}</text>
      </view>
      <view class="menu-item" @click="handleMoreInfo">
        <text class="iconfont icon-Info" />
        <text class="menu-text text-ellipsis">{{
          t("Mobile.Conversation.moreInfo")
        }}</text>
      </view>
      <template v-if="isTaskAgentVal && hasHistoryVal">
        <view class="menu-item" @click="handleRestartAgent">
          <text class="iconfont icon-restart" />
          <text class="menu-text text-ellipsis">{{
            t("Mobile.Sandbox.restartAgent")
          }}</text>
        </view>
        <view class="menu-item" @click="handleRestartSandbox">
          <text class="iconfont icon-restart_agent" />
          <text class="menu-text text-ellipsis">{{
            currentSandboxIdVal == "-1"
              ? t("Mobile.Sandbox.restartCloudComp")
              : t("Mobile.Sandbox.restartClient")
          }}</text>
        </view>
      </template>
    </view>
  </drawer-popup>

  <drawer-popup
    ref="popupMore"
    direction="bottom"
    height="85%"
    :show-header="true"
  >
    <more-info v-if="agentInfo" :agent-info="agentInfoNonNull" />
    <related-conversation
      v-if="agentInfo"
      :agent-info="agentInfoNonNull"
      @view-all="handleViewAll"
    />
  </drawer-popup>
  <drawer-popup
    ref="popupViewAll"
    :title="t('Mobile.Conversation.allConversations')"
    direction="bottom"
    height="85%"
  >
    <!-- 根据智能体id动态获取历史记录 -->
    <agent-conversation-history
      v-if="agentInfo"
      :agent-id="agentIdNum"
    />
  </drawer-popup>
</template>

<script setup lang="uts">
  import { ref, computed } from "vue";
  import MoreInfo from "../more-info/more-info.uvue";
  import RelatedConversation from "../related-conversation/related-conversation.uvue";
  import type { ConversationInfo } from "@/types/interfaces/conversationInfo";
  import AgentConversationHistory from "../agent-conversation-history/agent-conversation-history.uvue";
  import { useI18n } from "@/utils/i18n";
  import { TENANT_CONFIG_INFO } from "@/constants/home.constants";
  import type { TenantConfigInfo } from "@/types/interfaces/login";
  import { SUCCESS_CODE } from "@/constants/codes.constants.uts";
  import { apiTenantConfig } from "@/servers/account";

  const { t: tRaw } = useI18n();
  const t = (key: string): string => tRaw(key, new Map<string, any>(), "");

  // uvue 对复杂对象 prop（AgentDetailDto）会生成与 Props 接口类型不匹配的 override；
  // 可选 prop（?）配合 withDefaults 也会因 nullable 与非空不一致报 override 错误。
  // 因此 agentInfo 用 UTSJSONObject 接收，全部 prop 不使用 withDefaults，默认值经 computed 兜底。
  interface MorePopupProps {
    agentInfo?: UTSJSONObject;
    isTaskAgent?: boolean;
    hasHistory?: boolean;
    currentSandboxId?: string;
  }

  const props = defineProps<MorePopupProps>();

  // 是否开启订阅
  const isSubscriptionEnabled = ref<boolean>(false);
  const chatList = ref<ConversationInfo[]>([]);

  // ===== prop 读取（含默认值 / null 安全） =====
  const isTaskAgentVal = computed((): boolean => props.isTaskAgent == true);
  const hasHistoryVal = computed((): boolean => props.hasHistory == true);
  const currentSandboxIdVal = computed((): string =>
    props.currentSandboxId != null ? props.currentSandboxId : "",
  );

  const agentCollect = computed((): boolean => {
    const a = props.agentInfo;
    return a != null && a["collect"] == true;
  });
  const agentPaymentRequired = computed((): boolean => {
    const a = props.agentInfo;
    return a != null && a["paymentRequired"] == true;
  });
  const agentInfoNonNull = computed((): UTSJSONObject => {
    const a = props.agentInfo;
    return a != null ? a : ({} as UTSJSONObject);
  });
  const agentIdNum = computed((): number => {
    const a = props.agentInfo;
    if (a == null) {
      return 0;
    }
    const v = a["agentId"];
    return v != null ? (v as number) : 0;
  });

  const checkSubscriptionEnable = async () => {
    const storedVal = uni.getStorageSync(TENANT_CONFIG_INFO);
    const cfgStr = storedVal != null ? (storedVal as string) : "";
    if (cfgStr.length > 0) {
      try {
        const tenantConfig = JSON.parse(cfgStr) as UTSJSONObject;
        const enableVal = tenantConfig["enableSubscription"];
        isSubscriptionEnabled.value =
          enableVal != null && (enableVal as number) == 1;
      } catch (error) {
        console.error("解析租户配置失败:", error);
      }
    }

    try {
      const res = await apiTenantConfig();
      const d = res.data;
      if (res.code == SUCCESS_CODE && d != null) {
        isSubscriptionEnabled.value = d.enableSubscription == 1;
        uni.setStorageSync(TENANT_CONFIG_INFO, JSON.stringify(d));
      }
    } catch (e) {
      console.error("同步最新租户配置失败:", e);
    }
  };

  checkSubscriptionEnable();

  // 定义事件
  const emit = defineEmits([
    "collect",
    "restartAgent",
    "restartSandbox",
    "mySubscription",
  ]);

  const popup = ref<any | null>(null);
  const popupMore = ref<any | null>(null);
  const popupViewAll = ref<any | null>(null);

  // null 安全地调用 ref 上的方法
  const callRefMethod = (refVal: any | null, methodName: string) => {
    if (refVal == null) {
      return;
    }
    const obj = refVal as UTSJSONObject;
    const fn = obj[methodName];
    if (fn != null) {
      (fn as () => void)();
    }
  };

  // 打开抽屉
  const open = () => {
    checkSubscriptionEnable();
    callRefMethod(popup.value, "open");
  };

  // 关闭抽屉
  const close = () => {
    callRefMethod(popup.value, "close");
  };

  // 收藏功能
  const handleCollect = () => {
    close();
    emit("collect");
  };

  // 订阅功能
  const handleMySubscription = () => {
    close();
    emit("mySubscription");
  };

  // 分享功能
  const handleShare = () => {
    let currentUrl = "";

    // #ifdef H5
    currentUrl = window.location.href;
    // #endif

    // 复制到剪贴板
    uni.setClipboardData({
      data: currentUrl,
      success: () => {
        uni.showToast({
          title: t("Mobile.Link.copyAndOpen"),
          icon: "success",
          duration: 2000,
        });
      },
      fail: (err) => {
        console.error("复制失败:", err);
        uni.showToast({
          title: t("Mobile.Common.copyFailed"),
          icon: "error",
          duration: 2000,
        });
      },
    });

    close();
  };

  // 更多信息功能
  const handleMoreInfo = () => {
    close();
    callRefMethod(popupMore.value, "open");
  };

  // 重启智能体
  const handleRestartAgent = () => {
    close();
    emit("restartAgent");
  };

  // 重启容器环境
  const handleRestartSandbox = () => {
    close();
    emit("restartSandbox");
  };

  const handleViewAll = (data: ConversationInfo[]) => {
    chatList.value = data;
    callRefMethod(popupViewAll.value, "open");
  };

  defineExpose({
    open: open as any,
    close: close as any,
    popupMore,
  });
</script>

<style lang="scss" scoped>
  .menu-list {
    .menu-item {
      display: flex;
      flex-direction: row;
      align-items: center;
      padding: 20rpx 30rpx;
      transition: background-color 0.2s;
      border-radius: 8rpx;

      &:active {
        background-color: rgba(12, 20, 102, 0.04);
      }

      .iconfont {
        font-size: 40rpx;
        color: #333;
      }

      .icon-Star-fill {
        color: #faad14;
      }

      .menu-text {
        margin-left: 24rpx;
        font-size: 32rpx;
        line-height: 48rpx;
        color: rgba(21, 23, 31, 0.7);
        flex: 1;
      }
    }
  }
</style>

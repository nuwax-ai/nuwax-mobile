export interface I18nLangDto {
  id: number;
  name: string;
  lang: string;
  status: number;
  isDefault: number;
  sort: number;
  modified: string;
  created: string;
}

export type I18nState = {
  currentLang: string;
  langMap: UTSJSONObject;
  langList: I18nLangDto[];
  loaded: boolean;
  loading: boolean;
}


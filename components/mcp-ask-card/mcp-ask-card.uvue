<template>
  <view class="mcp-ask-card" v-if="interaction">
    <!-- 标题区 -->
    <view class="card-header">
      <text class="card-title">{{ interaction.title }}</text>
      <text v-if="interaction.description" class="card-desc">{{ interaction.description }}</text>
    </view>

    <!-- 状态标签 -->
    <view v-if="interaction.responseStatus !== 'pending'" class="status-tag">
      <text v-if="interaction.responseStatus === 'submitted'" class="iconfont icon-a-Checkcircle status-icon status-icon-success" />
      <text v-else-if="interaction.responseStatus === 'cancelled'" class="iconfont icon-a-Xcircle status-icon status-icon-cancelled" />
      <text v-else-if="interaction.responseStatus === 'skipped'" class="iconfont icon-attention status-icon status-icon-skipped" />
      <text class="status-tag-text">{{ statusLabel }}</text>
    </view>

    <!-- 表单区 -->
    <view v-if="interaction.responseStatus === 'pending'" class="card-form">
      <view v-for="field in parsedFields" :key="field.name" class="form-field">
        <text class="field-label">{{ field.label }}<text v-if="field.required" class="field-required">*</text></text>

        <!-- text 输入 -->
        <input
          v-if="field.widget === 'text'"
          class="field-input"
          :value="(formData[field.name] as string) || ''"
          @input="onTextInput(field.name, $event)"
          :placeholder="field.label"
        />

        <!-- textarea 输入 -->
        <textarea
          v-else-if="field.widget === 'textarea'"
          class="field-textarea"
          :value="(formData[field.name] as string) || ''"
          @input="onTextInput(field.name, $event)"
          :placeholder="field.label"
        />

        <!-- radio / select / list — 单选列表（垂直排列，样式类似 checkboxes） -->
        <view v-else-if="field.widget === 'radio' || field.widget === 'select' || field.widget === 'list'" class="field-list-group">
          <view
            v-for="opt in field.options"
            :key="opt.value"
            class="list-option"
            :class="{ 'list-selected': formData[field.name] === opt.value }"
            @tap="onRadioSelect(field.name, opt.value)"
          >
            <view class="list-radio-dot" :class="{ 'dot-selected': formData[field.name] === opt.value }">
              <text v-if="formData[field.name] === opt.value" class="iconfont icon-Check dot-check-icon" />
            </view>
            <text class="list-label">{{ opt.label }}</text>
          </view>
        </view>

        <!-- checkboxes 多选 -->
        <l-checkbox-group
          v-else-if="field.widget === 'checkboxes'"
          :modelValue="(formData[field.name] as string[]) || []"
          @update:modelValue="(val: string[]) => formData[field.name] = val"
          direction="vertical"
          icon="rectangle"
          checkedColor="#1677ff"
          gap="12rpx"
        >
          <l-checkbox
            v-for="opt in field.options"
            :key="opt.value"
            :value="opt.value"
            :label="opt.label"
          />
        </l-checkbox-group>

        <!-- file 文件上传 -->
        <view v-else-if="field.widget === 'file'" class="field-file-area">
          <!-- 已上传文件列表 -->
          <view v-if="getFileList(field.name).length" class="file-list">
            <view v-for="file in getFileList(field.name)" :key="file.uid" class="file-item">
              <image v-if="file.type?.includes('image/')" :src="file.url" class="file-thumb" mode="aspectFill" />
              <view v-else class="file-doc">
                <text class="iconfont icon-a-Filetext file-doc-icon" />
                <text class="file-doc-name">{{ file.name }}</text>
              </view>
              <view class="file-remove" @tap="removeFile(field.name, file.uid!)">
                <text class="iconfont icon-closeempty" />
              </view>
              <!-- 上传中遮罩 -->
              <view v-if="file.status === 'uploading'" class="file-uploading-mask">
                <text class="file-uploading-text">{{ file.percent || 0 }}%</text>
              </view>
            </view>
          </view>
          <!-- 上传按钮 -->
          <view class="file-upload-actions">
            <view class="file-upload-btn" @tap="chooseAndUpload(field.name, 'image')">
              <text class="iconfont icon-tupian" />
              <text class="file-upload-btn-text">图片</text>
            </view>
            <view class="file-upload-btn" @tap="chooseAndUpload(field.name, 'file')">
              <text class="iconfont icon-a-Filetext" />
              <text class="file-upload-btn-text">文件</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="form-actions">
        <l-button type="default" variant="light" block @click="handleCancel">
          {{ interaction.ui?.cancelLabel || t('Mobile.Intervention.McpAsk.cancel') }}
        </l-button>
        <l-button type="primary" block @click="handleSubmit">
          {{ interaction.ui?.submitLabel || t('Mobile.Intervention.McpAsk.submit') }}
        </l-button>
      </view>
    </view>
  </view>
</template>

<script lang="uts">
import { t } from '@/utils/i18n.uts'
import type { McpAskInteraction, McpAskRespondPayload } from '@/types/intervention'
import { uploadSingleFile, generateFileUid } from '@/utils/fileUploader'
import { UploadFileInfo } from '@/types/interfaces/common.uts'
import { UploadFileStatus } from '@/types/enums/common.uts'
import type { AttachmentFile } from '@/types/interfaces/conversationInfo.uts'

interface ParsedField {
  name: string
  label: string
  widget: string
  options: { label: string; value: string }[]
  required: boolean
}

export default {
  name: 'McpAskCard',
  props: {
    interaction: {
      type: Object as () => McpAskInteraction,
      required: true,
    },
  },
  emits: ['respond'],
  data() {
    return {
      formData: {} as Record<string, unknown>,
      fileData: {} as Record<string, UploadFileInfo[]>,
    }
  },
  computed: {
    parsedFields(): ParsedField[] {
      const ui = this.interaction?.ui
      if (!ui) return []

      const schema = (ui.schema as any) || {}
      const properties = schema.properties || {}
      const requiredFields = new Set(schema.required || [])
      const uiSchema = (ui.uiSchema as any) || {}

      const fields: ParsedField[] = []
      for (const key of Object.keys(properties)) {
        const prop = properties[key]
        const widget = this.resolveWidget(key, prop, uiSchema)
        const options = this.resolveOptions(prop)

        fields.push({
          name: key,
          label: prop.title || key,
          widget: widget,
          options: options,
          required: requiredFields.has(key),
        })
      }
      return fields
    },
    statusLabel(): string {
      const status = this.interaction?.responseStatus
      if (status === 'submitted') return t('Mobile.Intervention.McpAsk.submitted')
      if (status === 'cancelled') return t('Mobile.Intervention.McpAsk.cancelled')
      if (status === 'skipped') return t('Mobile.Intervention.McpAsk.skipped')
      return ''
    },
  },
  methods: {
    t,
    resolveWidget(name: string, prop: any, uiSchema: any): string {
      // file widget 检测
      if (prop.format === 'data-url' || uiSchema[name]?.['ui:widget'] === 'file') {
        return 'file'
      }
      // ui:widget 显式指定
      const uiWidget = uiSchema[name]?.['ui:widget']
      if (uiWidget) {
        if (uiWidget === 'radio') return 'radio'
        if (uiWidget === 'select') return 'select'
        if (uiWidget === 'list') return 'list'
        if (uiWidget === 'textarea') return 'textarea'
        if (uiWidget === 'checkboxes') return 'checkboxes'
      }
      // 根据 schema 推断
      if (prop.enum) {
        return prop.type === 'array' ? 'checkboxes' : 'radio'
      }
      if (prop.type === 'string') {
        return (prop.maxLength && prop.maxLength > 200) ? 'textarea' : 'text'
      }
      return 'text'
    },
    resolveOptions(prop: any): { label: string; value: string }[] {
      if (!prop.enum) return []
      const enumNames = prop.enumNames || prop['x-enumNames'] || []
      return prop.enum.map((val: string, idx: number) => ({
        label: enumNames[idx] || val,
        value: val,
      }))
    },
    onTextInput(name: string, event: any) {
      this.formData[name] = event.detail?.value || event.target?.value || ''
    },
    onRadioSelect(name: string, value: string) {
      this.formData[name] = value
    },

    // ==================== 文件上传 ====================

    getFileList(fieldName: string): UploadFileInfo[] {
      return this.fileData[fieldName] || []
    },

    chooseAndUpload(fieldName: string, type: 'image' | 'file') {
      if (type === 'image') {
        uni.chooseImage({
          count: 9 - this.getFileList(fieldName).length,
          sizeType: ['original', 'compressed'],
          sourceType: ['album', 'camera'],
          success: (res) => {
            this.uploadFiles(fieldName, res.tempFilePaths)
          },
        })
      } else {
        uni.chooseFile({
          count: 9 - this.getFileList(fieldName).length,
          success: (res) => {
            this.uploadFiles(fieldName, res.tempFilePaths)
          },
        })
      }
    },

    async uploadFiles(fieldName: string, filePaths: string[]) {
      // 初始化字段文件列表
      if (!this.fileData[fieldName]) {
        this.fileData[fieldName] = []
      }

      for (const filePath of filePaths) {
        const uid = generateFileUid()
        const fileName = filePath.split('/').pop() || 'file'

        // 添加上传中的占位条目
        const placeholder: UploadFileInfo = {
          key: '',
          name: fileName,
          type: filePath.includes('.png') || filePath.includes('.jpg') || filePath.includes('.jpeg') || filePath.includes('.gif')
            ? 'image/jpeg'
            : 'application/octet-stream',
          size: 0,
          url: filePath,
          uid: uid,
          status: UploadFileStatus.uploading,
          percent: 0,
        }
        this.fileData[fieldName] = [...this.fileData[fieldName], placeholder]

        // 执行上传
        const result = await uploadSingleFile(filePath, uid, (percent) => {
          const list = this.fileData[fieldName]
          const idx = list.findIndex((f) => f.uid === uid)
          if (idx >= 0) {
            list[idx] = { ...list[idx], percent: percent }
            this.fileData[fieldName] = [...list]
          }
        })

        // 更新条目状态
        const list = this.fileData[fieldName]
        const idx = list.findIndex((f) => f.uid === uid)
        if (idx >= 0) {
          if (result.success && result.file) {
            list[idx] = result.file
          } else {
            list[idx] = { ...list[idx], status: UploadFileStatus.error }
          }
          this.fileData[fieldName] = [...list]
        }
      }
    },

    removeFile(fieldName: string, uid: string) {
      const list = this.fileData[fieldName] || []
      this.fileData[fieldName] = list.filter((f) => f.uid !== uid)
    },

    /**
     * 将文件数据转换为 AttachmentFile 格式存入 formData
     */
    syncFileDataToForm() {
      for (const fieldName of Object.keys(this.fileData)) {
        const files = this.fileData[fieldName] || []
        const doneFiles = files.filter((f) => f.status === UploadFileStatus.done)
        if (doneFiles.length > 0) {
          const attachments: AttachmentFile[] = doneFiles.map((f) => ({
            fileKey: f.key || '',
            fileUrl: f.url || '',
            fileName: f.name || '',
            mimeType: f.type || '',
            fileSize: f.size || 0,
          }))
          this.formData[fieldName] = attachments
        }
      }
    },

    handleSubmit() {
      // 同步文件数据到表单
      this.syncFileDataToForm()

      const payload: McpAskRespondPayload = {
        action: 'submit',
        formData: { ...this.formData },
      }
      this.$emit('respond', payload)
    },
    handleCancel() {
      const payload: McpAskRespondPayload = {
        action: 'cancel',
      }
      this.$emit('respond', payload)
    },
  },
}
</script>

<style lang="scss" scoped>
.mcp-ask-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.status-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  margin-bottom: 16rpx;
}

.status-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.status-icon-success {
  color: #52c41a;
}

.status-icon-cancelled {
  color: #999;
}

.status-icon-skipped {
  color: #faad14;
}

.status-tag-text {
  font-size: 24rpx;
  color: #666;
}

.card-form {
  display: flex;
  flex-direction: column;
}

.form-field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.field-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.field-textarea {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  min-height: 160rpx;
}

/* 单选列表（样式类似 checkboxes） */
.field-list-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.list-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
}

.list-selected {
  /* 选中状态无额外样式 */
}

.list-radio-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d0d0;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot-selected {
  border-color: #1677ff;
  background-color: #1677ff;
}

.dot-check-icon {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
  padding: 0;
  margin: 0;
}

.list-label {
  font-size: 28rpx;
  color: #333;
}

/* 文件上传 */
.field-file-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.file-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.file-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
}

.file-thumb {
  width: 100%;
  height: 100%;
}

.file-doc {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
  padding: 12rpx;
}

.file-doc-icon {
  font-size: 48rpx;
  color: #1677ff;
  margin-bottom: 8rpx;
}

.file-doc-name {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.file-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.file-uploading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.file-uploading-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.file-upload-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.file-upload-btn {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border: 2rpx dashed #d0d0d0;
  border-radius: 12rpx;
  color: #666;
  font-size: 28rpx;
}

.file-upload-btn-text {
  font-size: 28rpx;
  color: #666;
}

.form-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 24rpx;
}
</style>

export type DiffInputFileItem = {
  filePath: string;
  oldText: string;
  newText: string;
}

export interface DiffLineItem {
  type: string;
  content: string;
  oldLineNum: string;
  newLineNum: string;
}

export interface DiffFileItem {
  filePath: string;
  addedCount: number;
  removedCount: number;
  diffLinesList: DiffLineItem[];
  isExpanded: boolean;
}

<template>
  <view class="acp-permission-card" v-if="interaction">
    <!-- 标题区 -->
    <view class="card-header">
      <!-- <text class="iconfont icon-seal card-icon" /> -->
      <view class="card-title-wrap">
        <text class="card-title">{{ title }}</text>
      </view>
      <text v-if="interaction.request.toolCall?.kind" class="card-kind-tag">
        {{ interaction.request.toolCall.kind }}
      </text>
    </view>

    <!-- 状态标签 -->
    <view v-if="interaction.responseStatus === 'submitted'" class="status-tag status-submitted">
      <text class="iconfont icon-a-Checkcircle status-icon status-icon-success" />
      <text class="status-tag-text">{{ t('Mobile.Intervention.AcpPermission.submitted') }}</text>
    </view>
    <view v-if="interaction.responseStatus === 'failed'" class="status-tag status-failed">
      <text class="iconfont icon-waring status-icon status-icon-failed" />
      <text class="status-tag-text">{{ interaction.errorMessage || t('Mobile.Intervention.AcpPermission.failed') }}</text>
    </view>

    <!-- 按钮区 -->
    <view class="card-actions" v-if="interaction.responseStatus === 'pending' || interaction.responseStatus === 'submitting'">
      <l-button
        v-for="option in visibleOptions"
        :key="option.optionId"
        class="card-action-btn"
        :type="option.kind.startsWith('allow') ? 'primary' : 'danger'"
        :variant="option.kind.startsWith('allow') ? 'solid' : 'outline'"
        size="small"
        radius="16rpx"
        :loading="interaction.responseStatus === 'submitting' && interaction.selectedOptionId === option.optionId"
        :disabled="interaction.responseStatus !== 'pending'"
        @click="handleSelect(option.optionId)"
      >{{ option.name || option.optionId }}</l-button>
    </view>
  </view>
</template>

<script lang="uts">
/**
 * ACP 权限审批卡片
 *
 * 示例页面：
 *   路由  /pages/test-intervention/test-intervention
 *   H5    {域名}/m/#/pages/test-intervention/test-intervention
 * 详见 components/agent-intervention/README.md
 */
import { t } from '@/utils/i18n.uts'
import type { AcpPermissionInteraction, AcpPermissionResponse, AcpPermissionOption } from '@/types/intervention'

const HIDDEN_OPTION_KINDS = new Set(['reject_always'])

export default {
  name: 'AcpPermissionCard',
  props: {
    interaction: {
      type: Object as () => AcpPermissionInteraction,
      required: true,
    },
  },
  emits: ['respond'],
  computed: {
    title(): string {
      return this.interaction?.request?.toolCall?.title || t('Mobile.Intervention.AcpPermission.defaultTitle')
    },
    visibleOptions(): AcpPermissionOption[] {
      if (!this.interaction?.request?.options) return []
      return this.interaction.request.options.filter(
        (opt: AcpPermissionOption) => !HIDDEN_OPTION_KINDS.has(opt.kind)
      )
    },
  },
  methods: {
    t,
    handleSelect(optionId: string) {
      if (this.interaction?.responseStatus !== 'pending') return
      const response: AcpPermissionResponse = {
        outcome: {
          outcome: 'selected',
          optionId: optionId,
        },
      }
      this.$emit('respond', response)
    },
  },
}
</script>

<style lang="scss" scoped>
  // 卡片容器及公共样式
  $card-bg-color: #fff;
  $card-border-radius: 16rpx;
  $card-padding: 24rpx;
  $card-margin: 8rpx;
  $card-box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  // 基础颜色
  $primary-color: #1677ff;
  $success-color: #52c41a;
  $danger-color: #ff4d4f;

  // 字体颜色及字号
  $text-color-primary: #1a1a1a;
  $text-color-secondary: #666;
  $font-size-title: 30rpx;
  $font-size-tag: 22rpx;
  $font-size-status: 24rpx;

  // 按钮样式
  $button-border-radius: 16rpx;
  $button-border-radius-double: 32rpx;

.acp-permission-card {
  background-color: $card-bg-color;
  border-radius: $card-border-radius;
  padding: $card-padding;
  margin: $card-margin;
  box-shadow: $card-box-shadow;

  .card-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    margin-bottom: 20rpx;

    .card-icon {
      font-size: 36rpx;
      color: $primary-color;
      margin-right: 12rpx;
    }

    .card-title-wrap {
      flex: 1;

      .card-title {
        font-size: $font-size-title;
        font-weight: 600;
        color: $text-color-primary;
      }
    }

    .card-kind-tag {
      font-size: $font-size-tag;
      color: $primary-color;
      background-color: #e6f4ff;
      padding: 4rpx 12rpx;
      border-radius: 8rpx;
      margin-left: 12rpx;
    }
  }

  .status-tag {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 8rpx 16rpx;
    border-radius: 8rpx;
    margin-bottom: 16rpx;

    &.status-submitted {
      background-color: #f6ffed;
    }

    &.status-failed {
      background-color: #fff2f0;
    }

    .status-icon {
      font-size: 28rpx;
      margin-right: 8rpx;

      &.status-icon-success {
        color: $success-color;
      }

      &.status-icon-failed {
        color: $danger-color;
      }
    }

    .status-tag-text {
      font-size: $font-size-status;
    }
  }

  .card-actions {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 16rpx;
    margin-top: 20rpx;

    .card-action-btn {
      flex-shrink: 0;
    }
  }

  /* #ifndef APP-ANDROID || APP-IOS || APP-HARMONY */
  ::v-deep .l-button {
    border: 0 !important;
    border-radius: $button-border-radius !important;
    overflow: visible !important;
  }
  ::v-deep .l-button::after {
    border-radius: $button-border-radius-double !important;
  }
  /* #endif */
}
</style>

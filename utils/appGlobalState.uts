import { CategoryItemInfo } from "@/types/interfaces/agentConfig";

/**
 * 跨页面临时数据传递的共享状态（单例）
 * 替代 getApp().globalData（UTS 端 getApp() 返回类型不含 globalData 字段）
 *
 * 注意：仅用于页面加载时一次性读取，不依赖响应式。
 */
export class AppGlobalState {
  localAgentList: CategoryItemInfo[] = [] as CategoryItemInfo[];
  searchPlaceholder: string = "";
}

export const appGlobalState: AppGlobalState = new AppGlobalState();

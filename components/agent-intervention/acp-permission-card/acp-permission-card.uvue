<template>
  <view class="acp-permission-card" v-if="interaction">
    <!-- 标题区 -->
    <view class="card-header">
      <view class="card-title-wrap">
        <text class="card-eyebrow">{{
          t("Mobile.Intervention.AcpPermission.eyebrow")
        }}</text>
        <text class="card-title">{{ title }}</text>
      </view>
    </view>

    <!-- 状态标签 -->
    <view
      v-if="interaction.responseStatus === 'submitted'"
      class="status-tag status-submitted"
    >
      <text
        class="iconfont icon-a-Checkcircle status-icon status-icon-success"
      />
      <text class="status-tag-text">{{
        t("Mobile.Intervention.AcpPermission.submitted")
      }}</text>
    </view>
    <view
      v-if="interaction.responseStatus === 'failed'"
      class="status-tag status-failed"
    >
      <text class="iconfont icon-waring status-icon status-icon-failed" />
      <text class="status-tag-text">{{
        interaction.errorMessage ||
        t("Mobile.Intervention.AcpPermission.failed")
      }}</text>
    </view>

    <!-- 文件写入/编辑预览：对齐 PC 端，审批前展示路径与代码差异 -->
    <view v-if="permissionDiffItems.length > 0" class="permission-diff-block">
      <view class="permission-diff-summary">
        <text class="permission-diff-path">{{
          primaryPermissionDiff?.path || ""
        }}</text>
        <view class="permission-diff-stats">
          <text class="permission-diff-added"
            >+{{ permissionDiffStats.added }}</text
          >
          <text class="permission-diff-removed"
            >-{{ permissionDiffStats.removed }}</text
          >
        </view>
      </view>
      <scroll-view
        class="permission-diff-preview"
        direction="vertical"
        :show-scrollbar="false"
      >
        <diff-content-view :diffLinesList="primaryPermissionDiffLines" />
      </scroll-view>
    </view>

    <!-- 选项区（单击选中，不直接提交）-->
    <view
      class="card-actions"
      v-if="
        interaction.responseStatus === 'pending' ||
        interaction.responseStatus === 'submitting'
      "
    >
      <view
        v-for="(option, index) in visibleOptions"
        :key="option.optionId"
        class="card-action-item"
        :class="{ 'item-active': activeIndex === index }"
        @tap="setActiveIndex(index)"
      >
        <view class="option-index">
          <text class="option-index-text">{{ index + 1 }}</text>
        </view>
        <text class="option-label">{{ getOptionLabel(option) }}</text>
      </view>
    </view>

    <!-- Footer：取消 + 确认（对齐 PC 端两步流程）-->
    <view
      class="card-footer"
      v-if="
        interaction.responseStatus === 'pending' ||
        interaction.responseStatus === 'submitting'
      "
    >
      <l-button
        class="footer-cancel-btn"
        type="default"
        variant="light"
        size="small"
        radius="16rpx"
        :disabled="interaction.responseStatus !== 'pending' || !rejectOption"
        :loading="
          interaction.responseStatus === 'submitting' &&
          interaction.selectedOptionId === rejectOption?.optionId
        "
        @click="handleCancel"
      >
        {{ t("Mobile.Intervention.AcpPermission.rejectOnce") }}
      </l-button>
      <l-button
        class="footer-confirm-btn"
        type="primary"
        size="small"
        radius="16rpx"
        :disabled="interaction.responseStatus !== 'pending'"
        :loading="
          interaction.responseStatus === 'submitting' &&
          interaction.selectedOptionId !== rejectOption?.optionId
        "
        @click="handleConfirm"
      >
        {{ t("Mobile.Intervention.AcpPermission.confirm") }}
      </l-button>
    </view>
  </view>
</template>

<script lang="uts">
  /**
   * ACP 权限审批卡片
   *
   * 示例页面：
   *   路由  /pages/test-intervention/test-intervention
   *   H5    {域名}/m/#/pages/test-intervention/test-intervention
   * 详见 components/agent-intervention/README.md
   */
  import { t } from "@/utils/i18n.uts";
  import type {
    AcpPermissionInteraction,
    AcpPermissionResponse,
    AcpPermissionOption,
  } from "@/types/intervention";
  import DiffContentView from "@/components/diff-list-view/components/diff-content-view/diff-content-view.uvue";
  import {
    normalizeFileDiffItems,
    getFileDiffTotalStats,
    getFileDiffLines,
  } from "@/utils/fileChangeDiff.uts";

  const HIDDEN_OPTION_KINDS = new Set(["reject_always"]);

  export default {
    name: "AcpPermissionCard",
    components: {
      DiffContentView,
    },
    props: {
      interaction: {
        type: Object as () => AcpPermissionInteraction,
        required: true,
      },
    },
    emits: ["respond"],
    data() {
      return {
        activeIndex: 0,
      };
    },
    watch: {
      // interaction 切换时重置选中项（对齐 PC 端 useEffect activeIndex=0）
      "interaction.request.sessionId"() {
        this.activeIndex = 0;
      },
    },
    computed: {
      title(): string {
        const rawInput = this.interaction?.request?.toolCall?.rawInput;
        if (rawInput != null && typeof rawInput === 'object') {
          const cmd = (rawInput as Record<string, any>)['command'];
          if (typeof cmd === 'string' && cmd.length > 0) {
            return cmd;
          }
        }
        return (
          this.interaction?.request?.toolCall?.title ||
          t("Mobile.Intervention.AcpPermission.defaultTitle")
        );
      },
      visibleOptions(): AcpPermissionOption[] {
        if (!this.interaction?.request?.options) return [];
        const list = this.interaction.request.options.filter(
          (opt: AcpPermissionOption) => !HIDDEN_OPTION_KINDS.has(opt.kind),
        );
        const getAcpPermissionShortcutHint = (kind: string): string => {
          if (kind === "allow_once") return "1";
          if (kind === "allow_always") return "2";
          if (kind === "reject_once") return "3";
          return "9";
        };
        return list.sort(
          (a: AcpPermissionOption, b: AcpPermissionOption): number => {
            const orderA = getAcpPermissionShortcutHint(a.kind);
            const orderB = getAcpPermissionShortcutHint(b.kind);
            return orderA.localeCompare(orderB);
          },
        );
      },
      rejectOption(): AcpPermissionOption | null {
        if (!this.interaction?.request?.options) return null;
        const found = this.interaction.request.options.find(
          (o: AcpPermissionOption) => o.kind.startsWith("reject"),
        );
        return found || null;
      },
      permissionDiffItems(): any[] {
        const toolCall = this.interaction?.request?.toolCall;
        const rawInput = toolCall?.rawInput;
        return normalizeFileDiffItems({
          input: rawInput,
          rawInput,
          toolCall,
        });
      },
      primaryPermissionDiff(): any | null {
        return this.permissionDiffItems.length > 0
          ? this.permissionDiffItems[0]
          : null;
      },
      permissionDiffStats(): any {
        return getFileDiffTotalStats(this.permissionDiffItems);
      },
      primaryPermissionDiffLines(): any[] {
        const file = this.primaryPermissionDiff;
        return file ? getFileDiffLines(file) : [];
      },
    },
    methods: {
      t,
      setActiveIndex(index: number) {
        if (this.interaction?.responseStatus !== "pending") return;
        this.activeIndex = index;
      },
      handleConfirm() {
        if (this.interaction?.responseStatus !== "pending") return;
        const activeOption = this.visibleOptions[this.activeIndex];
        if (!activeOption) return;
        const response: AcpPermissionResponse = {
          outcome: {
            outcome: "selected",
            optionId: activeOption.optionId,
          },
        };
        this.interaction.selectedOptionId = activeOption.optionId;
        this.$emit("respond", response);
      },
      handleCancel() {
        if (this.interaction?.responseStatus !== "pending") return;
        const reject = this.rejectOption;
        if (!reject) return;
        const response: AcpPermissionResponse = {
          outcome: {
            outcome: "selected",
            optionId: reject.optionId,
          },
        };
        this.interaction.selectedOptionId = reject.optionId;
        this.$emit("respond", response);
      },
      getOptionLabel(option: AcpPermissionOption): string {
        const camelCaseKind = option.kind.replace(
          /_([a-z])/g,
          (_: string, letter: string): string => letter.toUpperCase(),
        );
        const i18nKey = `Mobile.Intervention.AcpPermission.${camelCaseKind}`;
        const translated = t(i18nKey);
        if (translated !== i18nKey) {
          return translated;
        }
        return option.name || option.optionId;
      },
    },
  };
</script>

<style lang="scss" scoped>
  // 卡片容器及公共样式
  $card-bg-color: #fff;
  $card-border-radius: 16rpx;
  $card-padding: 24rpx;
  $card-margin: 8rpx;
  $card-box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  // 基础颜色
  $primary-color: #1677ff;
  $success-color: #52c41a;
  $danger-color: #ff4d4f;

  // 字体颜色及字号
  $text-color-primary: #1a1a1a;
  $text-color-secondary: #666;
  $font-size-title: 30rpx;
  $font-size-status: 24rpx;

  // 按钮样式
  $button-border-radius: 16rpx;
  $button-border-radius-double: 32rpx;

  .acp-permission-card {
    background-color: $card-bg-color;
    border-radius: $card-border-radius;
    padding: $card-padding;
    margin: $card-margin;
    box-shadow: $card-box-shadow;

    .card-header {
      display: flex;
      flex-direction: row;
      align-items: center;
      margin-bottom: 20rpx;

      .card-title-wrap {
        flex: 1;

        .card-eyebrow {
          font-size: 22rpx;
          font-weight: 500;
          color: $primary-color;
          margin-bottom: 6rpx;
          display: block;
        }

        .card-title {
          font-size: $font-size-title;
          font-weight: 600;
          color: $text-color-primary;
        }
      }
    }

    .status-tag {
      display: flex;
      flex-direction: row;
      align-items: center;
      padding: 8rpx 16rpx;
      border-radius: 8rpx;
      margin-bottom: 16rpx;

      &.status-submitted {
        background-color: #f6ffed;
      }

      &.status-failed {
        background-color: #fff2f0;
      }

      .status-icon {
        font-size: 28rpx;
        margin-right: 8rpx;

        &.status-icon-success {
          color: $success-color;
        }

        &.status-icon-failed {
          color: $danger-color;
        }
      }

      .status-tag-text {
        font-size: $font-size-status;
      }
    }

    .permission-diff-block {
      border: 1rpx solid #e8eaed;
      border-radius: 12rpx;
      overflow: hidden;
      margin-bottom: 18rpx;
      background-color: #fff;

      .permission-diff-summary {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        padding: 14rpx 18rpx;
        background-color: #f7f8fa;
        gap: 14rpx;
      }

      .permission-diff-path {
        flex: 1;
        min-width: 0;
        color: #333;
        font-size: 24rpx;
        line-height: 34rpx;
        font-weight: 500;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .permission-diff-stats {
        flex-shrink: 0;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10rpx;
      }

      .permission-diff-added {
        color: #1a7f37;
        font-size: 22rpx;
        line-height: 30rpx;
        font-weight: 600;
      }

      .permission-diff-removed {
        color: #cf222e;
        font-size: 22rpx;
        line-height: 30rpx;
        font-weight: 600;
      }

      .permission-diff-preview {
        max-height: 360rpx;
        background-color: #fff;
      }
    }

    .card-actions {
      display: flex;
      flex-direction: column;
      gap: 8rpx;
      margin-top: 8rpx;
      margin-bottom: 16rpx;

      .card-action-item {
        display: flex;
        flex-direction: row;
        align-items: center;
        padding: 16rpx 20rpx;
        border-radius: 12rpx;
        background-color: #f7f8fa;
        gap: 16rpx;

        &.item-active {
          background-color: #e8f0fe;

          .option-index {
            background-color: $primary-color;

            .option-index-text {
              color: #fff;
            }
          }

          .option-label {
            color: $primary-color;
            font-weight: 600;
          }
        }

        .option-index {
          flex-shrink: 0;
          width: 36rpx;
          height: 36rpx;
          border-radius: 50%;
          background-color: #e0e0e0;
          display: flex;
          align-items: center;
          justify-content: center;

          .option-index-text {
            font-size: 22rpx;
            font-weight: 700;
            color: $text-color-secondary;
            line-height: 1;
          }
        }

        .option-label {
          flex: 1;
          font-size: 28rpx;
          color: $text-color-primary;
        }
      }
    }

    .card-footer {
      display: flex;
      flex-direction: row;
      justify-content: flex-end;
      align-items: center;
      gap: 16rpx;
      padding-top: 16rpx;
      border-top: 2rpx solid #f0f0f0;

      .footer-cancel-btn {
        flex-shrink: 0;
      }

      .footer-confirm-btn {
        flex-shrink: 0;
      }
    }

    /* #ifndef APP-ANDROID || APP-IOS || APP-HARMONY */
    ::v-deep .l-button {
      border: 0 !important;
      border-radius: $button-border-radius !important;
      overflow: visible !important;
    }
    ::v-deep .l-button::after {
      border-radius: $button-border-radius-double !important;
    }
    /* #endif */
  }
</style>

import type { MessageInfo } from "@/types/interfaces/conversationInfo.uts";
import type {
  AcpPermissionInteraction,
  InterventionStatus,
  InterventionCardKind,
  McpAskInteraction,
} from "@/types/intervention";

export interface AcpPermissionDockItem {
  key: string;
  kind: InterventionCardKind;
  interaction: AcpPermissionInteraction;
}

export interface McpAskDockItem {
  key: string;
  kind: InterventionCardKind;
  message: MessageInfo;
  interaction: McpAskInteraction;
}

const isActiveInterventionStatus = (status?: string): boolean => {
  const value = status || "pending";
  return value === "pending" || value === "submitting" || value === "failed";
};

const getPendingAcpPermissionToolCallIds = (
  messageList: MessageInfo[],
): Set<string> => {
  const ids = new Set<string>();
  messageList.forEach((item: MessageInfo) => {
    const interactions = item.acpPermissionInteractions || [];
    interactions.forEach((interaction: AcpPermissionInteraction) => {
      if (!isActiveInterventionStatus(interaction.responseStatus)) return;
      const toolCallId = interaction.request?.toolCall?.toolCallId;
      if (toolCallId) ids.add(toolCallId);
    });
  });
  return ids;
};

const filterVisibleMcpAskInteractions = (
  interactions: McpAskInteraction[],
  pendingToolCallIds: Set<string>,
): McpAskInteraction[] => {
  const activeInteractions = interactions.filter(
    (interaction: McpAskInteraction) =>
      isActiveInterventionStatus(interaction.responseStatus),
  );
  if (!pendingToolCallIds.size) return activeInteractions;

  return activeInteractions.filter((interaction: McpAskInteraction) => {
    return (
      !interaction.toolCallId ||
      !pendingToolCallIds.has(interaction.toolCallId)
    );
  });
};

export const getVisibleMcpAskInteractions = (
  item: MessageInfo,
): McpAskInteraction[] => {
  const interactions = item.mcpAskInteractions || [];
  if (!interactions.length) return [];

  return filterVisibleMcpAskInteractions(
    interactions,
    getPendingAcpPermissionToolCallIds([item]),
  );
};

export const getActiveAcpPermissionDockItems = (
  messageList: MessageInfo[],
): AcpPermissionDockItem[] => {
  const items: AcpPermissionDockItem[] = [];
  messageList.forEach((message: MessageInfo) => {
    const interactions = message.acpPermissionInteractions || [];
    interactions.forEach((interaction: AcpPermissionInteraction) => {
      if (!isActiveInterventionStatus(interaction.responseStatus)) return;
      items.push({
        key: `acp:${interaction.id}`,
        kind: "acp_permission",
        interaction,
      });
    });
  });
  return items;
};

export const getVisibleMcpAskDockItems = (
  messageList: MessageInfo[],
): McpAskDockItem[] => {
  const items: McpAskDockItem[] = [];
  const pendingToolCallIds = getPendingAcpPermissionToolCallIds(messageList);

  messageList.forEach((message: MessageInfo) => {
    const interactions = filterVisibleMcpAskInteractions(
      message.mcpAskInteractions || [],
      pendingToolCallIds,
    );
    interactions.forEach((interaction: McpAskInteraction) => {
      items.push({
        key: `ask:${interaction.requestId}:${interaction.revision || 1}`,
        kind: "mcp_ask",
        message,
        interaction,
      });
    });
  });
  return items;
};

export const updateMcpAskInteractionStatusInMessageList = (
  messageList: MessageInfo[],
  interaction: McpAskInteraction,
  responseStatus: InterventionStatus,
): MessageInfo[] => {
  const revision = interaction.revision || 1;
  const list = [...messageList];
  for (let msgIndex = 0; msgIndex < list.length; msgIndex++) {
    const msg = list[msgIndex];
    const interactions = msg.mcpAskInteractions;
    if (!interactions) continue;

    let matched = false;
    const nextInteractions = interactions.map((item: McpAskInteraction) => {
      if (
        item.requestId === interaction.requestId &&
        (item.revision || 1) === revision
      ) {
        matched = true;
        return { ...item, responseStatus };
      }
      return item;
    });

    if (!matched) continue;

    list[msgIndex] = {
      ...msg,
      mcpAskInteractions: nextInteractions,
    };
    break;
  }
  return list;
};

export const removeMcpAskInteractionFromMessageList = (
  messageList: MessageInfo[],
  interaction: McpAskInteraction,
): MessageInfo[] => {
  const revision = interaction.revision || 1;
  const list = [...messageList];
  for (let msgIndex = 0; msgIndex < list.length; msgIndex++) {
    const msg = list[msgIndex];
    const interactions = msg.mcpAskInteractions;
    if (!interactions) continue;

    const nextInteractions = interactions.filter(
      (item: McpAskInteraction) =>
        !(
          item.requestId === interaction.requestId &&
          (item.revision || 1) === revision
        ),
    );
    if (nextInteractions.length === interactions.length) continue;

    list[msgIndex] = {
      ...msg,
      mcpAskInteractions: nextInteractions.length
        ? nextInteractions
        : undefined,
    };
    break;
  }
  return list;
};

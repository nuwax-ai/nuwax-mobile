/**
 * MCP Ask schema and tool input helpers (nuwax.interaction.v2).
 * Keeps SSE, history hydration, resume formatting, and card rendering aligned.
 *
 * v2:表单为有序自描述数组 ui.fields[];不再有 schema/uiSchema/ui:widget/enum。
 */
import type {
  InteractionUiOptions,
  InteractionUiSchema,
  InteractionUiStep,
  McpAskFieldOption,
  McpAskFormField,
  McpAskInteraction,
  McpAskWidget,
} from "@/types/intervention";
import { MCP_ASK_TOOL_NAME, MCP_ASK_WIDGET_TYPES } from "@/types/intervention";

export const MCP_ASK_SCHEMA_VERSION = "nuwax.mcp_ask.v2";
export const INTERACTION_UI_SCHEMA_VERSION = "nuwax.interaction.v2";
export { MCP_ASK_TOOL_NAME };

/**
 * 解析后的字段:形状对齐渲染层(mcp-ask-question-card.uvue 的 toParsedField)读取路径。
 * property 为从 v2 McpAskFormField 重建的 JsonSchema 约束视图。
 */
export interface ParsedMcpAskField {
  name: string;
  property: any;
  widget: McpAskWidget;
  required: boolean;
  options: InteractionUiOptions;
  enumValues: string[];
  enumLabels: string[];
  isInteger: boolean;
}

function asRecord(value: any): Record<string, unknown> | null {
  if (value !== null && value !== undefined && typeof value === "object") {
    return value as Record<string, unknown>;
  }
  return null;
}

function maybeParseRawInput(raw: any): any {
  if (typeof raw !== "string") return raw;
  try {
    return JSON.parse(raw);
  } catch (_) {
    return null;
  }
}

function isKnownWidget(widget: string): boolean {
  return (MCP_ASK_WIDGET_TYPES as readonly string[]).includes(widget);
}

function isFieldOption(opt: any): boolean {
  return (
    opt !== null &&
    opt !== undefined &&
    typeof opt === "object" &&
    typeof (opt as McpAskFieldOption).value === "string" &&
    typeof (opt as McpAskFieldOption).label === "string"
  );
}

/** 把 v2 字段重建为 JsonSchema 约束视图(toParsedField 读 minimum/maximum/type/title)。 */
function buildProperty(field: McpAskFormField): any {
  return {
    type: field.type,
    title: field.title,
    description: field.description,
    minimum: field.minimum,
    maximum: field.maximum,
    multipleOf: field.multipleOf,
    minLength: field.minLength,
    maxLength: field.maxLength,
  };
}

function buildOptions(field: McpAskFormField): InteractionUiOptions {
  return {
    placeholder: field.placeholder,
    allowCustom: field.allowCustom,
    otherValue: field.otherValue,
    otherField: field.otherField,
    accept: field.accept,
    multiple: field.multiple,
  };
}

function parseField(field: McpAskFormField): ParsedMcpAskField {
  const rawOptions = Array.isArray(field.options) ? field.options : [];
  const options = rawOptions.filter(isFieldOption) as McpAskFieldOption[];
  const widget = isKnownWidget(field.widget) ? field.widget : ("text" as McpAskWidget);
  return {
    name: field.name,
    property: buildProperty(field),
    widget: widget,
    required: field.required === true,
    options: buildOptions(field),
    enumValues: options.map((opt: McpAskFieldOption): string => opt.value),
    enumLabels: options.map((opt: McpAskFieldOption): string => opt.label),
    isInteger: getJsonSchemaPrimaryType({ type: field.type }) === "integer",
  };
}

/**
 * 解析 v2 表单字段:遍历 ui.fields[],数组顺序即展示顺序。
 * 传入 fieldNames(wizard 步骤)时按其顺序与名称过滤。
 */
export function parseInteractionFields(
  ui: InteractionUiSchema,
  fieldNames?: string[],
): ParsedMcpAskField[] {
  const rawFields = Array.isArray(ui.fields) ? ui.fields : [];
  const allFields = rawFields as McpAskFormField[];
  if (!fieldNames || fieldNames.length === 0) {
    return allFields.map(
      (field: McpAskFormField): ParsedMcpAskField => parseField(field),
    );
  }
  const result: ParsedMcpAskField[] = [];
  fieldNames.forEach((name: string) => {
    const found = allFields.find(
      (f: McpAskFormField): boolean => f.name === name,
    );
    if (found) {
      result.push(parseField(found));
    }
  });
  return result;
}

export function getInteractionSteps(
  ui: InteractionUiSchema,
): InteractionUiStep[] {
  if (ui.steps && ui.steps.length > 0) return ui.steps;

  const rawFields = Array.isArray(ui.fields) ? ui.fields : [];
  const allFields = rawFields as McpAskFormField[];
  if (allFields.length === 0) return [];

  const fieldNames = allFields.map((f: McpAskFormField): string => f.name);
  return [
    {
      id: "default",
      title: ui.title,
      description: ui.description,
      fields: fieldNames,
    },
  ];
}

export function isWizardPresentation(ui: InteractionUiSchema): boolean {
  return ui.presentation === "wizard" || (!!ui.steps && ui.steps.length > 1);
}

/** 是否允许跳过:v2 由 ui.allowSkip 顶层字段控制(旧 v1 的 uiSchema.ui:options.allowSkip 已移除)。 */
export function isSkipAllowed(ui: InteractionUiSchema): boolean {
  return ui.allowSkip === true;
}

export function getSkipLabel(ui: InteractionUiSchema): string | undefined {
  return ui.skipLabel;
}

/** JSON Schema 主类型(忽略 null 联合)。parseField 用于判断 integer。 */
export function getJsonSchemaPrimaryType(property: any): string {
  if (Array.isArray(property?.type)) {
    const match = (property.type as string[]).find(
      (item: string): boolean => item !== "null",
    );
    return match || "string";
  }
  return property?.type || "string";
}

export function extractMcpAskStructuredInputFromResult(
  result: any,
): Record<string, unknown> | null {
  const data = result?.data;
  if (!Array.isArray(data)) return null;

  for (const item of data) {
    if (!item || typeof item !== "object") continue;
    const content = (item as any).content;
    if (content?.type !== "text" || typeof content.text !== "string") continue;

    // 前置快速校验：只有以 { 开头才可能是 JSON 对象，避免对 markdown 等非 JSON 文本做无用解析
    const trimmed = content.text.trim();
    if (!trimmed.startsWith("{")) continue;

    try {
      const parsed = JSON.parse(content.text);
      const input = parsed?.input;
      if (input && typeof input === "object" && Object.keys(input).length > 0) {
        return input as Record<string, unknown>;
      }
    } catch (_) {
      // 非 JSON,跳过
    }
  }
  return null;
}

/**
 * 仅支持 v2:优先 schemaVersion,其次 ui.version 推断。非 v2 返回 null。
 */
function resolveSchemaVersion(record: Record<string, unknown>): string | null {
  const schemaVersion = (record as any).schemaVersion;
  if (
    typeof schemaVersion === "string" &&
    schemaVersion === MCP_ASK_SCHEMA_VERSION
  ) {
    return schemaVersion;
  }

  const ui = asRecord((record as any).ui);
  const uiVersion = ui ? (ui as any).version : null;
  if (
    typeof uiVersion === "string" &&
    uiVersion === INTERACTION_UI_SCHEMA_VERSION
  ) {
    return MCP_ASK_SCHEMA_VERSION;
  }

  // 兜底:agent 按"服务端盖戳"约定省略 schemaVersion/ui.version 时,识别裸 v2。
  // v2 强信号 = 有 ui.fields 且无 v1 的 ui.schema。
  if (ui && Array.isArray((ui as any).fields) && !(ui as any).schema) {
    return MCP_ASK_SCHEMA_VERSION;
  }

  return null;
}

export function parseMcpAskToolInput(raw: any): any | null {
  const record = asRecord(maybeParseRawInput(raw));
  if (!record) return null;

  const schemaVersion = resolveSchemaVersion(record);
  if (!schemaVersion) return null;

  const toolName = (record as any).toolName || MCP_ASK_TOOL_NAME;
  if (toolName !== MCP_ASK_TOOL_NAME) {
    return null;
  }

  const ui = asRecord((record as any).ui);
  if (
    typeof (record as any).requestId !== "string" ||
    (record as any).requestId.length === 0 ||
    typeof (record as any).revision !== "number" ||
    (record as any).revision <= 0 ||
    Math.floor((record as any).revision) !== (record as any).revision ||
    typeof (record as any).sessionId !== "string" ||
    (record as any).sessionId.length === 0 ||
    typeof (record as any).title !== "string" ||
    (record as any).title.length === 0 ||
    !ui
  )
    return null;

  // 版本识别已在 resolveSchemaVersion 完成(含裸 v2 推断);此处只校验 v2 形状。
  // v2:表单定义为 fields[](inline/modal)或 steps[](wizard)
  const hasFields =
    Array.isArray((ui as any).fields) && (ui as any).fields.length > 0;
  const hasSteps =
    Array.isArray((ui as any).steps) && (ui as any).steps.length > 0;
  if (!hasFields && !hasSteps) return null;

  return {
    ...record,
    schemaVersion,
    toolName,
  };
}

export function createMcpAskInteractionFromToolInput(
  rawInput: any,
  toolCallId?: string,
): McpAskInteraction | null {
  const input = parseMcpAskToolInput(rawInput);
  if (!input) return null;

  const ui = input.ui as InteractionUiSchema;
  return {
    toolName: input.toolName,
    schemaVersion: input.schemaVersion,
    requestId: input.requestId,
    revision: input.revision,
    sessionId: input.sessionId,
    toolCallId,
    title: input.title || ui.title || "",
    description: input.description || ui.description,
    ui,
    responseStatus: "pending",
    triggeredAt: Date.now(),
  };
}

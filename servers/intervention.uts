import { RequestResponse } from "@/types/interfaces/request";
import request from "@/servers/useRequest";

/** 权限审批回调参数 */
export interface AgentInterventionRespondParams {
  interventionId: string;
  permission_resolve_request: {
    request_permission_response: {
      outcome: {
        Selected?: { option_id: string };
        Cancelled?: null;
      };
    };
    session_id?: string;
    tool_call_id?: string;
    save_rule: boolean;
  };
  conversation_id?: number;
}

/**
 * 权限审批回调
 * 对齐 agent-platform /api/agent/conversation/chat/permission-request/response
 */
export async function apiAgentInterventionRespond(
  params: AgentInterventionRespondParams,
) {
  const permissionRequest = params.permission_resolve_request;
  const outcome = permissionRequest.request_permission_response.outcome;
  const selected = outcome.Selected;
  const fallbackOptionId =
    outcome.Cancelled !== undefined ? "reject" : undefined;

  return request<RequestResponse<null>>({
    url: "/api/agent/conversation/chat/permission-request/response",
    method: "POST",
    data: {
      conversationId: params.conversation_id,
      toolId: permissionRequest.tool_call_id,
      option: {
        optionId: selected?.option_id || fallbackOptionId,
        outcome: selected ? "selected" : "cancelled",
      },
    },
  });
}

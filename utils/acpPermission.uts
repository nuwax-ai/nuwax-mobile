import type {
  LegacyAcpPermissionInterventionRequest,
  RcoderAcpPermissionInteraction,
  RcoderNotifyResolvedRequest,
  RcoderPermissionProgressData,
  RcoderPermissionToolCall,
  RcoderRequestPermissionResponse,
} from "@/types/interfaces/acpPermission";

const isRecord = (value: any): boolean => {
  return !!value && typeof value === "object" && !Array.isArray(value);
};

const toSnakeCaseToolCall = (toolCall: any): RcoderPermissionToolCall => {
  return {
    tool_call_id: toolCall?.tool_call_id || toolCall?.toolCallId || "",
    kind: toolCall?.kind || "tool",
    status: toolCall?.status || "pending",
    title: toolCall?.title || toolCall?.kind || "tool",
    content: Array.isArray(toolCall?.content) ? toolCall.content : [],
    raw_input: toolCall?.raw_input ?? toolCall?.rawInput ?? {},
    _meta: toolCall?._meta || {},
  };
};

const isRcoderPermissionProgressData = (
  value: any,
): value is RcoderPermissionProgressData => {
  if (!isRecord(value)) return false;

  const request = value.request_permission_request;
  if (!isRecord(request)) return false;

  const toolCall = request.tool_call;
  return (
    typeof request.session_id === "string" &&
    request.session_id.length > 0 &&
    isRecord(toolCall) &&
    typeof toolCall.tool_call_id === "string" &&
    toolCall.tool_call_id.length > 0 &&
    Array.isArray(request.options)
  );
};

const normalizeLegacyAcpData = (
  value: any,
): {
  permission: RcoderPermissionProgressData;
  legacyIntervention: LegacyAcpPermissionInterventionRequest;
} | null => {
  if (!isRecord(value)) return null;

  const request = value?.acp?.request;
  if (!isRecord(request)) return null;

  const toolCall = isRecord(request.toolCall) ? request.toolCall : {};
  const sessionId = request.sessionId;
  const toolCallId = toolCall.toolCallId;
  if (typeof sessionId !== "string" || typeof toolCallId !== "string") {
    return null;
  }

  const options = Array.isArray(request.options)
    ? request.options.map((option: any) => {
        return {
          option_id: option?.option_id || option?.optionId || "",
          name: option?.name || option?.optionId || "",
          kind: option?.kind || "allow_once",
          _meta: option?._meta || {},
        };
      })
    : [];

  return {
    permission: {
      request_permission_request: {
        session_id: sessionId,
        tool_call: toSnakeCaseToolCall(toolCall),
        options,
        _meta: request?._meta || {},
      },
      tool_call_id: toolCallId,
      _meta: {
        nuwax_intervention_id: value.id,
        nuwax_revision: value.revision,
      },
    },
    legacyIntervention: value as LegacyAcpPermissionInterventionRequest,
  };
};

export const getRcoderPermissionInteractionId = (
  permission: RcoderPermissionProgressData,
): string => {
  const request = permission.request_permission_request;
  return `${request.session_id}:${request.tool_call.tool_call_id}`;
};

export const normalizeAcpPermissionProgressMessage = (
  message: any,
): RcoderAcpPermissionInteraction | null => {
  if (!isRecord(message)) return null;

  const messageType = message.messageType || message.message_type;
  const subType = message.subType || message.sub_type;
  if (
    messageType !== "acpRequestPermission" ||
    (subType !== "request_permission" &&
      subType !== "session/request_permission")
  ) {
    return null;
  }

  const data = message.data;
  if (isRcoderPermissionProgressData(data)) {
    return {
      id: getRcoderPermissionInteractionId(data),
      permission: data,
      responseStatus: "pending",
    };
  }

  const legacy = normalizeLegacyAcpData(data);
  if (!legacy) return null;

  return {
    id: getRcoderPermissionInteractionId(legacy.permission),
    permission: legacy.permission,
    responseStatus: "pending",
    legacyIntervention: legacy.legacyIntervention,
  };
};

export const getSelectedOptionId = (
  response: RcoderRequestPermissionResponse,
): string => {
  const outcome = response?.outcome as any;
  if (outcome && outcome.Selected && typeof outcome.Selected.option_id === "string") {
    return outcome.Selected.option_id;
  }
  return "";
};

export const buildNotifyResolvedRequest = (
  interaction: RcoderAcpPermissionInteraction,
  response: RcoderRequestPermissionResponse,
  options?: { saveRule?: boolean; projectId?: string },
): any => {
  const legacy = interaction.legacyIntervention;
  const selectedOptionId = getSelectedOptionId(response);

  if (legacy?.id) {
    return {
      interventionId: legacy.id,
      revision: legacy.revision,
      source: legacy.source || "acp_permission",
      protocol: legacy.protocol || "acp",
      callbackTarget: legacy.callbackTarget,
      action: selectedOptionId ? "submit" : "cancel",
      acpResponse: selectedOptionId
        ? {
            outcome: {
              outcome: "selected",
              optionId: selectedOptionId,
            },
          }
        : {
            outcome: {
              outcome: "cancelled",
            },
          },
    };
  }

  const request = interaction.permission.request_permission_request;
  const payload: RcoderNotifyResolvedRequest = {
    permission_resolve_request: {
      request_permission_response: response,
      session_id: request.session_id,
      tool_call_id: request.tool_call.tool_call_id,
      save_rule: !!options?.saveRule,
    },
  };

  if (options?.projectId) {
    payload.project_id = options.projectId;
  }

  return payload;
};

  /**
   * 更新配置
   */
  updateConfig(config: UTSJSONObject): void {
    const apiUrl = config["apiUrl"];
    if (apiUrl != null) {
      this.config.apiUrl = apiUrl as string;
    }
    const timeout = config["timeout"];
    if (timeout != null) {
      this.config.timeout = timeout as number;
    }
    const language = config["language"];
    if (language != null) {
      this.config.language = language as string;
    }
    const enableRetry = config["enableRetry"];
    if (enableRetry != null) {
      this.config.enableRetry = enableRetry as boolean;
    }
    const maxRetries = config["maxRetries"];
    if (maxRetries != null) {
      this.config.maxRetries = maxRetries as number;
    }
    const retryDelay = config["retryDelay"];
    if (retryDelay != null) {
      this.config.retryDelay = retryDelay as number;
    }
  }

  /**
   * 获取当前配置
   */
  getConfig(): UploadConfig {
    return this.config;
  }
}

/**
 * 创建音频上传器实例
 */
export function createAudioUploader(
  config: UTSJSONObject | null = null,
): AudioUploader {
  return new AudioUploader(config);
}

/**
 * 内存管理器
 * 用于清理临时音频文件和管理内存使用
 */
export class MemoryManager {
  private static audioFiles: string[] = [] as string[];
  private static readonly MAX_FILES: number = 3;

  /**
   * 添加音频文件到管理列表
   */
  static addAudioFile(filePath: string): void {
    MemoryManager.audioFiles.push(filePath);

    // 如果文件数量超过限制，清理最老的文件
    if (MemoryManager.audioFiles.length > MemoryManager.MAX_FILES) {
      const oldestFile = MemoryManager.audioFiles[0];
      MemoryManager.cleanupAudioFile(oldestFile);
    }
  }

  /**
   * 清理音频文件
   */
  static cleanupAudioFile(filePath: string): void {
    if (filePath.length == 0) return;

    try {
      // 从管理列表中移除
      const idx = MemoryManager.audioFiles.indexOf(filePath);
      if (idx >= 0) {
        MemoryManager.audioFiles.splice(idx, 1);
      }

      // 如果是临时文件URL，释放内存（仅H5平台）
      // #ifdef H5
      if (filePath.startsWith("blob:")) {
        URL.revokeObjectURL(filePath);
      }
      // #endif

      // #ifdef H5 || WEB
      // 尝试删除临时文件
      uni.removeSavedFile({
        filePath: filePath,
        success: () => {
          console.log("清理音频文件成功:", filePath);
        },
        fail: (error) => {
          console.warn("清理音频文件失败:", error);
        },
      });
      // #endif
    } catch (error) {
      console.warn("清理音频文件时发生错误:", error);
    }
  }

  /**
   * 清理所有音频文件
   */
  static cleanupAllAudioFiles(): void {
    const snapshot = MemoryManager.audioFiles;
    for (let i = 0; i < snapshot.length; i++) {
      MemoryManager.cleanupAudioFile(snapshot[i]);
    }
    MemoryManager.audioFiles = [] as string[];
  }

  /**
   * 获取当前文件数量
   */
  static getFileCount(): number {
    return MemoryManager.audioFiles.length;
  }
}

/**
 * 工具函数：将音频文件转换为Base64
 */
export function audioFileToBase64(filePath: string): Promise<string> {
  return new Promise((resolve, reject) => {
    const fileManager = uni.getFileSystemManager();

    fileManager.readFile({
      filePath: filePath,
      encoding: "base64",
      success: (res) => {
        resolve(res.data as string);
      },
      fail: (error) => {
        const reasonVal = error.errMsg == null ? "" : (error.errMsg as string);
        const reasonParams = new Map<string, string | number>();
        reasonParams.set("reason", reasonVal);
        reject(
          new Error(
            t("Mobile.AudioUploader.fileReadFailed", reasonParams),
          ),
        );
      },
    });
  });
}

/**
 * 工具函数：检查音频文件格式
 */
export function validateAudioFormat(format: string): boolean {
  const supportedFormats = ["mp3", "wav", "aac", "PCM", "webm"];
  return supportedFormats.includes(format.toLowerCase());
}

/**
 * 工具函数：格式化文件大小
 */
export function formatFileSize(bytes: number): string {
  if (bytes == 0) return "0 B";

  const k = 1024;
  const sizes = ["B", "KB", "MB", "GB"];
  const i = Math.floor(Math.log(bytes) / Math.log(k));

  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + " " + sizes[i];
}

/**
 * 工具函数：格式化时长
 */
export function formatDuration(seconds: number): string {
  const minutes = Math.floor(seconds / 60);
  const remainingSeconds = Math.floor(seconds % 60);

  if (minutes > 0) {
    return `${minutes}:${remainingSeconds.toString().padStart(2, "0")}`;
  } else {
    return `${remainingSeconds}s`;
  }
}

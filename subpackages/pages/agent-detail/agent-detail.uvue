<template>
	<chat-conversation-component ref="chatConversationComponentRef" />
</template>

<script setup lang="uts">
	import ChatConversationComponent from '@/subpackages/pages/chat-conversation-component/chat-conversation-component.uvue'
	import { ref, onUnmounted, getCurrentInstance } from 'vue'
	import { getCurrentPageFullPath } from '@/utils/common'
	import { onAddToFavorites, onShow, onHide, onShareAppMessage } from '@dcloudio/uni-app'

	const instance = getCurrentInstance()
	const chatConversationComponentRef = ref<any | null>(null)

	onShow(() => {
        // #ifndef MP-WEIXIN
        const comp = chatConversationComponentRef.value
        if (comp != null) {
            const fn = (comp as UTSJSONObject)["triggerResume"] as (() => void) | null
            if (fn != null) {
                fn()
            }
        }
        // #endif
        // #ifdef MP-WEIXIN
        // 尝试通过实例获取引用，绕过闭包捕获问题
        // Const variable "chatConversationComponentRef" might not be captured by onShow in MP environment
        const proxy: any = instance?.proxy
        const componentRef = proxy?.$refs?.chatConversationComponentRef ? proxy?.$refs?.chatConversationComponentRef : proxy?.chatConversationComponentRef
        if (Boolean(componentRef)) {
            (componentRef as any).triggerResume?.()
        }
        // #endif
	})
	onHide(() => {
        // #ifndef MP-WEIXIN
        const comp = chatConversationComponentRef.value
        if (comp != null) {
            const fn = (comp as UTSJSONObject)["triggerHide"] as (() => void) | null
            if (fn != null) {
                fn()
            }
        }
        // #endif
        // #ifdef MP-WEIXIN
        const proxy: any = instance?.proxy
        const componentRef = proxy?.$refs?.chatConversationComponentRef ? proxy?.$refs?.chatConversationComponentRef : proxy?.chatConversationComponentRef
        if (Boolean(componentRef)) {
            (componentRef as any).triggerHide?.()
        }
        // #endif
	})

	onUnmounted(() => {
		/**
		 * 事件监听, 刷新首页，重新请求我的收藏数据
		 * 智能体主页中点击收藏或取消收藏后，返回首页，需要刷新首页数据
		 */
		uni.$emit('refreshData')
	})

	// #ifdef MP-WEIXIN
	// 转发给朋友
	onShareAppMessage(()=>{
        const proxy: any = instance?.proxy
        const componentRef = proxy?.$refs?.chatConversationComponentRef ? proxy?.$refs?.chatConversationComponentRef : proxy?.chatConversationComponentRef
		return {
			title: (componentRef?.getAgentInfo()?.name ?? name) || '',
			path: getCurrentPageFullPath(),
		}
	})

    // 收藏
    onAddToFavorites(()=>{
        const proxy: any = instance?.proxy
        const componentRef = proxy?.$refs?.chatConversationComponentRef ? proxy?.$refs?.chatConversationComponentRef : proxy?.chatConversationComponentRef
        return {
            title: (componentRef?.getAgentInfo()?.name ?? name) || '',
        }
    })
	// #endif
</script>

<style lang="scss" scoped>
</style>
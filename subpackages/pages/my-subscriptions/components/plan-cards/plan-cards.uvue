<template>
  <view class="plan-cards">
    <text class="section-title">{{ t("Mobile.MySubscriptions.planGrid") }}</text>

    <view class="cards-list">
      <view
        v-for="plan in plans"
        :key="plan.id"
        class="plan-card"
        :class="{ 'plan-current': plan.id === currentPlanId }"
      >
        <!-- 标签 -->
        <view class="plan-badges">
          <view v-if="plan.id === currentPlanId" class="badge badge-active">
            <text class="badge-text">{{ t("Mobile.MySubscriptions.currentPlan") }}</text>
          </view>
          <view v-else-if="plan.isHot" class="badge badge-hot">
            <text class="badge-text">{{ t("Mobile.MySubscriptions.statusHot") }}</text>
          </view>
        </view>

        <!-- 套餐信息 -->
        <text class="plan-name">{{ plan.name }}</text>
        <view class="plan-price-row">
          <text class="plan-price">¥{{ plan.price }}</text>
          <text class="plan-period">{{ getPeriodUnit(plan.period) }}</text>
        </view>
        <text class="plan-credits">{{ plan.creditAmount }} {{ t("Mobile.MySubscriptions.creditUnit") }}/{{ t("Mobile.MySubscriptions.creditsMonth") }}</text>

        <!-- 权益列表 -->
        <view class="benefits" v-if="plan.itemGroups && plan.itemGroups.length > 0">
          <view
            v-for="group in plan.itemGroups"
            :key="group.name"
            class="benefit-group"
          >
            <view
              v-for="item in group.items"
              :key="item.name"
              class="benefit-item"
            >
              <text class="benefit-icon" :class="item.selected ? 'icon-check' : 'icon-cross'">
                {{ item.selected ? '✓' : '✗' }}
              </text>
              <text class="benefit-text">{{ item.name }}</text>
            </view>
          </view>
        </view>

        <!-- 底部操作 -->
        <view class="plan-footer">
          <text v-if="plan.id === currentPlanId && currentEndTime" class="plan-renewal">
            {{ t("Mobile.MySubscriptions.nextRenewal", { time: currentEndTime }) }}
          </text>
          <view
            v-if="getButtonText(plan) && plan.price > 0"
            class="plan-btn"
            :class="{ 'plan-btn-processing': processingId === plan.id }"
            @tap="handleAction(plan)"
          >
            <text class="plan-btn-text">{{ getButtonText(plan) }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
  import type { SystemSubscriptionPlan } from '@/types/interfaces/subscription';
  import { SUCCESS_CODE } from '@/constants/codes.constants.uts';
  import { apiCreateSubscriptionOrder, apiGetOrderCashier } from '@/servers/subscription';
  import { useI18n } from '@/utils/i18n';
  import { getPeriodUnit } from '../../utils.uts';

  const { t } = useI18n();

  interface Props {
    plans: SystemSubscriptionPlan[];
    currentPlanId: number | null;
    currentEndTime: string | null;
  }

  const props = defineProps<Props>();
  const processingId = ref<number | null>(null);

  const getButtonText = (plan: SystemSubscriptionPlan): string | null => {
    if (plan.id === props.currentPlanId) {
      return t('Mobile.MySubscriptions.renewNow');
    }
    if (props.currentPlanId == null) {
      return t('Mobile.MySubscriptions.subscribeNow');
    }
    return t('Mobile.MySubscriptions.upgradeNow');
  };

  const handleAction = async (plan: SystemSubscriptionPlan) => {
    if (processingId.value === plan.id) return;
    processingId.value = plan.id;
    try {
      const orderRes = await apiCreateSubscriptionOrder({ planId: plan.id });
      if (orderRes.code === SUCCESS_CODE && orderRes.data) {
        const orderId = orderRes.data.id ?? orderRes.data;
        const cashierRes = await apiGetOrderCashier(orderId as number);
        if (cashierRes.code === SUCCESS_CODE && cashierRes.data) {
          const returnUrl = encodeURIComponent(window.location.href);
          window.location.href = `${cashierRes.data}?returnUrl=${returnUrl}`;
        }
      } else {
        uni.showToast({ title: t('Mobile.MySubscriptions.orderIdNotFound'), icon: 'none' });
      }
    } catch (e) {
      uni.showToast({ title: t('Mobile.MySubscriptions.loadFailed'), icon: 'none' });
    } finally {
      processingId.value = null;
    }
  };
</script>

<style lang="scss" scoped>
  @import './plan-cards.scss';
</style>

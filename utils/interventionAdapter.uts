/**
 * SSE 干预数据适配器
 * 从 SSE chunk 中提取 ACP Permission 和 MCP Ask 数据
 * 对齐 nuwax Web 版 applyAcpPermissionSseEvent + applyMcpAskToolCallSseEvent
 */
import type { AcpPermissionInteraction, AcpPermissionRequest, McpAskInteraction, InteractionUiSchema } from '@/types/intervention'

/** SSE chunk 中的数据结构（与 chatDataAdapter.uts 中的 SSEChunk 兼容） */
interface SSEEventData {
  messageType?: string
  message_type?: string
  subType?: string
  sub_type?: string
  eventType?: string
  data?: {
    id?: string
    ext?: unknown
    [key: string]: unknown
  }
  [key: string]: unknown
}

/**
 * 判断是否为 ACP Permission 事件
 * 对齐 backend SandboxAgentClient.isAcpPermissionEvent() 的识别逻辑
 */
export function isAcpPermissionEvent(chunk: SSEEventData): boolean {
  const messageType = chunk.messageType || (chunk as any).message_type
  const subType = chunk.subType || (chunk as any).sub_type

  // 直接匹配 messageType
  if (messageType === 'acpRequestPermission') {
    return true
  }
  // 匹配 subType
  if (subType === 'request_permission' || subType === 'AcpRequestPermission') {
    return true
  }
  return false
}

/**
 * 判断是否为 MCP Ask tool_call 事件
 * 对齐 nuwax Web 版 applyMcpAskToolCallSseEvent 的识别逻辑
 */
export function isMcpAskToolCallEvent(chunk: SSEEventData): boolean {
  const subType = chunk.subType || (chunk as any).sub_type
  if (subType !== 'tool_call' && subType !== 'tool_call_update') {
    return false
  }

  // 检查 rawInput 中的 schemaVersion
  const rawData = chunk as any
  const rawInput = rawData?.data?.ext?.rawInput || rawData?.rawInput
  if (!rawInput) return false

  return rawInput.schemaVersion === 'nuwaclaw.mcp_ask.v1'
}

/**
 * 从 ACP Permission SSE 事件中提取交互数据
 */
export function extractAcpPermissionInteraction(chunk: SSEEventData): AcpPermissionInteraction | null {
  if (!isAcpPermissionEvent(chunk)) return null

  const rawData = chunk as any
  const data = rawData.data || rawData

  // 尝试从 intervention 对象中提取（后端直接提供）
  if (data.intervention) {
    return data.intervention as AcpPermissionInteraction
  }

  // 从原始数据中构建（后端未直接提供 intervention 对象时）
  const request = data.request || data
  const options = request.options || []

  return {
    id: `itv_${Date.now()}_${Math.random().toString(36).substring(2, 9)}`,
    request: {
      sessionId: request.session_id || request.sessionId || '',
      toolCall: {
        toolCallId: request.tool_call_id || request.toolCallId || '',
        title: request.title || request.toolCall?.title || '',
        kind: request.kind || request.toolCall?.kind || '',
      },
      options: options.map((opt: any) => ({
        optionId: opt.option_id || opt.optionId || opt.id,
        kind: opt.kind || 'allow_once',
        name: opt.name || opt.label || opt.kind,
      })),
    },
    responseStatus: 'pending',
  }
}

/**
 * 从 MCP Ask tool_call 事件中提取交互数据
 */
export function extractMcpAskInteraction(chunk: SSEEventData): McpAskInteraction | null {
  if (!isMcpAskToolCallEvent(chunk)) return null

  const rawData = chunk as any
  const rawInput = rawData?.data?.ext?.rawInput || rawData?.rawInput
  if (!rawInput) return null

  const ui = rawInput.ui as InteractionUiSchema

  return {
    requestId: rawInput.requestId || '',
    title: rawInput.title || '',
    description: rawInput.description,
    ui: ui,
    responseStatus: 'pending',
  }
}

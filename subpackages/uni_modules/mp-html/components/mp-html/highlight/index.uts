/**
 * @fileoverview highlight 插件 (UTS stub for app-android)
 * PrismJS is not compatible with UTS — syntax highlighting is disabled on native platforms.
 */
export default class Highlight {
  vm: any | null = null;

  constructor(vm: any) {
    this.vm = vm;
  }

  onParse(node: any, vm: any): void {
    // PrismJS 不可用，native 端不高亮，no-op
  }
}

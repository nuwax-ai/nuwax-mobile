/**
 * @fileoverview Container 插件（UTS stub）
 * 原生端无自定义容器解析逻辑，实现 MpHtmlPlugin 以安全通过 parser 分发。
 */
import { MpHtmlPlugin, Parser } from '../parser.uts'

export default class Container implements MpHtmlPlugin {
  constructor(vm: any) {}

  onUpdate(content: string, config: UTSJSONObject): string {
    return content
  }

  onParse(node: UTSJSONObject, parser: Parser): boolean {
    return true
  }
}

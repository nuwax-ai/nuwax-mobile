<template>
  <view class="related-conversation">
    <view class="header">
      <text class="title">{{ t("Mobile.Conversation.relatedTitle") }}</text>
      <view class="view-all" @click="onViewAll(chatList)">
        <text class="view-all-text">{{
          t("Mobile.Conversation.viewAll")
        }}</text>
        <text class="iconfont icon-a-Chevronright" />
      </view>
    </view>
    <custom-nav-bar-speak :chat-list="chatListTop" />
  </view>
</template>

<script setup lang="uts">
  import { ref, computed, onMounted } from "vue";
  import type { ConversationInfo } from "@/types/interfaces/conversationInfo";
  import { SUCCESS_CODE } from "@/constants/codes.constants";
  import { apiAgentConversationList } from "@/servers/conversation";
  import CustomNavBarSpeak from "@/components/custom-nav-bar/custom-nav-bar-speak/custom-nav-bar-speak.uvue";
  import { useI18n } from "@/utils/i18n";

  const { t: tRaw } = useI18n();
  const t = (key: string): string => tRaw(key, new Map<string, any>(), "");

  // uvue 对复杂对象 prop（AgentDetailDto）存在 override 类型不匹配问题，改用 UTSJSONObject
  interface RelatedConversationProps {
    agentInfo: UTSJSONObject;
  }

  const props = defineProps<RelatedConversationProps>();

  // 定义自定义事件
  const emit = defineEmits<{
    "view-all": [data: ConversationInfo[]];
  }>();

  const chatList = ref<ConversationInfo[]>([]);

  // 取前 10 条（UTS 用循环构建，避免模板上对数组做 slice/?.  的 nullable 问题）
  const chatListTop = computed<ConversationInfo[]>((): ConversationInfo[] => {
    const src = chatList.value;
    const out: ConversationInfo[] = [] as ConversationInfo[];
    const limit = src.length >= 10 ? 10 : src.length;
    for (let i = 0; i < limit; i++) {
      out.push(src[i]);
    }
    return out;
  });

  // 查看全部处理
  const onViewAll = (data: ConversationInfo[]) => {
    emit("view-all", data);
  };

  // 查询用户历史会话
  const fetchUserConversationList = async () => {
    const a = props.agentInfo;
    const idVal = a["agentId"];
    const agentId = idVal != null ? (idVal as number) : 0;

    const params = { agentId: agentId } as UTSJSONObject;
    const res = await apiAgentConversationList(params);
    if (res == null) {
      return;
    }
    const code = res.code;
    if (code == SUCCESS_CODE) {
      const d = res.data;
      const list: ConversationInfo[] = d != null
        ? (d as ConversationInfo[])
        : ([] as ConversationInfo[]);
      chatList.value = list;
    }
  };

  onMounted(() => {
    fetchUserConversationList();
  });
</script>

<style lang="scss" scoped>
  .related-conversation {
    padding: 0rpx;
    background-color: #fff;
    border-radius: 16rpx;
    margin-bottom: 24rpx;
    .header {
      margin-top: 20rpx;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 20rpx 10rpx;
      .title {
        font-size: 28rpx;
        font-weight: 600;
        color: rgba(21, 23, 31, 1);
        line-height: 44rpx;
      }
      .view-all {
        display: flex;
        flex-direction: row;
        align-items: center;
        .view-all-text {
          font-size: 24rpx;
          color: rgba(130, 136, 148, 1);
          margin-right: 5rpx;
          line-height: 38rpx;
        }
        .iconfont {
          font-size: 26rpx;
          color: #898a8e;
        }
      }
    }
  }
</style>

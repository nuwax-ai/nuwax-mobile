<template>
  <view class="container flex flex-col h-full">
    <custom-nav-bar :title="categoryName">
      <template v-slot:left>
        <text
          class="iconfont icon-a-Chevronleft"
          @tap="jumpNavigateBack"
        ></text>
      </template>
    </custom-nav-bar>
    <scroll-view class="flex-1" direction="vertical" :show-scrollbar="false">
      <template v-if="loading">
        <view class="loading-state">
          <text class="loading-text">{{
            t("Mobile.Page.loadingMore")
          }}</text>
        </view>
      </template>
      <template v-else>
        <view
          v-for="item in categoryItems"
          :key="item.targetId"
          class="flex flex-row items-center item-card"
          hover-class="item-card-active"
          @click="handleAgentClick(item)"
        >
          <image
            class="item-card__icon"
            :src="getImageSrc(item.targetId, item.icon)"
            mode="aspectFill"
            :alt="item.name.length > 0 ? item.name : t('Mobile.Common.agentIconAlt')"
            @error="handleImageError(item.targetId)"
          />
          <view class="item-card__content">
            <text class="item-card__name text-ellipsis">{{ item.name }}</text>
            <text class="item-card__desc text-ellipsis">{{
              item.description
            }}</text>
          </view>
        </view>
      </template>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
  import agentImage from "@/static/assets/agent_image.png";
  import { jumpToAgentDetailPage } from "@/utils/commonBusiness";
  import {
    SUCCESS_CODE,
    USER_NO_LOGIN,
    REDIRECT_LOGIN,
  } from "@/constants/codes.constants";
  import { apiHomeCategoryList } from "@/servers/agentDev";
  import {
    CategoryInfo,
    CategoryItemInfo,
  } from "@/types/interfaces/agentConfig";
  import { ref, computed } from 'vue';
  import { onLoad, onShow } from "@dcloudio/uni-app";
  // #ifndef APP-ANDROID
  import { onAddToFavorites } from "@dcloudio/uni-app";
  // #endif
  import { setCurrentPageNavigationBarTitle } from "@/utils/system";
  import { useI18n } from "@/utils/i18n";

  const { t: tRaw } = useI18n();
  const t = (key: string): string => tRaw(key, new Map<string, any>(), "");

  const loading = ref<boolean>(false);
  const categoryKey = ref<string>(""); // 分类key
  // 分类信息
  const category = ref<CategoryInfo | null>(null);
  // 分类下的智能体列表
  const categoryItems = ref<CategoryItemInfo[]>([]);

  // 记录加载失败的图片ID（UTS 下用数组替代 Set）
  const failedImageIds = ref<number[]>([]);

  // 新增标志变量，用于区分首次加载
  const isFirstLoad = ref<boolean>(true);

  const categoryName = computed((): string => {
    const c = category.value;
    return c != null ? c.name : "";
  });

  const hasFailed = (id: number): boolean => {
    const arr = failedImageIds.value;
    for (let i = 0; i < arr.length; i++) {
      if (arr[i] == id) return true;
    }
    return false;
  };

  const addFailed = (id: number) => {
    if (!hasFailed(id)) {
      failedImageIds.value.push(id);
    }
  };

  const jumpNavigateBack = () => {
    uni.switchTab({ url: "/pages/agent-union-record/agent-union-record" });
  };

  /**
   * 获取图片源地址
   * @param id 智能体ID
   * @param originalIcon 原始图片地址
   * @returns 图片地址（加载失败则返回默认图片）
   */
  const getImageSrc = (id: number, originalIcon: string): string => {
    return hasFailed(id) ? agentImage : originalIcon;
  };

  /**
   * 图片加载错误时触发，切换为默认图片
   * @param id 智能体ID
   */
  const handleImageError = (id: number) => {
    addFailed(id);
  };

  // 主页智能体列表接口
  const fetchHomeCategoryList = async () => {
    const response = await apiHomeCategoryList();
    loading.value = false;
    if (response == null) return;
    const code = response.code;
    const data = response.data;
    const message = response.message;
    if (code == SUCCESS_CODE) {
      if (data != null) {
        // 按分类 key 查找分类信息
        const cats = data.categories;
        let matched: CategoryInfo | null = null;
        for (let i = 0; i < cats.length; i++) {
          if (cats[i].type == categoryKey.value) {
            matched = cats[i];
            break;
          }
        }
        category.value = matched;

        // 取分类下的智能体列表
        const itemsObj = data.categoryItems as UTSJSONObject;
        const itemsRaw = itemsObj[categoryKey.value];
        if (itemsRaw != null) {
          categoryItems.value = itemsRaw as CategoryItemInfo[];
        } else {
          categoryItems.value = [] as CategoryItemInfo[];
        }
      }
    } else if (code != USER_NO_LOGIN && code != REDIRECT_LOGIN) {
      const toastTitle = message != null && message.length > 0
        ? message
        : t("Mobile.AgentUnion.fetchHomeAgentListFailed");
      uni.showToast({
        title: toastTitle,
        icon: "none",
      });
    }
  };

  onShow((options: any) => {
    if (isFirstLoad.value) {
      isFirstLoad.value = false;
      return;
    }
    fetchHomeCategoryList();
  });

  onLoad((options: any) => {
    // 设置当前页面导航栏标题
    setCurrentPageNavigationBarTitle();
    const optObj = options as UTSJSONObject;
    const ck = optObj["categoryKey"];
    if (ck != null) {
      categoryKey.value = ck as string;
    }
    isFirstLoad.value = true;
    loading.value = true;
    fetchHomeCategoryList();
  });

  // 点击智能体
  const handleAgentClick = (info: CategoryItemInfo) => {
    jumpToAgentDetailPage(info.targetId, null, "ChatBot", info.name);
  };

  // #ifndef APP-ANDROID
  // 收藏（仅小程序/H5 支持，Android 端整段剥离）
  onAddToFavorites(() => {
    const c = category.value;
    const name = c != null && c.name.length > 0
      ? c.name
      : t("Mobile.Common.appName");
    return {
      title: name,
    };
  });
  // #endif
</script>

<style lang="scss" scoped>
  .container {
    overflow: hidden;
    background-color: #fff;
    /* #ifdef MP-WEIXIN */
    // padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
    /* #endif */

    /* 加载状态 */
    .loading-state {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;

      .loading-text {
        font-size: 28rpx;
        color: #666;
        display: flex;
        align-items: center;
        flex-direction: row;

        /* #ifdef H5 */
        @keyframes spin {
          0% {
            transform: rotate(0deg);
          }
          100% {
            transform: rotate(360deg);
          }
        }
        /* #endif */

        /* #ifdef H5 */
        &::before {
          content: "";
          width: 32rpx;
          height: 32rpx;
          border: 4rpx solid #e8e8e8;
          border-top: 4rpx solid #8b5cf6;
          border-radius: 50%;
          animation: spin 1s linear infinite;
          margin-right: 16rpx;
        }
        /* #endif */
      }
    }

    .item-card {
      display: flex;
      align-items: center;
      padding: 24rpx 32rpx;
      border-bottom: 1px solid rgba(12, 20, 102, 0.04);

      &-active {
        background-color: rgba(12, 20, 102, 0.04);
      }

      &__icon {
        width: 80rpx;
        height: 80rpx;
        border-radius: 50%;
        margin-right: 24rpx;
      }

      &__content {
        flex: 1;
      }

      &__name {
        font-size: 32rpx;
        color: #333;
      }

      &__desc {
        font-size: 24rpx;
        color: #999;
        margin-top: 8rpx;
      }

      &__count {
        font-size: 28rpx;
        color: #666;
      }
    }
  }
</style>

<template>
  <view ref="msgListContentRef" class="agent-detail-container page-container">
    <!-- 导航栏 -->
    <!-- 临时会话不显示Logo, 显示标题`和xxx开始会话` -->
    <custom-nav-bar
      :title="headerTitle"
      :show-back="!isAppDetails"
      :icon="isTempChat ? '' : agentInfo?.icon"
    >
      <template v-slot:left>
        <!-- #ifdef MP-WEIXIN -->
        <menu-dropdown
          v-if="!isAppDetails"
          :list="customMenuList"
          :onClick="handleMenuDropdownClick"
        />
        <!-- #endif -->

        <!-- 应用详情页显示菜单按钮 -->
        <!-- #ifdef MP-WEIXIN || H5 || WEB -->
        <text
          v-if="isAppDetails"
          class="iconfont icon-Menu"
          @tap="onMenuClick"
        ></text>
        <!-- #endif -->

        <!-- #ifdef H5 || WEB -->
        <text
          v-if="isShowWebView"
          class="iconfont icon-Home"
          @tap="handleBackHome"
        ></text>
        <!-- #endif -->
      </template>

      <template v-slot:right>
        <!-- #ifdef H5 || WEB -->
        <view class="right-buttons">
          <view
            class="icon-box"
            hover-class="icon-box-hover"
            @tap="handleMorePopup"
            v-if="!isTempChat && !isAppDetails"
          >
            <text class="iconfont icon-More"></text>
          </view>
          <template v-if="showNavCreateConversation">
            <!-- 创建新会话 -->
            <view
              class="icon-box"
              hover-class="icon-box-hover"
              @tap="handleCreateNewConversation"
            >
              <text class="iconfont icon-message-add"></text>
            </view>
          </template>
        </view>
        <!-- #endif -->
      </template>
    </custom-nav-bar>

    <!-- 默认展开扩展页面区域，且隐藏聊天区域 -->
    <template v-if="isShowWebView">
      <web-view
        class="w-full"
        v-if="pageHomeUrl?.length"
        :src="pageHomeUrl + (ticket.length > 0 ? '?_ticket=' + ticket : '')"
        id="webview"
      ></web-view>
    </template>
    <template v-else>
      <view class="chat-container">
        <!-- 聊天内容 -->
        <view class="scroll-view-box">
          <scroll-view
            direction="vertical"
            class="msg-list"
            :scroll-into-view="scrollIntoView"
            id="msg-list"
            :scroll-with-animation="scrollWithAnimation"
            :upper-threshold="50"
            @scrolltoupper="handleScrollToUpper"
            @scroll="onScroll"
            @touchstart="handleTouchStart"
            @touchend="handleTouchEnd"
            @touchcancel="handleTouchEnd"
          >
            <!-- 加载更多历史消息提示 -->
            <view class="loading-more-tip" v-if="isLoadingMoreMessages">
              <uni-load-more
                status="loading"
                :content-text="historyLoadMoreContentText"
              />
            </view>
            <new-conversation-set
              ref="newConversationSetRef"
              :variables="variables"
              :user-fill-variables="userFillVariables"
              :disabled="isSendMessageRef"
              @toggleWholeDisabled="handleToggleWholeDisabled"
            />
            <view class="msg-list-content" v-if="messageList?.length">
              <template
                v-for="(item, listIndex) in messageList"
                :key="`${item.id}_${item.index}`"
              >
                <view :id="`msg-wrapper-${item.id}_${item.index}`">
                  <!-- 智能体会话消息 -->
                  <uni-ai-x-msg
                    v-if="isAssistantMessage(item.messageType)"
                    :msg="handleMessageContent(item)"
                    :is-last-msg="isLastMessage(listIndex)"
                    :is-conversation-active="isConversationActive"
                    :task-status="conversationInfo?.taskStatus"
                    @longpress="onlongTapMsg(convertMessageInfoToMsgItem(item))"
                    @changeThinkContent="changeThinkContent"
                    :id="`msg-item-${item.id}_${item.index}`"
                    :ref="(el: any) => setMessageRef(el, `${item.id}_${item.index}`)"
                  ></uni-ai-x-msg>
                  <!-- 用户消息 -->
                  <template v-else>
                    <!-- 图片以及文件 -->
                    <scroll-view
                      class="files-container"
                      v-if="hasMessageAttachments(item.attachments)"
                      direction="horizontal"
                      :scroll-with-animation="true"
                      :show-scrollbar="false"
                    >
                      <view class="files-list">
                        <view
                          class="files-box"
                          :class="getFileBoxClassName(file.mimeType)"
                          v-for="file in item.attachments"
                          :key="file.fileKey"
                          @click="onPreview(file, safeAttachments(item))"
                        >
                          <image
                            class="image"
                            v-if="isImageMimeType(file.mimeType)"
                            :src="file?.fileUrl"
                            mode="aspectFill"
                            :alt="getUploadImageAlt(file.fileName)"
                          />
                          <!-- 文件 -->
                          <template v-else>
                            <image
                              class="doc-image"
                              :src="docImage"
                              mode="aspectFill"
                              :alt="tt('Mobile.Chat.uploadFileAlt')"
                            />
                            <view class="doc-info-container">
                              <view class="doc-name text-ellipsis">{{
                                file?.fileName
                              }}</view>
                              <text class="doc-size text-ellipsis">{{
                                formatFileSize(file)
                              }}</text>
                            </view>
                          </template>
                        </view>
                      </view>
                    </scroll-view>
                    <rich-text
                      class="user-msg"
                      v-if="item?.text"
                      :user-select="true"
                      :id="`msg-item-${item.id}_${item.index}`"
                      :nodes="item.text"
                    ></rich-text>
                  </template>
                </view>
              </template>
              <view class="content" v-if="chatSuggestList?.length">
                <button-wrapper
                  :chat-suggest-list="chatSuggestList"
                  @button-click="handleButtonClick"
                />
              </view>

              <!-- 智能体任务执行中，显示加载中图标 -->
              <image
                v-if="isTaskExecuting"
                class="icon-loading-image"
                src="@/static/assets/icon_loading.svg"
                alt=""
                :show-menu-by-longpress="false"
                @longtap.stop.prevent
                @contextmenu.stop.prevent="true"
                mode="widthFix"
              />
            </view>

            <!-- 空状态内容 -->
            <view class="content" v-else>
              <view class="title-section">
                <sub-markdown-msg :text="agentInfo?.openingChatMsg" />
              </view>
              <button-wrapper
                v-if="chatSuggestList?.length"
                :chat-suggest-list="chatSuggestList"
                @button-click="handleButtonClick"
              />
            </view>

            <!-- 滚动到底部的锚点 -->
            <view style="height: 35px" id="last-msg"></view>
          </scroll-view>

          <!-- 滚动到底部按钮 -->
          <view
            :style="{ visibility: scrollInBottom ? 'hidden' : 'visible' }"
            class="scroll-to-bottom"
            @click="scrollToLastMsg(false)"
          >
            <text class="iconfont icon-a-Chevrondown"></text>
          </view>
        </view>
        <!-- 输入框 -->
        <chat-input-phone
          v-if="isRenderInputPhone"
          key="agent-details-chat-input"
          ref="agentDetailInputPhoneRef"
          :page-home-index="inputPageHomeIndex"
          :expand-page-area="inputExpandPageArea"
          :whole-disabled="wholeDisabled"
          :manual-components="inputManualComponents"
          :default-selected-components="selectedComponents"
          :is-conversation-active="isConversationActive"
          :is-stopping-conversation="isStoppingConversation"
          @onSendMessage="handleSendMessage"
          @onStopConversation="handleStopConversation"
          @onOpenPagePreview="(uri:string)=>openPagePreviewByUri(uri)"
          :is-task-agent="isTaskAgentType"
          @onOpenFileTree="handleOpenFileTree"
          :sandbox-list="sandboxList"
          :current-sandbox-id="currentSandboxId"
          :is-sandbox-switch-disabled="isSandboxLocked"
          :is-sandbox-unavailable="isSandboxUnavailable"
          :sandbox-disabled-text="sandboxDisabledText"
          :readonly="inputReadonlySandbox"
          :enable-skill-at="inputEnableSkillAt"
          :is-temp-chat="isTempChat"
          @onSandboxChange="(id: string) => handleSelectSandbox(id)"
          :has-permission="inputHasPermission"
          :allow-other-model="inputAllowOtherModel"
          :current-model-id="data.currentModelId.value"
          :current-model-name="data.currentModelName.value"
          :agent-id="agentId"
          :agent-type="agentInfo?.type"
          :subscription-required="subscriptionRequired"
          @onModelChange="(id: number, name: string) => handleSelectModel(id, name)"
          @onOpenSubscription="handleOpenSubscription"
        />
      </view>
    </template>

    <more-popup
      v-if="!isTempChat"
      ref="refMorePopup"
      :agent-info="agentInfo"
      :is-task-agent="isTaskAgentType"
      :has-history="messageList.length > 0"
      :current-sandbox-id="currentSandboxId"
      @collect="handleCollect"
      @restartAgent="handleRestartAgent"
      @restartSandbox="handleRestartSandbox"
      @mySubscription="handleOpenSubscription"
    />
    <template v-else>
      <!-- #ifdef H5 || WEB-->
      <view>
        <button :id="buttonId" type="button" class="captcha-button" />
        <aliyun-captcha-h5
          :config="tenantConfigInfo"
          :element-id="buttonId"
          @doAction="handleCaptchaDoAction"
          @onReady="handleCaptchaReady"
        />
      </view>
      <!-- #endif -->
      <!-- #ifndef H5 || WEB-->
      <view />
      <!-- #endif -->
    </template>

    <!-- 页面预览 -->
    <page-preview-iframe
      ref="pagePreviewIframeRef"
      @update-visible="updateVisible"
    />
    <!-- 文件树 -->
    <file-tree
      ref="fileTreeRef"
      v-if="isTaskAgentType"
      :cId="conversationId"
      :files="fileList"
      :is-loading="isLoadingFiles"
      @update-visible="updatePopupFileTreeVisible"
    />
    <!-- 工具详情弹窗 -->
    <tool-details-modal
      ref="toolDetailsModalRef"
      :title="toolDetailTitle"
      :detail-data="toolDetailData"
    />

    <!-- 订阅套餐弹窗 -->
    <agent-subscription-modal
      ref="refSubscriptionModal"
      v-if="agentInfo"
      :agent-id="agentId"
      :current-plan-id="agentInfoField('planId')"
      :current-plan-price="agentInfoField('price')"
      :called-trial-count="localCalledTrialCount"
      :trial-count="agentInfoField('trialCount')"
      :is-need-subscription="subscriptionRequired"
      @purchase-success="handlePurchaseSuccess"
      @update-visible="handleUpdateModalVisible"
    />
  </view>
</template>

<script setup lang="uts">
  // ==================== 导入模块 ====================
  // 分层架构
  import { onLoad } from "@dcloudio/uni-app";
  import AgentDetailData from "./layers/AgentDetailData.uts";
  import AgentDetailService, {
    HandleSendMessageData,
  } from "./layers/AgentDetailService.uts";
  import ComponentManager from "./layers/ComponentManager.uts";
  import ScrollManager from "./layers/ScrollManager.uts";

  // 类型定义
  import {
    MessageTypeEnum,
    HideChatAreaEnum,
    ExpandPageAreaEnum,
    AgentTypeEnum,
  } from "@/types/enums/agent";
  import type { ChatInputPhoneRef } from "@/types/interfaces/chat.uts";
  import type { MessageInfo } from "@/types/interfaces/conversationInfo.uts";
  import type { UploadFileStatus } from "@/types/enums/common.uts";
  import type { TenantConfigInfo } from "@/types/interfaces/login";
  import {
    AttachmentFile,
    OpenAppParams,
    ConversationChatResponse,
    ConversationInfo,
  } from "@/types/interfaces/conversationInfo.uts";
  import { RequestResponse } from "@/types/interfaces/request.uts";
  import {
    EventBindConfig,
    AgentManualComponentInfo,
    AgentSelectedComponentInfo,
  } from "@/types/interfaces/agent";
  import type { ShowPagePreviewOptions } from "@/types/interfaces/agent";
  import { ProcessingEnum } from "@/types/enums/common.uts";
  import { TaskStatus } from "@/types/enums/agent";
  import { DefaultSelectedEnum } from "@/types/enums/agent.uts";
  import { UploadFileInfo } from "@/types/interfaces/common";
  import type { MenuListItem } from "@/types/interfaces/common";

  // 组件
  import MorePopup from "./components/more-popup/more-popup.uvue";
  import AgentSubscriptionModal from "./components/agent-subscription-modal/agent-subscription-modal.uvue";
  import SubMarkdownMsg from "@/subpackages/components/markdown-msg/markdown-msg.uvue";
  import ChatInputPhone from "@/subpackages/components/chat-input-phone/chat-input-phone.uvue";
  import NewConversationSet from "./components/new-conversation-set/new-conversation-set.uvue";
  import FileTree from "./components/file-tree/file-tree.uvue";
  import ToolDetailsModal from "./components/tool-details-modal/tool-details-modal.uvue";

  // 常量
  import { SUCCESS_CODE } from "@/constants/codes.constants";
  import {
    TEMP_CONVERSATION_UID,
    TEMP_CHAT_KEY,
  } from "@/constants/common.constants";
  import docImage from "@/static/assets/doc_image.png";
  import { TENANT_CONFIG_INFO } from "@/constants/home.constants";
  import { API_BASE_URL } from "@/constants/config";
  import { EVENT_TYPE } from "@/subpackages/constants/event.constants";

  // ==================== API ====================
  import { apiAgentConversation } from "@/servers/conversation";
  import { apiTenantConfig } from "@/servers/account";
  import { apiUserTicketCreate } from "@/servers/agentDev";
  import {
    useMessageEventDelegate,
    handleMessageEventClick,
    EventDedupManager,
  } from "@/subpackages/hooks/useMessageEventDelegate.uts";
  import { usePageResume } from "@/subpackages/hooks/usePageResume.uts";

  // ==================== 工具方法 ====================
  import { formatBytes } from "@/utils/byteConverter.uts";
  import { objectToQueryString } from "@/utils/common";
  import { chatService } from "@/utils/chatService";
  import { handleExternalLink } from "@/utils/system.uts";
  import { setCurrentPageNavigationBarTitle } from "@/utils/system.uts";
  import eventBus from "@/utils/eventBus";
  import { throttle } from "@/subpackages/utils/functionUtils";
  import { useI18n } from "@/utils/i18n";
  import { getUniLoadMoreContentText } from "@/utils/i18n-third-party";
  import { hasUploadErrorInFiles } from "@/subpackages/components/chat-input-phone/chatInputActions.uts";

  const { t } = useI18n();
  const historyLoadMoreContentText = computed(() =>
    getUniLoadMoreContentText(
      "",
      t("Mobile.Conversation.loadingHistory"),
      "",
    ),
  );

  /** 文件树弹窗组件引用 */
  interface FileTreePopupRef {
    open: any;
    close: any;
  }

  // 接收组件属性，设置默认值
  const props = withDefaults(
    defineProps<{
      isTempChat?: boolean;
      isAppDetails?: boolean; // 是否是应用智能体页面
    }>(),
    {
      isTempChat: false,
      isAppDetails: false,
    },
  );


  // 定义 emits
  const emit = defineEmits<{
    // 菜单按钮点击事件
    (e: "menu-click"): void;
  }>();

  // 菜单按钮点击事件
  const onMenuClick = () => {
    emit("menu-click");
  };

  // 创建防重复触发管理器（可选）
  const dedupManager = new EventDedupManager(1000);

  // 定义 chat-input-phone 组件的引用
  const agentDetailInputPhoneRef = ref<ChatInputPhoneRef | null>(null);
  const newConversationSetRef = ref<any | null>(null);
  // 聊天内容区域引用用于绑定自定义事件代理
  const msgListContentRef = ref<any | null>(null);
  // 事件绑定配置
  const eventBindConfig = ref<EventBindConfig | null>(null);
  // 阿里云验证码按钮id
  const buttonId = ref<string>("aliyun-captcha-id");
  // 租户配置信息
  const tenantConfigInfo = ref<TenantConfigInfo | null>(null);
  // 页面预览iframe引用
  const pagePreviewIframeRef = ref<any | null>(null);
  // 页面预览是否可见
  const pagePreviewVisible = ref(false);
  const msgListRef = ref<any | null>(null);
  // 用户临时票据
  const ticket = ref<string>("");
  /**
   * 是否渲染输入框组件， 进入页面后渲染，离开页面后卸载组件
   * 出现一个bug，当从智能体详情页面返回首页时，录音后发送消息事件触发的是智能体详情页绑定的消息事件，而不是首页绑定的消息事件
   * 所以需要卸载输入框组件，重新渲染输入框组件
   */
  const isRenderInputPhone = ref<boolean>(false);

  // 文件树弹窗是否可见
  const popupFileTreeVisible = ref<boolean>(false);

  // 文件树引用
  const fileTreeRef = ref<FileTreePopupRef | null>(null);

  // 工具详情弹窗引用
  const toolDetailsModalRef = ref<any | null>(null);
  const toolDetailData = ref<any | null>(null);
  const toolDetailTitle = ref<string>("");

  // 处理返回首页
  const handleBackHome = () => {
    uni.switchTab({
      url: "/pages/index/index",
    });
  };

  const updateVisible = (value: boolean) => {
    pagePreviewVisible.value = value;
  };

  // 处理文件树弹窗可见性变化
  const updatePopupFileTreeVisible = (value: boolean) => {
    popupFileTreeVisible.value = value;
  };
  // ==================== 初始化分层架构 ====================
  // 创建各层实例
  const data = new AgentDetailData();
  data.isTempChat.value = props.isTempChat;
  const service = new AgentDetailService(data);
  const componentManager = new ComponentManager(data);
  const scrollManager = new ScrollManager(data);

  /** 非空字符串兜底 */
  const coalesceNonEmptyString = (
    value: string | null | undefined,
    fallback: string,
  ): string => {
    if (value != null) {
      const text = value as string;
      if (text.length > 0) {
        return text;
      }
    }
    return fallback;
  };

  /** 是否应自动滚动到底部 */
  const shouldAutoScrollToLast = (): boolean => {
    if (data.scrollTouch.value == true) {
      return false;
    }
    return data.autoToLastMsg.value == true;
  };

  // ==================== 暴露方法给模板 ====================

  // 数据层
  const {
    agentId,
    agentName,
    agentInfo,
    pageHomeUrl,
    conversationId,
    messageList,
    chatSuggestList,
    requestId,
    isTempChat,
    messageIdRef,
    captchaVerifyParam,
    chatKey,
    conversationUid,
    conversationInfo,
    needUpdateTopicRef,
    manualComponents,
    selectedComponents,
    variables,
    userFillVariables,
    processingList,
    scrollIntoView,
    scrollInBottom,
    scrollWithAnimation,
    scrollTouch,
    scrolling,
    keyboardHeight,
    refMorePopup,
    refSubscriptionModal,
    isStoppingConversation,
    isConversationActive,
    isSendMessageRef,
    wholeDisabled,
    fileList,
    isLoadingFiles,
    sandboxList,
    currentSandboxId,
    isSandboxSwitchDisabled,
    isSandboxUnavailable,
    sandboxDisabledText,
    isLoadingMoreMessages,
    hasMoreMessages,
    currentModelId,
    currentModelName,
    modelSelectVisible,
    subscriptionRequired,
    subscriptionModalVisible,
    localCalledTrialCount,
  } = data;

  // 是否显示webview（须位于 data 解构之后，showNavCreateConversation 之前）
  const isShowWebView = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return false;
    }
    const expandYes = info.expandPageArea == ExpandPageAreaEnum.Yes;
    const hideChat = info.hideChatArea == HideChatAreaEnum.Yes;
    if (expandYes == true) {
      if (hideChat == true) {
        return true;
      }
    }
    return false;
  });

  /** 消息是否含附件 */
  const hasMessageAttachments = (
    attachments: AttachmentFile[] | null | undefined,
  ): boolean => {
    if (attachments == null) {
      return false;
    }
    return (attachments as AttachmentFile[]).length > 0;
  };

  /** 是否助手消息（模板辅助，避免模板中直接引用枚举类） */
  const isAssistantMessage = (messageType: any): boolean => {
    return messageType == MessageTypeEnum.ASSISTANT;
  };

  /** 是否消息列表最后一条（模板辅助，避免模板中做 nullable 算术） */
  const isLastMessage = (listIndex: number): boolean => {
    const list = messageList.value;
    return list.length - 1 == listIndex;
  };

  /** 会话任务是否执行中（模板辅助，避免模板中引用枚举类与 ===） */
  const isTaskExecuting = computed((): boolean => {
    const info = conversationInfo.value;
    if (info == null) {
      return false;
    }
    return info.taskStatus == TaskStatus.EXECUTING;
  });

  /** 是否图片 MIME */
  const isImageMimeType = (mimeType: string | null | undefined): boolean => {
    if (mimeType == null) {
      return false;
    }
    return (mimeType as string).indexOf("image/") >= 0;
  };

  /** 附件卡片样式类名 */
  const getFileBoxClassName = (mimeType: string | null | undefined): string => {
    if (isImageMimeType(mimeType) == true) {
      return "files-box-image";
    }
    return "files-box-file";
  };

  /** 上传图片 alt 文案 */
  const getUploadImageAlt = (fileName: string | null | undefined): string => {
    return coalesceNonEmptyString(fileName, t("Mobile.Chat.uploadImageAlt"));
  };

  /** 模板中调用 t 的便捷包装（UTS 不允许模板里调用带默认参数的方法） */
  const tt = (key: string): string => {
    const params = new Map<string, string | number>();
    return t(key, params, "");
  };

  /** 模板中安全读取文件大小（UTS 不允许模板里把 nullable 传给非空参数） */
  const safeFileSize = (file: any): number => {
    const obj = file as UTSJSONObject;
    const sizeVal = obj["fileSize"];
    if (sizeVal != null) {
      return sizeVal as number;
    }
    return 0;
  };

  /** 模板中安全格式化文件大小（合并读取与格式化，避免模板里嵌套调用） */
  const formatFileSize = (file: any): string => {
    return formatBytes(safeFileSize(file));
  };

  /** 模板中安全获取附件数组（保证非空，避免 nullable 传给非空参数） */
  const safeAttachments = (item: any): AttachmentFile[] => {
    const obj = item as UTSJSONObject;
    const attVal = obj["attachments"];
    if (attVal != null) {
      return attVal as AttachmentFile[];
    }
    return [] as AttachmentFile[];
  };

  /** 模板中读取 agentInfo 的继承字段（UTS 不解析 interface 继承字段） */
  const agentInfoField = (key: string): any | null => {
    const info = agentInfo.value;
    if (info == null) {
      return null;
    }
    return (info as UTSJSONObject)[key];
  };

  /** 导航栏是否显示「新建会话」 */
  const showNavCreateConversation = computed((): boolean => {
    return isShowWebView.value == false;
  });

  /** 输入框 pageHomeIndex */
  const inputPageHomeIndex = computed((): string => {
    const info = agentInfo.value;
    if (info == null) {
      return "";
    }
    if (info.pageHomeIndex != null) {
      return info.pageHomeIndex as string;
    }
    return "";
  });

  /** 输入框 expandPageArea */
  const inputExpandPageArea = computed((): number => {
    const info = agentInfo.value;
    if (info == null) {
      return ExpandPageAreaEnum.No as number;
    }
    if (info.expandPageArea != null) {
      return info.expandPageArea as number;
    }
    return ExpandPageAreaEnum.No as number;
  });

  /** 输入框 manualComponents */
  const inputManualComponents = computed((): AgentManualComponentInfo[] => {
    const info = agentInfo.value;
    if (info == null) {
      return [];
    }
    if (info.manualComponents != null) {
      return info.manualComponents;
    }
    return [];
  });

  /** 输入框 hasPermission */
  const inputHasPermission = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return true;
    }
    if (info.hasPermission == true) {
      return true;
    }
    return false;
  });

  /** 是否任务型智能体 */
  const isTaskAgentType = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return false;
    }
    return info.type == AgentTypeEnum.TaskAgent;
  });

  /** 是否允许 @ 技能 */
  const inputEnableSkillAt = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return false;
    }
    return info.allowAtSkill == DefaultSelectedEnum.Yes;
  });

  /** 是否允许切换模型 */
  const inputAllowOtherModel = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return false;
    }
    return info.allowOtherModel == DefaultSelectedEnum.Yes;
  });

  /** 沙盒只读 */
  const inputReadonlySandbox = computed((): boolean => {
    const info = agentInfo.value;
    if (info == null) {
      return false;
    }
    return info.allowPrivateSandbox == DefaultSelectedEnum.No;
  });

  // 处理禁用发送按钮
  const handleToggleWholeDisabled = (disabled: boolean) => {
    data.wholeDisabled.value = disabled;
  };

  // 服务层 - 使用箭头函数保持this上下文
  const handleQueryConversation = (result: RequestResponse<ConversationInfo>) =>
    service.handleQueryConversation(result);
  const handleChangeMessageList = (
    res: ConversationChatResponse,
    currentMessageId: string,
  ) => service.handleChangeMessageList(res, currentMessageId);

  // 停止会话
  const handleStopConversation = () =>
    service.handleStopConversation(props.isTempChat);
  const createNewConversation = (isAppDetails: boolean) =>
    service.createNewConversation(isAppDetails);
  function getPublishedAgentInfo(appParams: OpenAppParams | null) {
    // 服务层 getPublishedAgentInfo 的可选参数在 UTS 中无法零参调用，
    // 这里在调用方做 null 判断；通过 any 中转避免 null/空字面量到接口的转换报错，
    // 服务层内部会做 appParams != null 且 keys.length>0 检查后才使用
    if (appParams == null) {
      service.getPublishedAgentInfo(null as any as OpenAppParams);
    } else {
      service.getPublishedAgentInfo(appParams);
    }
  }
  const handleCollect = () => service.handleCollect();

  // 重启智能体
  const handleRestartAgent = () => service.handleRestartAgent();

  // 重启沙箱
  const handleRestartSandbox = () =>
    service.handleRestartSandbox(data.currentSandboxId.value == "-1");
  // 清空会话数据
  const clearConversationData = (isTempChat: boolean) =>
    service.clearConversationData(isTempChat);

  // 触发打开订阅/升级计划模态框
  const handleOpenSubscription = () => {
    subscriptionModalVisible.value = true;
    nextTick(() => {
      const subRef = refSubscriptionModal.value as any | null;
      if (subRef != null) {
        const openFn = (subRef as UTSJSONObject)["open"] as (() => void) | null;
        if (openFn != null) {
          openFn();
        }
      } else {
        setTimeout(() => {
          const subRefLater = refSubscriptionModal.value as any | null;
          if (subRefLater != null) {
            const openFnLater = (subRefLater as UTSJSONObject)["open"] as (() => void) | null;
            if (openFnLater != null) {
              openFnLater();
            }
          }
        }, 50);
      }
    });
  };

  // 订阅/购买套餐成功回调
  const handlePurchaseSuccess = (plan: any) => {
    service.handleCheckSubscriptionLimit();
  };

  // 弹窗可见性回调
  const handleUpdateModalVisible = (visible: boolean) => {
    subscriptionModalVisible.value = visible;
  };

  // 监听订阅弹窗的显示状态，唤起或关闭组件
  watch(subscriptionModalVisible, (visible: boolean) => {
    if (visible) {
      nextTick(() => {
        const subRef = refSubscriptionModal.value as any | null;
        if (subRef != null) {
          const openFn = (subRef as UTSJSONObject)["open"] as (() => void) | null;
          if (openFn != null) {
            openFn();
          }
        } else {
          // 如果首次 nextTick 还没挂载完（常见于小程序首屏自动弹窗），则在小延时后重试
          setTimeout(() => {
            const subRefLater = refSubscriptionModal.value as any | null;
            if (subRefLater != null) {
              const openFnLater = (subRefLater as UTSJSONObject)["open"] as (() => void) | null;
              if (openFnLater != null) {
                openFnLater();
              }
            }
          }, 100);
        }
      });
    } else {
      const subRef = refSubscriptionModal.value as any | null;
      if (subRef != null) {
        const closeFn = (subRef as UTSJSONObject)["close"] as (() => void) | null;
        if (closeFn != null) {
          closeFn();
        }
      }
    }
  });

  // 临时会话
  const queryTempConversation = (conversationUid: string) =>
    service.queryTempConversation(conversationUid);
  const createTempChatConversation = (captchaVerifyParam: string) =>
    service.createTempChatConversation(captchaVerifyParam);

  // 获取文件树列表
  const fetchFileList = (cId: number) => service.fetchFileList(cId);

  const handleSelectSandbox = (sandboxId: string) =>
    service.handleSelectSandbox(sandboxId);

  // 模型相关
  const handleSelectModel = (modelId: number, modelName: string) =>
    service.handleSelectModel(modelId, modelName);

  // 组件管理层 - 使用箭头函数保持this上下文
  const setMessageRef = (el: any, messageId: string) =>
    componentManager.setMessageRef(el, messageId);
  const removeMessageRef = (messageId: string) =>
    componentManager.removeMessageRef(messageId);
  const updateMessageComponent = (messageId: string, newData: any) =>
    componentManager.updateMessageComponent(messageId, newData);
  const convertMessageInfoToMsgItem = (messageInfo: MessageInfo) =>
    componentManager.convertMessageInfoToMsgItem(messageInfo);
  // 处理消息内容
  const handleMessageContent = (item: any) => {
    // 处理消息内容中的data属性
    const itemObj = item as UTSJSONObject;
    const rawText = itemObj["text"] as string;
    itemObj["text"] = rawText.replace(/data="(\{.*?\})"/g, (match: string, p1: number, p2: string): string => {
      // UTS replace 回调签名固定为 (match, offset, fullString)；用 p2 作为完整字符串重新匹配
      // 这里 p1 是偏移量，无法直接拿到捕获组，改用对 match 的简单替换
      const dataMatch = /data="(\{.*?\})"/.exec(match);
      if (dataMatch != null && dataMatch.length > 1) {
        const groupVal = dataMatch[1];
        if (groupVal != null) {
          return `data='${groupVal}'`;
        }
      }
      return match;
    });
    return convertMessageInfoToMsgItem(item as MessageInfo);
  };

  // 滚动管理层 - 使用箭头函数保持this上下文
  const scrollToLastMsg = (userClick: boolean) =>
    scrollManager.scrollToLastMsg(userClick);
  const setIsInScrollBottom = (e: UniScrollEvent) =>
    scrollManager.setIsInScrollBottom(e);
  const lockAutoToLastMsg = () => scrollManager.lockAutoToLastMsg();
  const onScroll = (e: UniScrollEvent) => {
    // #ifdef MP-WEIXIN
    // 微信小程序中，由于使用 scrollIntoView 等机制，可能导致系统内部 scrolltoupper 的触发状态机未复位
    // 表现为“必须先下滑一点，再上滑才能触发”。我们在此加入滚动高度探测做双重保障。
    if (e != null) {
      const detail = e.detail;
      if (detail != null) {
        if (detail.scrollTop <= 100) {
          const notLoading = data.isLoadingMoreMessages.value == false;
          const hasMore = data.hasMoreMessages.value == true;
          if (notLoading == true) {
            if (hasMore == true) {
              handleScrollToUpper();
            }
          }
        }
      }
    }
    // #endif
    scrollManager.onScroll(e);
  };
  const scrollToMessage = (messageId: string | number) =>
    scrollManager.scrollToMessage(messageId);

  // 加载更多历史消息
  const handleLoadMoreMessages = () => service.handleLoadMoreMessages();

  /**
   * 处理上滑到顶部事件，加载更多历史消息
   */
  const handleScrollToUpper = async () => {
    const canLoadMore = hasMoreMessages.value == true;
    const isLoading = isLoadingMoreMessages.value == true;
    const listEmpty = messageList.value.length == 0;
    if (canLoadMore == false) {
      return;
    }
    if (isLoading == true) {
      return;
    }
    if (listEmpty == true) {
      return;
    }

    // 记录当前第一条可见消息的 ID 和 游标，用于加载完成后保持滚动位置
    const firstMessage = messageList.value[0];
    let firstVisibleMessageId = "";
    if (firstMessage != null) {
      firstVisibleMessageId = `${firstMessage.id}_${firstMessage.index}`;
    }

    // 临时禁用自动滚动，避免加载更多时触发自动滚动到底部
    const previousAutoToLastMsg = data.autoToLastMsg.value;
    data.autoToLastMsg.value = false;

    await handleLoadMoreMessages();

    // 加载完成后，滚动到之前的第一条消息位置，保持用户视角不变
    if (firstVisibleMessageId.length > 0) {
      await nextTick();
      scrollToMessage(firstVisibleMessageId);
    }

    // 恢复自动滚动状态
    data.autoToLastMsg.value = previousAutoToLastMsg;
  };

  // ==================== 视图层方法 (原ViewManager逻辑) ====================

  const handleCaptchaReady = () => {
    const el = document.getElementById(buttonId.value);
    if (el != null) {
      el.click();
    }
  };

  // ChatFinished 事件处理函数（带节流）
  // 注意：须位于 handleSendMessage 等引用之前（UTS 无提升）
  const handleChatFinishedInternal = (event: any) => {
    const eventConvIdStr = `${(event as UTSJSONObject)["conversationId"]}`;
    if (conversationId.value == parseInt(eventConvIdStr, 10)) {
      throttle(() => {
        if (data.isConversationActive.value == true) {
          data.isConversationActive.value = false;
        }

        const convId = conversationId.value;
        const isNotTemp = props.isTempChat == false;
        if (convId != null) {
          if (convId != 0) {
            if (isNotTemp == true) {
              apiAgentConversation(convId as number).then((res) => {
                if (res.code == SUCCESS_CODE) {
                  handleQueryConversation(res);
                }
              });
            }
          }
        }
      }, 500)();
    }
  };

  // 发送消息
  const handleSendMessage = (_data: any) => {
    // 取消订阅 ChatFinished 事件（发送新消息时，旧会话已结束）
    eventBus.off(`${EVENT_TYPE.ChatFinished}`, handleChatFinishedInternal);

    data.autoToLastMsg.value = true;
    data.needSetLockAutoToLastMsg.value = true;
    // 发送过消息,则禁用变量参数
    data.isSendMessageRef.value = true;

    scrollToLastMsg(false);

    let params: UTSJSONObject = {} as UTSJSONObject;

    const urlOtherParams = data.urlOtherParams.value as any | null;
    if (urlOtherParams != null) {
      const urlObj = urlOtherParams as UTSJSONObject;
      let otherAttachments: AttachmentFile[] = [];
      const otherAttVal = urlObj["attachments"];
      if (otherAttVal != null) {
        otherAttachments = otherAttVal as AttachmentFile[];
      }

      const otherAttachmentsFiles: UTSJSONObject[] = [];
      const attachLen = otherAttachments.length;
      for (let i = 0; i < attachLen; i++) {
        const item = otherAttachments[i];
        let fileName = "";
        let fileKey = "";
        if (item.fileName != null) {
          fileName = item.fileName as string;
        }
        if (item.fileKey != null) {
          fileKey = item.fileKey as string;
        }
        const fileObj: UTSJSONObject = {
          url: item.fileUrl,
          type: item.mimeType,
          name: fileName,
          key: fileKey,
        };
        otherAttachmentsFiles.push(fileObj);
      }

      let otherFiles: UploadFileInfo[] = [];
      const otherFilesVal = urlObj["files"];
      if (otherFilesVal != null) {
        otherFiles = otherFilesVal as UploadFileInfo[];
      }
      let _selectedComponents: AgentSelectedComponentInfo[] = [];
      const otherSelVal = urlObj["selectedComponents"];
      if (otherSelVal != null) {
        _selectedComponents = otherSelVal as AgentSelectedComponentInfo[];
      }
      let otherSkillIds: number[] = [];
      const otherSkillVal = urlObj["skillIds"];
      if (otherSkillVal != null) {
        otherSkillIds = otherSkillVal as number[];
      }
      const otherModelId = urlObj["modelId"];
      const otherSandboxId = urlObj["sandboxId"];

      const dataObj = _data as UTSJSONObject;
      let dataFiles: UploadFileInfo[] = [];
      const dataFilesVal = dataObj["files"];
      if (dataFilesVal != null) {
        dataFiles = dataFilesVal as UploadFileInfo[];
      }
      let dataSelected: AgentSelectedComponentInfo[] = [];
      const dataSelectedVal = dataObj["selectedComponents"];
      if (dataSelectedVal != null) {
        dataSelected = dataSelectedVal as AgentSelectedComponentInfo[];
      }
      let dataSkillIds: number[] = [];
      const dataSkillIdsVal = dataObj["skillIds"];
      if (dataSkillIdsVal != null) {
        dataSkillIds = dataSkillIdsVal as number[];
      }
      let variableParams: any | null = null;
      const convSet = newConversationSetRef.value as any | null;
      if (convSet != null) {
        const convSetObj = convSet as UTSJSONObject;
        const vpVal = convSetObj["variableParams"];
        if (vpVal != null) {
          variableParams = vpVal;
        }
      }
      let modelId = dataObj["modelId"];
      if (modelId == null) {
        modelId = otherModelId;
      }
      let sandboxId = dataObj["sandboxId"];
      if (sandboxId == null) {
        sandboxId = otherSandboxId;
      }

      const mergedFiles: UTSJSONObject[] = [];
      for (let f = 0; f < otherFiles.length; f++) {
        mergedFiles.push(otherFiles[f] as UTSJSONObject);
      }
      for (let g = 0; g < otherAttachmentsFiles.length; g++) {
        mergedFiles.push(otherAttachmentsFiles[g]);
      }
      for (let h = 0; h < dataFiles.length; h++) {
        mergedFiles.push(dataFiles[h] as UTSJSONObject);
      }

      const mergedSelected: AgentSelectedComponentInfo[] = [];
      for (let sc = 0; sc < _selectedComponents.length; sc++) {
        mergedSelected.push(_selectedComponents[sc]);
      }
      for (let dc = 0; dc < dataSelected.length; dc++) {
        mergedSelected.push(dataSelected[dc]);
      }
      const mergedSkillIds: number[] = [];
      for (let sk = 0; sk < otherSkillIds.length; sk++) {
        mergedSkillIds.push(otherSkillIds[sk]);
      }
      for (let dk = 0; dk < dataSkillIds.length; dk++) {
        mergedSkillIds.push(dataSkillIds[dk]);
      }

      const paramsObj: UTSJSONObject = {};
      // 复制 _data 的原始字段
      const dataKeys = UTSJSONObject.keys(dataObj);
      const dataKeysLen = dataKeys.length;
      for (let dk2 = 0; dk2 < dataKeysLen; dk2++) {
        const k = dataKeys[dk2] as string;
        paramsObj[k] = dataObj[k];
      }
      paramsObj["variableParams"] = variableParams;
      paramsObj["files"] = mergedFiles;
      paramsObj["selectedComponents"] = mergedSelected;
      paramsObj["skillIds"] = mergedSkillIds;
      paramsObj["modelId"] = modelId;
      paramsObj["sandboxId"] = sandboxId;
      params = paramsObj;
    } else {
      let variableParamsElse: any | null = null;
      const convSetElse = newConversationSetRef.value as any | null;
      if (convSetElse != null) {
        const convSetElseObj = convSetElse as UTSJSONObject;
        const vpElseVal = convSetElseObj["variableParams"];
        if (vpElseVal != null) {
          variableParamsElse = vpElseVal;
        }
      }
      const paramsObjElse: UTSJSONObject = {};
      const dataObjElse = _data as UTSJSONObject;
      const dataKeysElse = UTSJSONObject.keys(dataObjElse);
      const dataKeysElseLen = dataKeysElse.length;
      for (let ek = 0; ek < dataKeysElseLen; ek++) {
        const k = dataKeysElse[ek] as string;
        paramsObjElse[k] = dataObjElse[k];
      }
      paramsObjElse["variableParams"] = variableParamsElse;
      params = paramsObjElse;
    }

    service.handleSendMessage(params as HandleSendMessageData, props.isTempChat, () => {
      // 将工具调用状态从 loading 修改为 error
      // service.updateProcessingListToFailed()
      // 中止当前 SSE 连接
      chatService.abort();
      // 注意：超时时不调用停止接口，只中止 SSE 连接
      // 停止接口只应该由用户手动点击停止按钮时调用

      // 重置按钮状态（按钮变为发送按钮）
      data.isConversationActive.value = false;
      data.isStoppingConversation.value = false;
    });
  };

  /**
   * 处理菜单下拉框点击，强同步拉取最新配置，以控制订阅选项的实时展示
   */
  const handleMenuDropdownClick = (): void => {
    initTenantConfig();
  };

  /**
   * 处理创建新会话
   */
  const handleCreateNewConversation = (): void => {
    // 中止当前 SSE 连接
    chatService.abort();
    // 注意：创建新会话时不调用停止接口，只中止 SSE 连接
    // 停止接口只应该由用户手动点击停止按钮时调用

    // 重置按钮状态（按钮变为发送按钮）
    data.isConversationActive.value = false;
    data.isStoppingConversation.value = false;

    // 取消订阅 ChatFinished 事件（防止旧会话的事件影响新会话）
    eventBus.off(`${EVENT_TYPE.ChatFinished}`, handleChatFinishedInternal);

    // 清空本地缓存中的临时会话uid
    uni.removeStorageSync(TEMP_CONVERSATION_UID);
    if (props.isTempChat) {
      // 清空会话数据
      clearConversationData(true);

      // 创建临时会话
      createTempChatConversation(data.captchaVerifyParam.value);
    } else {
      createNewConversation(props.isAppDetails);
    }
  };

  /**
   * 处理更多弹窗
   */
  const handleMorePopup = (): void => {
    const morePopup = data.refMorePopup.value as any | null;
    if (morePopup != null) {
      nextTick(() => {
        const openFn = (morePopup as UTSJSONObject)["open"] as (() => void) | null;
        if (openFn != null) {
          openFn();
        }
      });
    }
  };

  /**
   * 处理功能按钮点击
   */
  const handleButtonClick = (guideQuestion: string): void => {
    if (data.wholeDisabled.value == true) {
      uni.showToast({
        title: t("Mobile.Chat.fillRequiredParams"),
        icon: "none",
        duration: 2000,
      });
      return;
    }
    const inputPhoneRef = agentDetailInputPhoneRef.value;
    let existErrorFile = false;
    if (inputPhoneRef != null) {
      existErrorFile = hasUploadErrorInFiles(inputPhoneRef.files.value);
    }
    if (existErrorFile == true) {
      uni.showToast({
        title: t("Mobile.Chat.removeUploadFailed"),
        icon: "none",
        duration: 1500,
      });
      return;
    }
    let guideFiles: UploadFileInfo[] = [];
    let guideComponents: AgentSelectedComponentInfo[] = [];
    if (inputPhoneRef != null) {
      guideFiles = inputPhoneRef.files.value;
      guideComponents = inputPhoneRef.selectedComponents.value;
    }
    const params = {
      messageInfo: guideQuestion,
      files: guideFiles,
      selectedComponents: guideComponents,
    };

    handleSendMessage(params);
  };

  // 预览图片
  const onPreview = (file: AttachmentFile, attachments: AttachmentFile[]) => {
    const isImage = file.mimeType.indexOf("image/") >= 0;
    if (isImage == false) {
      uni.showToast({
        title: t("Mobile.Chat.previewTypeUnsupported"),
        icon: "none",
        duration: 1500,
      });
      return;
    }
    const urls: string[] = [];
    const attachLen = attachments.length;
    for (let i = 0; i < attachLen; i++) {
      const item = attachments[i];
      if (item.mimeType.indexOf("image/") >= 0) {
        urls.push(item.fileUrl);
      }
    }
    const currentUrl = file.fileUrl;
    if (urls.length > 0) {
      if (currentUrl.length > 0) {
        uni.previewImage({
          urls,
          current: currentUrl,
        });
      }
    }
  };

  /**
   * 长按消息处理
   */
  const onlongTapMsg = (item: any): void => {
    // 显示操作菜单
  };

  /**
   * 思考内容变化处理
   */
  const changeThinkContent = (hideThinkContent: boolean): void => {
    // 注意：不要在这里调用 setIsInScrollBottom()，因为没有事件参数会导致状态错误
    if (shouldAutoScrollToLast() == true) {
      nextTick(() => {
        if (shouldAutoScrollToLast() == true) {
          scrollToLastMsg(false);
        }
      });
    }
  };

  /**
   * 键盘高度变化处理
   */
  const onKeyboardheightchange = (
    res: UniInputKeyboardHeightChangeEvent,
  ): void => {
    data.keyboardHeight.value = res.detail.height;
  };

  // ==================== 计算属性 ====================
  const lastMessage = computed((): MessageInfo | null => {
    const list = data.messageList.value;
    const listLen = list.length;
    if (listLen == 0) {
      return null;
    }
    return list[listLen - 1];
  });
  // 标题
  const headerTitle = computed((): string => {
    const info = agentInfo.value;
    let agentName = "";
    if (info != null) {
      if (info.name != null) {
        agentName = info.name as string;
      }
    }
    if (props.isTempChat == true) {
      if (agentName.length > 0) {
        const nameMap = new Map<string, string | number>();
        nameMap.set("name", agentName);
        return t("Mobile.Conversation.startWithAgent", nameMap as Record<string, string | number>);
      }
    }
    return agentName;
  });

  // 沙盒是否锁定 (综合判断: 服务层限制 || 已发送消息 || 存在历史消息)
  const isSandboxLocked = computed((): boolean => {
    if (data.isSandboxSwitchDisabled.value == true) {
      return true;
    }
    if (data.isSendMessageRef.value == true) {
      return true;
    }
    if (data.messageList.value.length > 0) {
      return true;
    }
    return false;
  });

  // ==================== 页面加载处理 ====================
  const handleScrollToLastMsg = async () => {
    // 注意：不要在这里调用 setIsInScrollBottom()，因为没有事件参数会导致状态错误
    lockAutoToLastMsg();
    if (shouldAutoScrollToLast() == true) {
      await nextTick();
      setTimeout(() => {
        if (shouldAutoScrollToLast() == true) {
          scrollToLastMsg(false);
        }
      }, 100);
    }
  };
  watch(lastMessage, handleScrollToLastMsg, { deep: true });

  // 消息列表变化处理
  watch(data.messageList, handleScrollToLastMsg, { deep: true });

  // 问题建议列表变化处理
  watch(
    chatSuggestList,
    (newVal: any[]) => {
      if (newVal != null) {
        if ((newVal as any[]).length > 0) {
          handleScrollToLastMsg();
        }
      }
    },
    { deep: true },
  );

  watch(
    conversationId,
    async (newVal: number | null) => {
      const hasConfig = eventBindConfig.value != null;
      const hasConvId = newVal != null;
      const isNotTempChat = props.isTempChat == false;
      if (hasConfig == false) {
        if (hasConvId == true) {
          if (isNotTempChat == true) {
            const res = await apiAgentConversation(newVal as number);
            if (res.code == SUCCESS_CODE) {
              const resData = res.data;
              if (resData != null) {
                const agent = resData.agent;
                if (agent != null) {
                  eventBindConfig.value = (agent as UTSJSONObject)["eventBindConfig"] as EventBindConfig;
                }
              }
            }
          }
        }
      }
    },
    { deep: true },
  );

  // 监听键盘高度变化
  watch(data.keyboardHeight, (newVal: number) => {
    if (newVal > 0) {
      handleScrollToLastMsg();
    }
  });

  // 记录上一次成功获取租户配置的时间戳，避免首屏加载与 onShow 唤醒时并发重复请求
  let lastTenantConfigFetchTime: number = 0;

  /**
   * 初始化并更新租户配置，同步 enableSubscription 状态
   */
  const initTenantConfig = async (): Promise<void> => {
    const now = Date.now();
    // 2秒防抖时间窗口：如果距离上次成功获取配置的时间不足2秒，则直接跳过，防止并发快速重复拉取
    const withinDebounce = now - lastTenantConfigFetchTime < 2000;
    const hasSubscription = data.enableSubscription.value != null;
    if (withinDebounce == true) {
      if (hasSubscription == true) {
        return;
      }
    }

    try {
      const res = await apiTenantConfig();
      const codeOk = res.code == SUCCESS_CODE;
      const hasData = res.data != null;
      if (codeOk == true) {
        if (hasData == true) {
          const resData = res.data as TenantConfigInfo;
          let enableSub = 0;
          if (resData.enableSubscription != null) {
            enableSub = resData.enableSubscription as number;
          }
          data.enableSubscription.value = enableSub;
          tenantConfigInfo.value = resData;
          uni.setStorageSync(TENANT_CONFIG_INFO, JSON.stringify(res.data));
          lastTenantConfigFetchTime = Date.now();
        }
      } else {
        const info = uni.getStorageSync(TENANT_CONFIG_INFO);
        if (info != null) {
          const cachedConfig = JSON.parse(info as string) as TenantConfigInfo;
          let enableSub = 0;
          if (cachedConfig.enableSubscription != null) {
            enableSub = cachedConfig.enableSubscription as number;
          }
          data.enableSubscription.value = enableSub;
          tenantConfigInfo.value = cachedConfig;
        }
      }
    } catch (e) {
      console.error("初始化租户配置失败:", e);
      const info = uni.getStorageSync(TENANT_CONFIG_INFO);
      if (info != null) {
        const cachedConfig = JSON.parse(info as string) as TenantConfigInfo;
        let enableSub = 0;
        if (cachedConfig.enableSubscription != null) {
          enableSub = cachedConfig.enableSubscription as number;
        }
        data.enableSubscription.value = enableSub;
        tenantConfigInfo.value = cachedConfig;
      }
    }
  };

  // ==================== 页面唤醒恢复逻辑 ====================
  /**
   * 处理会话恢复
   * 当页面从后台恢复时，检测并恢复会话状态
   */
  const handleSessionResume = async (): Promise<void> => {
    // 页面切回前台时，同步并更新最新的租户配置
    await initTenantConfig();

    // 检查会话ID是否存在
    const convId = conversationId.value;
    if (convId == null) {
      return;
    }
    if (convId == 0) {
      return;
    }

    // 重新获取会话订阅与限制状态，确保在支付返回后能够实时同步状态与解锁输入框
    await service.handleCheckSubscriptionLimit();

    // 调用服务层的恢复方法
    const needResume = await service.resumeConversationState();

    if (needResume == true) {
      console.log("[PageResume] 会话状态已恢复");
    }
  };

  // 使用页面唤醒检测 Hook
  // 注意：H5 环境会自动监听 visibilitychange
  // 小程序环境需要配合 App.uvue 的 onShow 使用
  // 使用页面唤醒检测 Hook
  // 注意：H5 环境会自动监听 visibilitychange
  // 小程序环境需要配合 App.uvue 的 onShow 使用
  const {
    isHidden: isPageHidden,
    triggerResume,
    triggerHide,
  } = usePageResume({
    onResume: (): void => {
      // 异步恢复逻辑包装为同步回调，避免 Promise 类型不匹配
      handleSessionResume();
    },
    onHide: (): void => {
      // console.log("[PageResume] 页面进入后台");
    },
    // 最小隐藏时间 5 秒，避免短暂切换触发恢复
    minHiddenDuration: 5000,
  });

  /**
   * 处理页面加载
   */
  const handlePageLoad = async (options: any): Promise<void> => {
    // 智能体id
    const idVal = (options as UTSJSONObject)["id"];
    if (idVal != null) {
      data.agentId.value = parseInt(idVal as string, 10);
    } else {
      data.agentId.value = null;
    }

    // 如果存在会话id，则初始化ParseMarkdown，查询历史会话信息
    const convIdVal = (options as UTSJSONObject)["conversationId"];
    if (convIdVal != null) {
      const id = parseInt(convIdVal as string, 10);
      // 先设置一个临时值，防止 watch(conversationId) 触发时重复调用接口
      eventBindConfig.value = {} as UTSJSONObject as EventBindConfig;
      data.conversationId.value = id;

      if (props.isTempChat) return;

      // 查询历史会话信息(接口返回数据中包含智能体详情信息, 所以不在需要单独查询智能体详情信息了)
      const res = await apiAgentConversation(id);
      if (res.code == SUCCESS_CODE) {
        const resData = res.data;
        if (resData != null) {
          const agent = resData.agent;
          if (agent != null) {
            eventBindConfig.value = (agent as UTSJSONObject)["eventBindConfig"] as EventBindConfig;
          }
        }
        handleQueryConversation(res);

        if (resData != null) {
          if (resData.taskStatus == TaskStatus.EXECUTING) {
          // 设置会话为活跃状态（按钮显示为停止按钮）
          data.isConversationActive.value = true;
          // 订阅 ChatFinished 事件
          eventBus.on(`${EVENT_TYPE.ChatFinished}`, handleChatFinishedInternal);
          }
        }
      }
    } else {
      let paramsData: OpenAppParams | null = null;
      const paramsFromUrl = (options as UTSJSONObject)["params"];
      if (paramsFromUrl != null) {
        paramsData = JSON.parse(paramsFromUrl as string) as OpenAppParams;
      }

      // 查询智能体详情信息，并初始化会话id
      getPublishedAgentInfo(paramsData);
    }
  };

  /**
   * 使用chatKey、captchaVerifyParam创建临时会话
   * chatKey: 链接key
   * captchaVerifyParam: 验证码参数 (可选)
   */
  const handleCreateTempChat = async (captchaVerifyParam: any) => {
    // 验证码参数
    const verifyParam = captchaVerifyParam != null ? `${captchaVerifyParam}` : "";
    data.captchaVerifyParam.value = verifyParam;
    data.isLoadingConversation.value = true;
    const uid = uni.getStorageSync(TEMP_CONVERSATION_UID);
    if (uid != null) {
      const uidStr = uid as string;
      if (uidStr.length > 0) {
        data.conversationUid.value = uidStr;
        queryTempConversation(uidStr);
      } else {
        createTempChatConversation(verifyParam);
      }
    } else {
      createTempChatConversation(verifyParam);
    }
  };

  /**
   * 处理临时会话页面加载
   */
  const handleTempChatPageLoad = async (options: any) => {
    // 临时会话key
    const chatKeyVal = (options as UTSJSONObject)["chatKey"] as string;
    data.chatKey.value = chatKeyVal;
    // 是否存在缓存的chatKey值
    const _cacheChatKey = uni.getStorageSync(TEMP_CHAT_KEY);

    /**
     * 如果缓存的chatKey值存在且与当前的chatKey值不一致，则清空缓存的临时会话uid
     * (防止用户手动修改url地址中的chatKey值后刷新页面，因为缓存TEMP_CONVERSATION_UID的值与chatKey值不匹配，导致后面查询会话详情时提示会话ID不存在的bug)
     */
    if (_cacheChatKey != null) {
      const cacheKey = _cacheChatKey as string;
      if (cacheKey.length > 0) {
        if (chatKeyVal != cacheKey) {
          uni.removeStorageSync(TEMP_CONVERSATION_UID);
        }
      }
    }
    // 缓存chatKey
    uni.setStorageSync(TEMP_CHAT_KEY, chatKeyVal);

    const _tenantConfigInfo = tenantConfigInfo.value;
    if (_tenantConfigInfo != null) {
      const captchaSceneId = _tenantConfigInfo.captchaSceneId;
      const captchaPrefix = _tenantConfigInfo.captchaPrefix;
      const openCaptcha = _tenantConfigInfo.openCaptcha;
      let isNeedCaptcha = false;
      if (captchaSceneId != null) {
        if (captchaPrefix != null) {
          if ((openCaptcha as number) != 0) {
            isNeedCaptcha = true;
          }
        }
      }
      if (isNeedCaptcha == false) {
        handleCreateTempChat("");
      }
    }
  };

  // 验证码 doAction 回调包装（避免模板内联箭头触发 UTS 泛型 E 推断失败）
  const handleCaptchaDoAction = (captchaVerifyParam: string) => {
    handleCreateTempChat(captchaVerifyParam);
  };

  const handlePagePreviewDetail = (toolCall: any, detailData: any) => {
    toolDetailData.value = detailData;
    const toolName = (toolCall as UTSJSONObject)["name"] as string | null;
    const rawTitle = coalesceNonEmptyString(
      toolName,
      t("Mobile.ThirdParty.MpHtml.executionPlan"),
    );
    toolDetailTitle.value = rawTitle.replace(/&quot;/g, '"');
    const modalRef = toolDetailsModalRef.value as any | null;
    if (modalRef != null) {
      const openFn = (modalRef as UTSJSONObject)["open"] as (() => void) | null;
      if (openFn != null) {
        openFn();
      }
    }
  };

  /**
   * 打开页面预览
   * @param uri 页面URI
   * @param method 请求方法 (默认: browser_open_page)
   * @param data_type 数据类型 (默认: html)
   * @param request_id 请求ID (默认: '')
   */
  // 注意：须位于 handlePagePreviewExecuting 等调用方之前（UTS 无提升）
  const handleOpenPagePreview = async (opts: UTSJSONObject) => {
    // 由于 UTS 解构默认值受限，这里在函数体内手动兜底
    let uri = opts.uri;
    const uriVal = (opts as UTSJSONObject)["uri"];
    if (uriVal != null) {
      uri = uriVal as string;
    }
    let method = "browser_open_page";
    const methodVal = (opts as UTSJSONObject)["method"];
    if (methodVal != null) {
      method = methodVal as string;
    }
    let data_type = "html";
    const dataTypeVal = (opts as UTSJSONObject)["data_type"];
    if (dataTypeVal != null) {
      data_type = dataTypeVal as string;
    }
    let request_id = "";
    const reqIdVal = (opts as UTSJSONObject)["request_id"];
    if (reqIdVal != null) {
      request_id = reqIdVal as string;
    }
    // 打开页面首页
    // #ifdef H5 || WEB
    const iframeRef = pagePreviewIframeRef.value as any | null;
    if (iframeRef != null) {
      const handlePageOpenFn = (iframeRef as UTSJSONObject)["handlePageOpen"] as ((opts: UTSJSONObject) => void) | null;
      if (handlePageOpenFn != null) {
        const optsObj: UTSJSONObject = {
          uri: `${API_BASE_URL}${uri}`,
          method: method,
          data_type: data_type,
          request_id: request_id,
        };
        handlePageOpenFn(optsObj);
      }
    }
    // #endif

    // #ifdef MP-WEIXIN
    const { code, data } = await apiUserTicketCreate();
    const ticketOk = code == SUCCESS_CODE;
    const hasTicket = data != null;
    if (ticketOk == true) {
      if (hasTicket == true) {
        const ticketData = data as string;
        if (uri.indexOf("?") >= 0) {
          uri = uri + "&_ticket=" + ticketData;
        } else {
          uri = uri + "?_ticket=" + ticketData;
        }
      }
    }
    const pageHomeTitle = encodeURIComponent(t("Mobile.Common.pageHome"));
    handleExternalLink(
      `${API_BASE_URL}${uri}&jump_type=inner&title=${pageHomeTitle}&method=${method}&data_type=${data_type}&request_id=${request_id}`,
    );
    // #endif
  };

  /** 模板中触发打开页面预览（避免在模板里构造接口对象字面量） */
  const openPagePreviewByUri = (uri: string): void => {
    const opts: UTSJSONObject = {
      uri: uri,
      method: "browser_open_page",
      data_type: "html",
      request_id: "",
    };
    handleOpenPagePreview(opts);
  };

  const handlePagePreviewExecuting = (execData: any) => {
    const execObj = execData as UTSJSONObject;
    let input: any | null = null;
    const result = execObj["result"] as any | null;
    if (result != null) {
      input = (result as UTSJSONObject)["input"] as any | null;
    }
    if (input == null) {
      return;
    }
    const inputObj = input as UTSJSONObject;
    if (inputObj["uri_type"] == null) {
      inputObj["uri_type"] = "Page";
    }
    const argumentsString = objectToQueryString(inputObj["arguments"]);
    let queryString = "";
    if (argumentsString.length > 0) {
      queryString = "?" + argumentsString;
    }

    if (inputObj["uri_type"] == "Link") {
      // #ifdef H5 || WEB
      if (execObj["status"] == ProcessingEnum.FINISHED) {
        const pageUrl = `${inputObj["uri"]}${queryString}`;
        window.open(pageUrl, "_blank");
      }
      // #endif
      return;
    }

    if (inputObj["uri_type"] == "Page") {
      const fullUri = `${inputObj["uri"]}${queryString}`;

      if (execObj["status"] == ProcessingEnum.FINISHED) {
        const previewOpts: UTSJSONObject = {
          uri: fullUri,
          method: "browser_open_page",
          data_type: "html",
          request_id: "",
        };
        handleOpenPagePreview(previewOpts);
        return;
      }

      if (execObj["status"] == ProcessingEnum.EXECUTING) {
        const previewOpts2: UTSJSONObject = {
          uri: fullUri,
          method: inputObj["method"] as string,
          data_type: inputObj["data_type"] as string,
          request_id: inputObj["request_id"] as string,
        };
        handleOpenPagePreview(previewOpts2);
        return;
      }
    }
  };

  // 处理更多信息
  const handleOpenInfo = () => {
    nextTick(() => {
      const morePopup = refMorePopup.value as any | null;
      if (morePopup != null) {
        const popupMore = (morePopup as UTSJSONObject)["popupMore"] as any | null;
        if (popupMore != null) {
          const openFn = (popupMore as UTSJSONObject)["open"] as (() => void) | null;
          if (openFn != null) {
            openFn();
          }
        }
      }
    });
  };

  // 自定义菜单列表（须位于各 handler 与 data 解构之后）
  const customMenuList = computed<MenuListItem[]>(() => {
    let collectIcon = "icon-Star";
    const info = agentInfo.value;
    if (info != null) {
      if (info.collect == true) {
        collectIcon = "icon-Star-fill";
      }
    }

    const list: MenuListItem[] = [
      {
        label: "Mobile.Conversation.newConversation",
        value: "add",
        icon: "icon-message-add",
        onClick: handleCreateNewConversation,
      }
    ];

    const agentInfoVal = agentInfo.value;
    if (
      agentInfoVal != null &&
      (agentInfoVal as UTSJSONObject)["paymentRequired"] == true &&
      data.enableSubscription.value == 1
    ) {
      list.push({
        label: "Mobile.Conversation.mySubscription",
        value: "mySubscription",
        icon: "icon-member",
        onClick: handleOpenSubscription,
      });
    }

    list.push(
      {
        label: "Mobile.Conversation.moreInfo",
        value: "info",
        icon: "icon-Info",
        onClick: handleOpenInfo,
      },
      {
        label: "Mobile.Conversation.favorite",
        value: "collect",
        icon: collectIcon,
        onClick: handleCollect,
      }
    );

    const agentInfoVal2 = agentInfo.value;
    if (
      agentInfoVal2 != null &&
      (agentInfoVal2 as UTSJSONObject)["type"] == AgentTypeEnum.TaskAgent &&
      messageList.value.length > 0
    ) {
      list.push({
        label: "Mobile.Sandbox.restartAgent",
        value: "restartAgent",
        icon: "icon-restart",
        onClick: handleRestartAgent,
      });
      list.push({
        label:
          currentSandboxId.value == "-1"
            ? "Mobile.Sandbox.restartCloudComp"
            : "Mobile.Sandbox.restartClient",
        value: "restartSandbox",
        icon: "icon-restart_agent",
        onClick: handleRestartSandbox,
      });
    }

    return list;
  });

  // 事件代理
  useMessageEventDelegate(
    msgListContentRef,
    eventBindConfig,
    (data: ShowPagePreviewOptions) => {
      // 打开引导问题页面弹窗
      const previewOpts: UTSJSONObject = {
        uri: data.uri,
        method: "browser_open_page",
        data_type: "html",
        request_id: "",
      };
      handleOpenPagePreview(previewOpts);
    },
  );

  // ==================== 生命周期 ====================
  // 内部异步逻辑包装为同步回调，避免 Promise 类型不匹配
  const runOnLoadAsync = async (options: any): Promise<void> => {
    // 获取并更新租户配置，初始化 enableSubscription
    await initTenantConfig();

    // 设置当前页面导航栏标题
    setCurrentPageNavigationBarTitle();
    const ticketVal = (options as UTSJSONObject)["_ticket"];
    if (ticketVal != null) {
      ticket.value = ticketVal as string;
    } else {
      ticket.value = "";
    }
    // 进入页面后渲染输入框组件
    isRenderInputPhone.value = true;

    // 微信小程序事件绑定
    // #ifdef MP-WEIXIN
    uni.$on("message-event-delegate", (data: any) => {
      const dataObj = data as UTSJSONObject;
      const attrsObj = dataObj["attrs"] as UTSJSONObject;
      const eventType = attrsObj["event-type"];
      const dataStr = attrsObj["data"];
      if (eventType != null) {
        if (dataStr != null) {
          handleMessageEventClick(
            eventType,
            dataStr,
            eventBindConfig.value,
            handleOpenPagePreview,
            dedupManager,
          );
        } else {
          const warnObj: UTSJSONObject = {
            eventType: eventType,
            dataStr: dataStr,
          };
          console.warn("[Event Delegate] 缺少必要属性", warnObj);
        }
      }
    });
    // #endif

    // 判断是否是临时会话
    if (props.isTempChat) {
      await handleTempChatPageLoad(options);
    } else {
      await handlePageLoad(options);
    }
  };
  onLoad((options: any) => {
    runOnLoadAsync(options);
  });

  // 刷新文件列表
  const onRefreshFileList = () => {
    // 如果智能体类型为任务型智能体，并且会话id存在,并且文件树弹窗可见，则获取文件树列表
    const info = agentInfo.value;
    let isTaskAgent = false;
    if (info != null) {
      if (info.type == AgentTypeEnum.TaskAgent) {
        isTaskAgent = true;
      }
    }
    const convId = conversationId.value;
    let hasConvId = false;
    if (convId != null) {
      if (convId != 0) {
        hasConvId = true;
      }
    }
    const treeVisible = popupFileTreeVisible.value == true;
    if (isTaskAgent == true) {
      if (hasConvId == true) {
        if (treeVisible == true) {
          fetchFileList(convId as number);
        }
      }
    }
  };

  // 处理消息组件更新事件
  const handleUpdateMessageComponent = (eventData: any) => {
    const edObj = eventData as UTSJSONObject;
    const dataVal = edObj["data"] as any;
    updateMessageComponent(edObj["messageId"] as string, dataVal);
  };

  // 流式消息滚动定时器
  let streamScrollTimer: number = 0;
  // 触摸结束延迟计时器
  let touchEndTimer: number = 0;

  // 触摸开始处理
  const handleTouchStart = () => {
    // 清除触摸结束延迟计时器，确保触摸开始时立即生效
    if (touchEndTimer != 0) {
      clearTimeout(touchEndTimer);
      touchEndTimer = 0;
    }
    data.scrollTouch.value = true;
  };

  // 触摸结束处理 - 延迟重置 scrollTouch
  const handleTouchEnd = () => {
    // 清除之前的计时器
    if (touchEndTimer != 0) {
      clearTimeout(touchEndTimer);
    }
    // 延迟 300ms 后才重置 scrollTouch
    // 这样在用户快速滑动时，自动滚动不会在手指抬起的瞬间抢占
    touchEndTimer = setTimeout(() => {
      data.scrollTouch.value = false;
      touchEndTimer = 0;
      // 触摸结束后，如果需要，自动滚动到底部
      handleScrollToLastMsg();
    }, 300);
  };

  const handleStreamMessageUpdate = () => {
    // 使用防抖处理，避免频繁滚动影响性能
    // 150ms 可以在保证流畅滚动的同时减少性能开销
    if (streamScrollTimer != 0) {
      clearTimeout(streamScrollTimer);
    }
    streamScrollTimer = setTimeout(() => {
      if (shouldAutoScrollToLast() == true) {
        scrollToLastMsg(false);
      }
    }, 150);
  };

  // 设置事件监听器
  // 内部异步逻辑包装为同步回调，避免 Promise 类型不匹配
  const runOnMountedAsync = async (): Promise<void> => {
    // 监听流式消息更新事件，触发自动滚动到底部
    // 兼容微信小程序和 H5
    uni.$on("streamMessageUpdate", handleStreamMessageUpdate);

    uni.$on("refreshFileList", onRefreshFileList);
    uni.$on("updateMessageComponent", handleUpdateMessageComponent);
    // #ifdef H5
    window.addEventListener("wheel", (e: WheelEvent) => {
      data.mouseScroll.value = true;
      let clear: number = 0;
      clear = setTimeout(() => {
        data.mouseScroll.value = false;
        clearTimeout(clear);
      }, 1000);
    });
    // #endif

    uni.$on("page_preview_executing", handlePagePreviewExecuting);
    uni.$on("page_preview_detail", handlePagePreviewDetail);
  };
  onMounted(() => {
    runOnMountedAsync();
  });

  // 清理事件监听器
  onUnmounted(() => {
    // 页面卸载时立即中断 SSE 连接并清除超时定时器
    // 注意：只中断连接，不调用停止接口
    console.log("[页面卸载] 准备中断 SSE 连接");
    chatService.abort();
    console.log("[页面卸载] SSE 连接已中断");

    uni.$off("streamMessageUpdate", handleStreamMessageUpdate);
    uni.$off("refreshFileList", onRefreshFileList);
    uni.$off("updateMessageComponent", handleUpdateMessageComponent);
    // 页面卸载时取消监听，防止内存泄漏
    uni.$off("page_preview_executing", handlePagePreviewExecuting);
    // 清理微信小程序事件监听器，防止返回首页后仍然触发当前页面的事件
    // #ifdef MP-WEIXIN
    uni.$off("message-event-delegate");
    // #endif
    // 离开页面后卸载输入框组件
    isRenderInputPhone.value = false;
    // 取消订阅 ChatFinished 事件（必须传入回调函数）
    eventBus.off(`${EVENT_TYPE.ChatFinished}`, handleChatFinishedInternal);
  });

  // 打开工作台文件树弹窗
  const handleOpenFileTree = () => {
    popupFileTreeVisible.value = true;
    // 打开文件树弹窗
    const treeRef = fileTreeRef.value as any | null;
    if (treeRef != null) {
      const openFn = (treeRef as UTSJSONObject)["open"] as (() => void) | null;
      if (openFn != null) {
        openFn();
      }
    }
    // 查询文件列表
    onRefreshFileList();
  };
  defineExpose({
    triggerResume: triggerResume as any,
    triggerHide: triggerHide as any,
    getAgentInfo: ((): any => agentInfo.value as any) as any,
  });
</script>

<style lang="scss" scoped>
  @import "./styles/index.scss";

  .captcha-button {
    position: absolute;
    left: 10px;
    top: 10px;
    visibility: hidden;
    opacity: 0;
  }

  .icon-loading-image {
    width: 48rpx;
    height: 48rpx;
    margin-left: 32rpx;
    -webkit-touch-callout: none !important;
    -webkit-user-select: none !important;
    user-select: none !important;
  }

  .loading-more-tip {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 24rpx 0;
  }
</style>

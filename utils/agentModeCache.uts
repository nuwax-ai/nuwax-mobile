export type AgentMode = "ask" | "yolo";

export const AGENT_MODE_STORAGE_KEY = "nuwax_agent_mode_cache";

export type AgentModeCacheObject = {
  version?: number;
  defaultMode?: AgentMode;
  agents?: Record<string, AgentMode>;
};

const isAgentMode = (mode: unknown): boolean =>
  mode === "yolo" || mode === "ask";

const normalizeAgentModeCacheAgentId = (
  agentId?: number | string | null,
): string | null => {
  if (agentId === undefined || agentId === null) {
    return null;
  }
  const normalized = String(agentId).trim();
  return normalized ? normalized : null;
};

const parseAgentModeCache = (
  raw: string | null,
): any | null => {
  if (!raw) {
    return null;
  }
  if (isAgentMode(raw)) {
    return raw;
  }
  try {
    const parsed = JSON.parse(raw);
    if (parsed && typeof parsed === "object") {
      return parsed;
    }
  } catch (e) {
    // ignore invalid cache
  }
  return null;
};

export const readAgentModeCache = (
  agentId?: number | string | null,
): AgentMode | null => {
  const agentKey = normalizeAgentModeCacheAgentId(agentId);
  const raw = uni.getStorageSync(AGENT_MODE_STORAGE_KEY) as string;
  const parsed = parseAgentModeCache(raw);

  if (isAgentMode(parsed)) {
    return parsed as AgentMode;
  }

  if (!parsed) {
    return null;
  }

  const cacheObj = parsed as AgentModeCacheObject;
  const agentMode = agentKey && cacheObj.agents ? cacheObj.agents[agentKey] : undefined;
  if (isAgentMode(agentMode)) {
    return agentMode;
  }

  if (isAgentMode(cacheObj.defaultMode)) {
    return cacheObj.defaultMode;
  }

  return null;
};

export const writeAgentModeCache = (
  mode: AgentMode,
  agentId?: number | string | null,
) => {
  const agentKey = normalizeAgentModeCacheAgentId(agentId);
  const raw = uni.getStorageSync(AGENT_MODE_STORAGE_KEY) as string;
  const parsed = parseAgentModeCache(raw);
  
  const nextCache: AgentModeCacheObject =
    parsed && !isAgentMode(parsed)
      ? {
          version: (parsed as AgentModeCacheObject).version,
          defaultMode: (parsed as AgentModeCacheObject).defaultMode,
          agents: { ...((parsed as AgentModeCacheObject).agents || {}) },
        }
      : {
          version: 1,
          defaultMode: isAgentMode(parsed) ? (parsed as AgentMode) : undefined,
          agents: {},
        };

  if (agentKey) {
    if (!nextCache.agents) {
      nextCache.agents = {};
    }
    nextCache.agents[agentKey] = mode;
  } else {
    nextCache.defaultMode = mode;
  }

  uni.setStorageSync(AGENT_MODE_STORAGE_KEY, JSON.stringify(nextCache));
  
  // 发送事件以便其他标签页/会话可以同步更新
  uni.$emit('NuwaxAgentModeChanged', { agentId: agentKey, mode });
};

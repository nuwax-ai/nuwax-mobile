<template>
  <view class="acp-card">
    <view class="acp-header">
      <view class="acp-title-block">
        <text class="acp-eyebrow">{{ t("Mobile.AcpPermission.eyebrow") }}</text>
        <text class="acp-title">{{ toolTitle }}</text>
      </view>
      <text class="acp-kind" v-if="toolKind">{{ toolKind }}</text>
    </view>

    <view class="acp-meta">
      <text class="acp-meta-label">{{ t("Mobile.AcpPermission.toolCallId") }}</text>
      <text class="acp-meta-value">{{ toolCallId || "-" }}</text>
    </view>

    <view class="acp-raw-input">
      <text class="acp-section-title">{{ t("Mobile.AcpPermission.rawInput") }}</text>
      <text class="acp-raw-text">{{ rawInputText }}</text>
    </view>

    <view class="acp-save-rule" v-if="ruleDescription" @tap="toggleSaveRule">
      <view class="acp-checkbox" :class="{ 'acp-checkbox-checked': saveRule }">
        <view v-if="saveRule" class="acp-checkbox-mark"></view>
      </view>
      <view class="acp-save-rule-content">
        <text class="acp-save-rule-title">
          {{ t("Mobile.AcpPermission.saveRule") }}
        </text>
        <text class="acp-save-rule-description">{{ ruleDescription }}</text>
      </view>
    </view>

    <view class="acp-options">
      <button
        v-for="option in options"
        :key="option.option_id"
        class="acp-option-button"
        :class="{
          'acp-option-button-primary': isAllowOption(option),
          'acp-option-button-danger': isRejectOption(option),
        }"
        :disabled="disabled"
        :loading="isSubmitting && selectedOptionId === option.option_id"
        @tap="handleSelect(option.option_id)"
      >
        {{ option.name || option.option_id }}
      </button>

      <button
        class="acp-option-button acp-option-button-secondary"
        :disabled="disabled"
        :loading="isSubmitting && !selectedOptionId"
        @tap="handleCancel"
      >
        {{ t("Mobile.Common.cancel") }}
      </button>
    </view>

    <text class="acp-error" v-if="interaction.responseStatus === 'failed'">
      {{ interaction.errorMessage }}
    </text>
    <text class="acp-submitted" v-if="isSubmitted">
      {{ t("Mobile.AcpPermission.submitted") }}
    </text>
  </view>
</template>

<script setup lang="uts">
  import { computed, ref } from "vue";
  import { useI18n } from "@/utils/i18n";
  import type {
    RcoderAcpPermissionInteraction,
    RcoderPermissionOption,
    RcoderRequestPermissionResponse,
  } from "@/types/interfaces/acpPermission";

  defineOptions({
    name: "AcpPermissionCard",
  });

  const props = defineProps<{
    interaction: RcoderAcpPermissionInteraction;
  }>();

  const emit = defineEmits(["respond"]);
  const { t } = useI18n();
  const saveRule = ref<boolean>(false);

  const request = computed(() => {
    return props.interaction.permission.request_permission_request;
  });

  const toolCall = computed(() => {
    return request.value.tool_call;
  });

  const toolCallId = computed((): string => {
    return toolCall.value.tool_call_id || "";
  });

  const toolKind = computed((): string => {
    return toolCall.value.kind || "";
  });

  const toolTitle = computed((): string => {
    return (
      toolCall.value.title ||
      toolCall.value.kind ||
      t("Mobile.AcpPermission.defaultTitle")
    );
  });

  const options = computed((): RcoderPermissionOption[] => {
    return request.value.options || [];
  });

  const isSubmitting = computed((): boolean => {
    return props.interaction.responseStatus === "submitting";
  });

  const isSubmitted = computed((): boolean => {
    return props.interaction.responseStatus === "submitted";
  });

  const disabled = computed((): boolean => {
    return isSubmitting.value || isSubmitted.value;
  });

  const selectedOptionId = computed((): string => {
    return props.interaction.selectedOptionId || "";
  });

  const rawInputText = computed((): string => {
    const rawInput = toolCall.value.raw_input;
    if (rawInput == null) {
      return t("Mobile.Common.noData");
    }
    if (typeof rawInput === "string") {
      return rawInput;
    }
    try {
      return JSON.stringify(rawInput, null, 2);
    } catch (error) {
      return String(rawInput);
    }
  });

  const ruleDescription = computed((): string => {
    const rule = props.interaction.permission.save_rule;
    if (!rule) return "";
    return `${rule.tool_name}: ${rule.suggested_pattern}`;
  });

  const isAllowOption = (option: RcoderPermissionOption): boolean => {
    return String(option.kind || "").startsWith("allow");
  };

  const isRejectOption = (option: RcoderPermissionOption): boolean => {
    return String(option.kind || "").startsWith("reject");
  };

  const toggleSaveRule = () => {
    if (disabled.value) return;
    saveRule.value = !saveRule.value;
  };

  const handleSelect = (optionId: string) => {
    if (disabled.value) return;
    const response: RcoderRequestPermissionResponse = {
      outcome: {
        Selected: {
          option_id: optionId,
        },
      },
    };
    emit("respond", {
      interaction: props.interaction,
      response,
      saveRule: saveRule.value,
    });
  };

  const handleCancel = () => {
    if (disabled.value) return;
    const response: RcoderRequestPermissionResponse = {
      outcome: {
        Cancelled: {},
      },
    };
    emit("respond", {
      interaction: props.interaction,
      response,
      saveRule: false,
    });
  };
</script>

<style lang="scss" scoped>
  .acp-card {
    margin: 12rpx 24rpx 0 72rpx;
    padding: 24rpx;
    border: 1rpx solid #e6e8ef;
    border-radius: 12rpx;
    background: #ffffff;
  }

  .acp-header {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16rpx;
  }

  .acp-title-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }

  .acp-eyebrow {
    color: #6b7280;
    font-size: 22rpx;
    line-height: 32rpx;
  }

  .acp-title {
    color: #15171f;
    font-size: 30rpx;
    font-weight: 600;
    line-height: 40rpx;
  }

  .acp-kind {
    flex-shrink: 0;
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
    background: rgba(12, 20, 102, 0.06);
    color: #4b5563;
    font-size: 22rpx;
    line-height: 32rpx;
  }

  .acp-meta {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12rpx;
    margin-top: 20rpx;
  }

  .acp-meta-label {
    color: #6b7280;
    font-size: 22rpx;
  }

  .acp-meta-value {
    flex: 1;
    color: #374151;
    font-size: 22rpx;
    word-break: break-all;
  }

  .acp-raw-input {
    margin-top: 20rpx;
  }

  .acp-section-title {
    color: #6b7280;
    font-size: 22rpx;
    line-height: 32rpx;
  }

  .acp-raw-text {
    display: block;
    margin-top: 8rpx;
    padding: 16rpx;
    border-radius: 8rpx;
    background: #f7f8fb;
    color: #111827;
    font-size: 22rpx;
    line-height: 34rpx;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .acp-save-rule {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 12rpx;
    margin-top: 20rpx;
  }

  .acp-checkbox {
    width: 32rpx;
    height: 32rpx;
    border: 2rpx solid #c7cad1;
    border-radius: 6rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .acp-checkbox-checked {
    border-color: #1677ff;
    background: #1677ff;
  }

  .acp-checkbox-mark {
    width: 16rpx;
    height: 8rpx;
    border-left: 3rpx solid #ffffff;
    border-bottom: 3rpx solid #ffffff;
    transform: rotate(-45deg);
  }

  .acp-save-rule-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4rpx;
  }

  .acp-save-rule-title {
    color: #15171f;
    font-size: 24rpx;
    line-height: 34rpx;
  }

  .acp-save-rule-description {
    color: #6b7280;
    font-size: 22rpx;
    line-height: 32rpx;
    word-break: break-all;
  }

  .acp-options {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 12rpx;
    margin-top: 24rpx;
  }

  .acp-option-button {
    height: 64rpx;
    min-width: 148rpx;
    margin: 0;
    padding: 0 22rpx;
    border-radius: 8rpx;
    border: 1rpx solid #d7dae2;
    background: #ffffff;
    color: #15171f;
    font-size: 24rpx;
    line-height: 62rpx;
  }

  .acp-option-button::after {
    border: none;
  }

  .acp-option-button-primary {
    border-color: #1677ff;
    background: #1677ff;
    color: #ffffff;
  }

  .acp-option-button-danger {
    border-color: #ef4444;
    color: #ef4444;
  }

  .acp-option-button-secondary {
    color: #4b5563;
  }

  .acp-error {
    display: block;
    margin-top: 16rpx;
    color: #ef4444;
    font-size: 22rpx;
    line-height: 32rpx;
  }

  .acp-submitted {
    display: block;
    margin-top: 16rpx;
    color: #1677ff;
    font-size: 22rpx;
    line-height: 32rpx;
  }
</style>

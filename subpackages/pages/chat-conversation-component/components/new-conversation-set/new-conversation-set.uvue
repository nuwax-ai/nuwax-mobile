<template>
  <view class="variables-box flex flex-col" v-if="variables.length > 0">
    <!-- header -->
    <view class="header">
      <text class="title">{{ t("Mobile.Conversation.settingsTitle") }}</text>
      <text class="iconfont icon-a-Chevrondown down-icon" :class="{'rotate-90': !isOpen}" @click="handleOpenClose" />
    </view>
    <!-- 内容区域 -->
    <view :class="{'close-form': !isOpen, 'conversation-container': isOpen}">
      <view class="form-box">
        <view class="uni-form-item" v-for="item in variables" :key="item.name">
          <!-- 名称 -->
          <view class="form-item-title">
            <text class="display-name">{{ item.displayName }}</text>
            <text v-if="item.require == true" class="required">{{
              t("Mobile.Common.requiredMark")
            }}</text>
          </view>
          <!-- textarea -->
          <textarea
            v-if="isInput(item, 'Paragraph')"
            :placeholder="item.description != null && item.description.length > 0 ? item.description : t('Mobile.Common.pleaseInput')"
            class="uni-input"
            :class="{'disabled-style': disabled}"
            :disabled="disabled"
            :value="getField(item.name)"
            placeholder-class="uni-placeholder"
            :maxlength="-1"
            @focus="markCurrentItem(item)"
            @input="handleChangeInput" />
          <!-- 级联下拉选择器(单选、多选) -->
          <view
            v-else-if="isInput(item, 'Select') || isInput(item, 'MultipleSelect')"
            class="uni-input flex flex-row items-center content-between"
            @click="handleSelect(item)"
          >
            <scroll-view
              v-if="getSourceList(item.name).length > 0"
              class="flex-1 flex flex-row items-center"
              direction="horizontal"
              :scroll-with-animation="true"
              :show-scrollbar="false"
              scroll-x>
              <!-- 循环渲染 -->
              <template v-for="(info, index) in getSourceList(item.name)" :key="info">
                <!-- 多选样式 -->
                <view class="multiple-box" v-if="isInput(item, 'MultipleSelect')">
                  <text :class="{'disabled-style': disabled}">{{ getLabel(info) }}</text>
                </view>
                <!-- 单选样式 -->
                <template v-else>
                  <text :class="{'disabled-style': disabled}">{{ getLabel(info) }}</text>
                  <text
                    :class="{'disabled-style': disabled}"
                    v-if="index != getSourceList(item.name).length - 1"
                  >
                    {{ t("Mobile.Common.optionSeparator") }}
                  </text>
                </template>
              </template>
            </scroll-view>
            <text v-else class="uni-placeholder">{{
              t("Mobile.Common.pleaseSelect")
            }}</text>
            <text class="iconfont icon-a-Chevrondown down-icon ml-10" />
          </view>
          <!-- 输入框 -->
          <input
            v-else
            :disabled="disabled"
            :value="getField(item.name)"
            :placeholder="item.description != null && item.description.length > 0 ? item.description : t('Mobile.Common.pleaseInput')"
            :type="isInput(item, 'Number') ? 'number' : 'text'"
            class="uni-input"
            :class="{'disabled-style': disabled}"
            placeholder-class="uni-placeholder"
            @focus="markCurrentItem(item)"
            @input="handleChangeInput"
          />
        </view>
      </view>
      <view v-if="disabled" class="desc-box">
        <text class="desc">{{
          t("Mobile.Conversation.settingsLocked")
        }}</text>
      </view>
      <!-- 单选级联选择器 -->
      <l-cascader
        v-if="visible"
        :visible="visible"
        v-model="cascaderValue"
        :title="t('Mobile.Common.pleaseSelect')"
        :options="options"
        @close="handleCancelSelect"
        @change="onChange" />

      <!-- 多选级联选择器 -->
      <l-cascader
        v-if="visibleMultiple"
        :visible="visibleMultiple"
        v-model:multipleValue="cascaderMultipleValue"
        :multiple="isMultiple"
        :title="t('Mobile.Common.pleaseSelect')"
        :options="options"
        :confirmBtn="t('Mobile.Common.ok')"
        @close="handleCancelSelect"
        @finish="handleFinish" />
    </view>
  </view>
</template>

<script setup lang="uts">
  import { ref, computed, watch, type Ref } from "vue";
  import { BindConfigWithSub } from '@/types/interfaces/common';
  import lCascader from '@/uni_modules/lime-cascader/components/l-cascader/l-cascader.uvue';
  import { useI18n } from "@/utils/i18n";

  const { t: tRaw } = useI18n();
  const t = (key: string): string => tRaw(key, new Map<string, any>(), "");

  const props = defineProps<{
    variables: BindConfigWithSub[];
    userFillVariables: UTSJSONObject;
    isFilled: boolean;
    disabled: boolean;
  }>();

  // 是否打开表单
  const isOpen = ref<boolean>(true);
  // 是否显示单选级联选择器
  const visible = ref<boolean>(false);
  // 是否显示多选级联选择器
  const visibleMultiple = ref<boolean>(false);
  // 是否多选
  const isMultiple = ref<boolean>(false);
  // 级联选择器选项
  const options = ref<any[]>([]);
  // 已选择项的值（单选模式）
  const cascaderValue = ref<string>('');
  // 已选择项的值（多选模式）
  const cascaderMultipleValue = ref<string[]>([]);
  // 当前选择项的名称
  const currentName = ref<string>('');
  // 当前正在编辑的项（用于 @input 回调定位 item）
  const currentInputItem = ref<BindConfigWithSub | null>(null);
  // 表单数据（动态 string-keyed map，用 UTSJSONObject 支持 bracket get/set）
  const formData = ref<UTSJSONObject>({} as UTSJSONObject);
  // 已选择项的源数据（动态 string-keyed map）
  const formSourceData = ref<UTSJSONObject>({} as UTSJSONObject);

  const emit = defineEmits(['toggleWholeDisabled'])

  defineExpose({
    variableParams: formData
  })

  // 取字符串字段值（供模板安全读取动态 map）
  const getField = (name: string): string => {
    const v = formData.value[name];
    if (v == null) {
      return "";
    }
    return `${v}`;
  }

  // 取源数据数组（供模板安全读取动态 map）
  const getSourceList = (name: string): any[] => {
    const v = formSourceData.value[name];
    if (v == null) {
      return [] as any[];
    }
    return v as any[];
  }

  // 取选项 label，兼容字符串与对象两种形态
  const getLabel = (info: any): string => {
    if (info == null) {
      return "";
    }
    const obj = info as UTSJSONObject;
    const label = obj["label"];
    if (label != null) {
      return `${label}`;
    }
    return `${info}`;
  }

  // 安全比较可选枚举字段 item.inputType（interface 中为可选；模板无法引用枚举常量，
  // 因此改为接收目标类型的字符串名称进行比对）
  const isInput = (item: BindConfigWithSub, targetName: string): boolean => {
    const raw = item.inputType;
    if (raw == null) {
      return false;
    }
    return `${raw}` == targetName;
  }

  // 判断 UTSJSONObject 是否为空对象
  const isEmptyObject = (obj: UTSJSONObject | null): boolean => {
    if (obj == null) {
      return true;
    }
    const keys = UTSJSONObject.keys(obj);
    return keys.length == 0;
  }

  // 将 src 的键值拷贝到 dst（dst 为 ref<UTSJSONObject>）
  const copyInto = (dst: Ref<UTSJSONObject>, src: UTSJSONObject) => {
    const keys = UTSJSONObject.keys(src);
    for (let i = 0; i < keys.length; i++) {
      const k = `${keys[i]}`;
      const v = src[k];
      dst.value[k] = v as any;
    }
  }

  // 清空 dst（替换为空对象保持引用）
  const clearMap = (dst: Ref<UTSJSONObject>) => {
    dst.value = {} as UTSJSONObject;
  }

  /**
   * 监听智能体用户已填写的变量参数
   * getter 返回 UTSJSONObject，回调显式标注类型，避免 Any/Unit 推断失败
   */
  watch((): UTSJSONObject => props.userFillVariables, (newVal: UTSJSONObject) => {
    if (isEmptyObject(newVal)) {
      clearMap(formSourceData);
      clearMap(formData);
    } else {
      clearMap(formSourceData);
      clearMap(formData);
      copyInto(formSourceData, newVal);
      copyInto(formData, newVal);
    }
  }, { deep: true, immediate: true })

  // 必填变量参数name列表
  const requiredNameList = computed((): string[] => {
    const list = props.variables;
    const result: string[] = [];
    for (let i = 0; i < list.length; i++) {
      const item = list[i];
      if (item.systemVariable != true && item.require == true) {
        result.push(item.name);
      }
    }
    return result;
  })

  // 触发“必填校验”的刷新计数器（手动驱动 watch）
  const validateTick = ref<number>(0);
  const bumpValidate = () => { validateTick.value = validateTick.value + 1; }

  // 监听必填参数列表变化（仅数组本身）
  watch([requiredNameList, validateTick], () => {
    const required = requiredNameList.value;
    if (required.length > 0) {
      let isSameName = true;
      for (let i = 0; i < required.length; i++) {
        const name = required[i];
        const v = formData.value[name];
        if (v == null || (`${v}`).length == 0) {
          isSameName = false;
          break;
        }
      }
      emit('toggleWholeDisabled', !isSameName);
    }
  }, { deep: true, immediate: true })

  /**
   * 级联选择器选择后
   * @param selectedPaths 选中的路径数组 输出: [['440000', '440300', '440305'], ['440000', '440300', '440306']]
   * @param selectedOptions 选中的源数据
   */
  const handleFinish = (selectedPaths: string[][], selectedOptions: Record<string, any>[]) => {
    formData.value[currentName.value] = selectedPaths;
    formSourceData.value[currentName.value] = selectedOptions;
    visibleMultiple.value = false;
    isMultiple.value = false;
    bumpValidate();
  }

  // 打开关闭表单
  const handleOpenClose = () => {
    isOpen.value = !isOpen.value;
  }

  // 级联选择器选择后（单选模式）
  const onChange = (_: string | string[], selectedOptions: any[]) => {
    if (!isMultiple.value) {
      visible.value = false;
      // 单选模式：value 是 string，selectedOptions 是选中的选项数组
      const mapped: string[] = [];
      if (selectedOptions != null) {
        for (let i = 0; i < selectedOptions.length; i++) {
          const opt = selectedOptions[i] as UTSJSONObject;
          const v = opt["value"];
          mapped.push(`${v}`);
        }
      }
      formData.value[currentName.value] = mapped;
      formSourceData.value[currentName.value] = selectedOptions != null ? selectedOptions : ([] as any[]);
      bumpValidate();
    }
  }

  // 点击后打开级联选择器
  const handleSelect = (item: BindConfigWithSub) => {
    // 如果禁用,则不打开级联选择器
    if (props.disabled == true) {
      return;
    }
    // 当前选择项的名称
    currentName.value = item.name;
    // 是否多选（用字符串名比对可选枚举）
    const isMulti = isInput(item, "MultipleSelect");
    if (isMulti) {
      visibleMultiple.value = true;
    } else {
      // 显示级联选择器
      visible.value = true;
    }
    // 是否多选
    isMultiple.value = isMulti;
    // 下拉选择项配置
    const sc = item.selectConfig;
    if (sc != null) {
      // 复制数组以规避 UTSArray 协变（out Any vs Any）
      const opts: any[] = [];
      const srcOpts = sc.options;
      for (let i = 0; i < srcOpts.length; i++) {
        opts.push(srcOpts[i] as any);
      }
      options.value = opts;
    } else {
      options.value = [] as any[];
    }
    // 已选择项的源数据中获取当前项的值
    const currentList = getSourceList(item.name);

    if (isMultiple.value == true) {
      // 多选模式：初始化多选值
      if (currentList.length == 0) {
        cascaderMultipleValue.value = [];
      } else {
        const vals: string[] = [];
        for (let i = 0; i < currentList.length; i++) {
          const it = currentList[i] as UTSJSONObject;
          const v = it["value"];
          vals.push(v != null ? `${v}` : "");
        }
        cascaderMultipleValue.value = vals;
      }
    } else {
      // 单选模式：初始化单选值
      if (currentList.length == 0) {
        cascaderValue.value = '';
      } else {
        const lastItem = currentList[currentList.length - 1] as UTSJSONObject;
        const v = lastItem["value"];
        cascaderValue.value = v != null ? `${v}` : '';
      }
    }
  }

  // 取消级联选择
  const handleCancelSelect = () => {
    // 当前选择项的名称
    currentName.value = '';
    // 隐藏级联选择器
    visible.value = false;
    visibleMultiple.value = false;
    isMultiple.value = false;
    // 下拉选择项配置
    options.value = [];
    // 已选择项的值
    cascaderValue.value = '';
    cascaderMultipleValue.value = [];
  }

  // 输入框/textarea 输入值（绑定到当前编辑项）
  const handleChangeInput = (event: UniInputChangeEvent) => {
    const item = currentInputItem.value;
    if (item == null) {
      return;
    }
    formData.value[item.name] = event.detail.value;
    formSourceData.value[item.name] = event.detail.value;
    bumpValidate();
  }

  // 在渲染时同步当前编辑项（通过 v-for 进入 input/textarea 前调用）
  // 注意：uts 模板无法直接传 item 进 @input 回调，改用 onFocus 标记当前项
  const markCurrentItem = (item: BindConfigWithSub) => {
    currentInputItem.value = item;
  }
</script>

<style lang="scss" scoped>
  .variables-box {
    /* #ifdef H5 */
    max-height: 50%;
    /* #endif */
    /* #ifndef H5 */
    max-height: 600rpx;
    /* #endif */
    border-radius: 10rpx;
    background-color: #fff;
    border: 1rpx solid #e5e5e5;
    box-sizing: border-box;
    margin: 0 32rpx;

    .header {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      font-weight: bold;
      padding: 18rpx 20rpx;

      .title {
        font-size: 28rpx;
        color: #15171F;
      }
    }

    .down-icon {
        color: #95979c;
        user-select: none;
        font-size: 32rpx;
        transition: transform 0.3s ease-in-out;

        &.rotate-90 {
          transform: rotate(-90deg);
        }
      }

    .conversation-container {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding-top: 20rpx;
      border-top: 1rpx solid #e5e5e5;
      box-sizing: border-box;
      overflow: hidden;
    }

    .close-form {
      transition: height 0.3s ease-in-out;
      height: 0;
      overflow: hidden;
    }

    .form-box {
      flex: 1;
      max-height: 400rpx;
      /* #ifdef H5 */
      overflow-y: auto;
      /* #endif */
      /* #ifndef H5 */
      overflow-y: hidden;
      /* #endif */
      padding: 0 20rpx;

      .uni-form-item {
        padding: 16rpx 0;

        .form-item-title {
          display: flex;
          flex-direction: row;
          align-items: center;

          .display-name {
            font-size: 28rpx;
            color: #15171F;
          }

          .required {
            margin-left: 4rpx;
            color: #FF0000;
          }
        }

        .uni-input {
          width: 100%;
          height: 72rpx;
          line-height: 40rpx;
          background-color: rgba(12,20,40,0.04);
          border-radius: 8rpx;
          font-size: 28rpx;
          color: #15171F;
          padding: 16rpx;
          margin-top: 8rpx;
          box-sizing: border-box;
        }

        // 禁用样式
        .disabled-style {
          background-color: #f5f5f5;
          color: #999;
        }

        .uni-placeholder {
          color: #6b6b75;
          font-size: 28rpx;
        }

        .multiple-box {
          display: flex;
          align-items: center;
          justify-content: center;
          background-color: rgba(0, 0, 0, 0.06);
          padding: 4rpx 12rpx;
          margin-right: 16rpx;
          border-radius: 8rpx;

          .disabled-style {
            background-color: transparent;
          }
        }
      }
    }

    .desc-box {
      display: flex;
      justify-content: center;
      height: 70rpx;
      padding: 0 20rpx;
      box-sizing: border-box;

      .desc {
        color: #e5e5e5;
        font-size: 28rpx;
      }
    }
  }
</style>

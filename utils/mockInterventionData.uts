    submitLabel: "确认发布",
    cancelLabel: "取消",
  };

  return {
    ...createMockMcpAskBase(),
    title: "发布检查",
    description: "请按步骤确认发布配置",
    ui: ui,
    responseStatus: "pending",
  };
}

// ==================== Mock 场景注册表 ====================

type MockScenarioKey =
  | "acp-simple"
  | "acp-multi"
  | "acp-network"
  | "mcp-survey"
  | "mcp-select"
  | "mcp-simple"
  | "mcp-file"
  | "mcp-list"
  | "mcp-wizard";

const MOCK_SCENARIOS: Record<
  MockScenarioKey,
  () => AcpPermissionInteraction | McpAskInteraction
> = {
  "acp-simple": mockAcpPermissionSimple,
  "acp-multi": mockAcpPermissionMultiOption,
  "acp-network": mockAcpPermissionNetwork,
  "mcp-survey": mockMcpAskSurvey,
  "mcp-select": mockMcpAskSelectForm,
  "mcp-simple": mockMcpAskSimple,
  "mcp-file": mockMcpAskWithFile,
  "mcp-list": mockMcpAskWithList,
  "mcp-wizard": mockMcpAskWizard,
};

/** 获取所有可用的 mock 场景 key 列表 */
export function getMockScenarioKeys(): string[] {
  return Object.keys(MOCK_SCENARIOS);
}

/** 根据 key 生成对应的 mock 交互数据 */
export function createMockInteraction(
  key: MockScenarioKey,
): AcpPermissionInteraction | McpAskInteraction | null {
  const factory = MOCK_SCENARIOS[key];
  if (!factory) return null;
  return factory();
}

// ==================== 注入工具 ====================

/**
 * 向消息列表中注入 mock 干预交互
 *
 * 查找最后一条 ASSISTANT 消息, 将 mock interaction 附加到其
 * acpPermissionInteractions 或 mcpAskInteractions 数组.
 * 如果没有 assistant 消息, 则创建一条 mock assistant 消息.
 *
 * @param messageListRef - Vue ref<MessageInfo[]> 消息列表引用
 * @param scenarioKey - mock 场景 key
 * @returns 注入是否成功
 */
export function injectMockIntervention(
  messageListRef: { value: any[] },
  scenarioKey: MockScenarioKey,
): boolean {
  const interaction = createMockInteraction(scenarioKey);
  if (!interaction) {
    console.error(`[MockIntervention] 未知的 mock 场景: ${scenarioKey}`);
    return false;
  }

  const list = [...messageListRef.value];

  // 查找最后一条 assistant 消息
  let targetIndex = -1;
  for (let i = list.length - 1; i >= 0; i--) {
    if (list[i].messageType === "ASSISTANT") {
      targetIndex = i;
      break;
    }
  }

  // 如果没有 assistant 消息, 创建一条 mock 消息
  if (targetIndex < 0) {
    const mockMsg = {
      id: `mock_msg_${Date.now()}`,
      index: 0,
      messageType: "ASSISTANT",
      text: "[Mock] 这是一条测试消息, 用于展示干预交互卡片",
      time: new Date().toISOString(),
      attachments: null,
    };
    list.push(mockMsg);
    targetIndex = list.length - 1;
  }

  const targetMessage = { ...list[targetIndex] };

  // 根据交互类型注入
  if ("request" in interaction && "toolCall" in (interaction as any).request) {
    // ACP Permission
    const acp = interaction as AcpPermissionInteraction;
    const existing = targetMessage.acpPermissionInteractions || [];
    targetMessage.acpPermissionInteractions = [...existing, acp];
    console.log(
      `[MockIntervention] 注入 ACP Permission: ${acp.request.toolCall.title}`,
    );
  } else {
    // MCP Ask
    const mcp = interaction as McpAskInteraction;
    const existing = targetMessage.mcpAskInteractions || [];
    targetMessage.mcpAskInteractions = [...existing, mcp];
    console.log(`[MockIntervention] 注入 MCP Ask: ${mcp.title}`);
  }

  list[targetIndex] = targetMessage;
  messageListRef.value = list;

  return true;
}

/**
 * 清除消息列表中所有 mock 干预交互
 */
export function clearMockInterventions(messageListRef: { value: any[] }): void {
  const list = [...messageListRef.value];
  for (let i = 0; i < list.length; i++) {
    const msg = { ...list[i] };
    if (msg.acpPermissionInteractions) {
      msg.acpPermissionInteractions = msg.acpPermissionInteractions.filter(
        (item: AcpPermissionInteraction) => !item.id.startsWith("mock_acp_"),
      );
      if (msg.acpPermissionInteractions.length === 0) {
        msg.acpPermissionInteractions = undefined;
      }
    }
    if (msg.mcpAskInteractions) {
      msg.mcpAskInteractions = msg.mcpAskInteractions.filter(
        (item: McpAskInteraction) => !item.requestId.startsWith("mock_mcp_"),
      );
      if (msg.mcpAskInteractions.length === 0) {
        msg.mcpAskInteractions = undefined;
      }
    }
    // 清除 mock 消息
    if (msg.id?.startsWith("mock_msg_")) {
      list.splice(i, 1);
      i--;
      continue;
    }
    list[i] = msg;
  }
  messageListRef.value = list;
}

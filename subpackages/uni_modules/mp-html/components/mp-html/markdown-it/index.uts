/**
 * @fileoverview markdown 插件（Android UTS stub）
 * markdown-it and markdown-it-container are JS-only npm packages.
 * On native platforms, markdown rendering is not available.
 */

export class Markdown {
  vm: any | null = null;

  constructor(vm: any) {
    this.vm = vm;
  }

  /** 原样返回 content（native 端无 markdown 渲染） */
  onUpdate(content: string): string {
    return content;
  }

  /** no-op */
  onParse(node: any, vm: any): void {}
}

export default Markdown;

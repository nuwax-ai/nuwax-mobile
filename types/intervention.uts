/**
 * 干预相关类型定义
 * 对齐 nuwax Web 版 AgentIntervention 模块（nuwax.interaction.v2）
 */

// ============ ACP Permission（工具权限审批） ============

/** 权限选项类型 */
export type AcpPermissionOptionKind =
  | "allow_once"
  | "allow_always"
  | "reject_once"
  | "reject_always";

/** 干预状态 */
export type InterventionStatus =
  | "pending"
  | "submitting"
  | "submitted"
  | "failed"
  | "cancelled"
  | "skipped"
  | "timeout";

/** 权限选项 */
export interface AcpPermissionOption {
  optionId: string;
  kind: AcpPermissionOptionKind;
  name: string;
}

/** 工具调用信息 */
export interface AcpToolCallInfo {
  toolCallId: string;
  title?: string;
  kind?: string;
  /** 原始工具输入（用于提取 MCP Ask requestId，对齐 PC readMcpAskRequestId 抑制逻辑） */
  rawInput?: any;
}

/** 权限请求 */
export interface AcpPermissionRequest {
  sessionId: string;
  toolCall: AcpToolCallInfo;
  options: AcpPermissionOption[];
}

/** 权限审批交互状态 */
export interface AcpPermissionInteraction {
  id: string;
  request: AcpPermissionRequest;
  responseStatus: InterventionStatus;
  /**
   * 审批到来时 processingList 的长度（仅实时流模式下设置）。
   * 若 processingList 后续增长，说明 agent 已进入下一步，审批已失效。
   * 对齐 PC focusExecuteId 机制，不依赖 server 侧 executeId 字段。
   */
  processingListLengthAtAdd?: number;
  /** 与 processingList.executeId 对齐，用于 sub 恢复后 reconcile 已审批态 */
  executeId?: string;
  /** FIFO 队列排序键（事件挂载时刻） */
  triggeredAt?: number;
  selectedOptionId?: string;
  errorMessage?: string;
}

/** 权限审批响应 */
export interface AcpPermissionResponse {
  outcome: {
    outcome: "selected" | "cancelled";
    optionId?: string;
  };
}

// ============ MCP Ask（结构化提问，nuwax.interaction.v2） ============

/** 表单展示模式 */
export type McpAskPresentation = "modal" | "inline" | "wizard";

/** 表单字段 widget 类型 */
export const MCP_ASK_WIDGET_TYPES = [
  "text",
  "textarea",
  "number",
  "radio",
  "checkboxes",
  "select",
  "list",
  "file",
  "radio-with-custom",
] as const;

export type McpAskWidget = (typeof MCP_ASK_WIDGET_TYPES)[number];

/** MCP Ask 唯一工具名，对齐 nuwax-ask-question-mcp MCP_ASK_TOOL_NAME */
export const MCP_ASK_TOOL_NAME = "nuwax_ask_question" as const;

/** MCP Ask 工具名类型 */
export type McpAskToolName = typeof MCP_ASK_TOOL_NAME;

/** 表单分步配置 */
export interface InteractionUiStep {
  id: string;
  title: string;
  description?: string;
  fields: string[];
}

/** v2 字段选项（合并旧 enum + enumNames） */
export interface McpAskFieldOption {
  value: string;
  label: string;
}

/** 渲染层（ParsedMcpAskField.options）读取的 UI 配置 */
export interface InteractionUiOptions {
  placeholder?: string;
  allowCustom?: boolean;
  otherValue?: string;
  otherField?: string;
  accept?: string;
  multiple?: boolean;
}

/** v2 单个表单字段（自描述：控件/选项/约束合并进同一对象） */
export interface McpAskFormField {
  name: string;
  title: string;
  widget: McpAskWidget;
  description?: string;
  required?: boolean;
  placeholder?: string;
  initialValue?: any;
  type?: string; // "string" | "integer" | "number" | "array"
  minimum?: number;
  maximum?: number;
  exclusiveMinimum?: number;
  exclusiveMaximum?: number;
  multipleOf?: number;
  minLength?: number;
  maxLength?: number;
  pattern?: string;
  options?: McpAskFieldOption[];
  accept?: string;
  multiple?: boolean;
  maxFileSize?: number;
  allowCustom?: boolean;
  otherValue?: string;
  otherField?: string;
}

/** v2 交互 UI 定义；数组顺序即渲染顺序，不再有 schema/uiSchema/ui:order */
export interface InteractionUiSchema {
  version: string;
  presentation: McpAskPresentation;
  title: string;
  description?: string;
  fields?: McpAskFormField[];
  steps?: InteractionUiStep[];
  submitLabel?: string;
  cancelLabel?: string;
  allowSkip?: boolean;
  skipLabel?: string;
  fallback?: {
    text: string;
    webUrl?: string;
    mobileUrl?: string;
  };
}

/** MCP Ask 交互状态 */
export interface McpAskInteraction {
  toolName?: McpAskToolName;
  schemaVersion?: string;
  requestId: string;
  revision?: number;
  sessionId: string;
  toolCallId?: string;
  title: string;
  description?: string;
  ui: InteractionUiSchema;
  responseStatus: InterventionStatus;
  formData?: Record<string, unknown>;
  errorMessage?: string;
  triggeredAt?: number;
  /**
   * 事件到来时 processingList 的长度（仅实时流模式下设置）。
   * 对齐 PC focusExecuteId 机制：若 processingList 后续增长，说明 agent 已进入下一步，卡片过期关闭。
   */
  processingListLengthAtAdd?: number;
}

/** MCP Ask 响应 payload */
export interface McpAskRespondPayload {
  interventionId?: string;
  toolCallId?: string;
  revision?: number;
  source?: "mcp_ask";
  protocol?: "mcp";
  action: "submit" | "cancel" | "skip" | "timeout";
  formData?: Record<string, unknown>;
  answeredBy?: {
    kind: "web" | "mobile";
    userId?: string;
    clientId?: string;
  };
  answeredAt?: number;
}

/** intervention-card 调度器 kind */
export type InterventionCardKind = "acp_permission" | "mcp_ask";

<template>
  <view class="sidebar">
    <!-- 用户信息（固定顶部） -->
    <view class="user-info">
      <image :src="props.user?.avatar" class="avatar" mode="aspectFill" :alt="t('Mobile.Common.avatarAlt')"></image>
      <view class="user-meta">
        <text class="nickname text-ellipsis">{{ props.user?.nickname }}</text>
        
        <!-- 积分展示 -->
        <view v-if="props.isSubscriptionEnabled" class="credits-show" @click="handleGoSubscriptions">
          <text class="credits-label">{{ t('Mobile.MySubscriptions.totalCredits') }}</text>
          <text class="credits-value">{{ formatCredit(props.totalCredit) }}</text>
          <view class="credits-action">
            <text class="action-text">{{ t('Mobile.MySubscriptions.addPurchase') }}</text>
            <text class="iconfont icon-Chevronright-1"></text>
          </view>
        </view>
      </view>
    </view>
 
    <!-- 会话记录（弹性撑满并局部滚动） -->
    <view class="session-recording">
      <!-- 头部固定 -->
      <view class="section-header">
        <view class="section-title">{{ t('Mobile.Common.conversationHistory') }}</view>
        
        <!-- 订阅按钮 -->
        <view v-if="props.isSubscriptionEnabled && props.isPaymentRequired" class="subscription-btn" @click="handleOpenSubscription">
          <text class="iconfont icon-member subscription-icon"></text>
          <text class="subscription-text">{{ t('Mobile.MySubscriptions.subscribeNow') }}</text>
        </view>
      </view>
      
      <!-- 会话历史列表（局部滚动，带滚动条） -->
      <scroll-view class="content-scroll" scroll-y="true" :show-scrollbar="true">
        <custom-nav-bar-speak :chat-list="props.chatList" :is-app-details="true" />
      </scroll-view>
    </view>
 
    <!-- 退出 -->
    <view class="logout">
      <view class="logout-item" @click="handleLogout">
        <text class="iconfont icon-Exit"></text>
        <text class="logout-text">{{ t('Mobile.Header.logout') }}</text>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import type { ConversationInfo} from '@/types/interfaces/conversationInfo';
import { SUCCESS_CODE } from '@/constants/codes.constants';
import { apiLogout } from '@/servers/account';
import { t } from '@/utils/i18n';
import CustomNavBarSpeak from '@/components/custom-nav-bar/custom-nav-bar-speak/custom-nav-bar-speak.uvue'
import { formatNumber } from "@/utils/system";

// 定义props
const props = withDefaults(
  defineProps<{
    user: {avatar: string, nickname: string},
    chatList: ConversationInfo[],
    totalCredit: number | null,
    isSubscriptionEnabled: boolean,
    isPaymentRequired?: boolean
  }>(),
  {
    isPaymentRequired: false
  }
)

// 定义 emits
const emit = defineEmits<{
  (e: "open-subscription"): void
}>()

const handleOpenSubscription = () => {
  emit("open-subscription")
}

const formatCredit = (value: number | null): string => {
  if (value == null) {
    return "--";
  }
  return value % 1 === 0 ? formatNumber(value, 0) : formatNumber(value, 2);
};

const handleGoSubscriptions = () => {
  const pages = getCurrentPages();
  const current = pages[pages.length - 1];
  const isEmptyObject = Object.keys(current.options).length === 0;
  const currentPath = isEmptyObject ? `/${current.route}` : `/${current.route}?${objectToQuery(current.options)}`;

  // 将返回路径安全存储到本地缓存，避免 URL 参数过长或被改写
  uni.setStorageSync("SUB_BACK_URL", currentPath);

  uni.navigateTo({
    url: "/subpackages/pages/my-subscriptions/my-subscriptions"
  });
};

// 对象转 query 字符串
function objectToQuery(obj) {
  return Object.keys(obj)
    .map(key => `${key}=${encodeURIComponent(obj[key])}`)
    .join('&');
}

// 获取当前页面信息
function getCurrentPageInfo() {
  // #ifdef H5 || WEB
  /**
   * 此处获取完整路径，因为H5端页面跳转redirectTo方法中需要完整路径
   */
  return window.location.href;
  // #endif

  // #ifdef MP-WEIXIN
  const pages = getCurrentPages();
  if (pages.length === 0) return '';
  // 获取当前页面
  const current = pages[pages.length - 1];

  // 判断参数对象是否为空
  const isEmptyObject = Object.keys(current.options).length === 0;
  // current.route 页面路径，如 pages/index/index
  // current.options 参数对象，如 {id: "123", conversationId: "456"}
  // fullPath 完整路径，如 /pages/index/index?id=123&conversationId=456
  return isEmptyObject ? `/${current.route}` : `/${current.route}?${objectToQuery(current.options)}`;
  // #endif
}

// 退出登录
const handleLogout = async ()=>{

  try {
    const result = await apiLogout()
    if (result.code === SUCCESS_CODE) {
      uni.showToast({
        title: t('Mobile.Header.logoutSuccess'),
        icon: 'success'
      })

      uni.clearStorageSync()
      // 获取当前页面完整路径
      const fullPath = getCurrentPageInfo();
      
      // #ifdef H5 || WEB
      const url = `/subpackages/pages/login/login?redirect=${encodeURIComponent(fullPath)}`;
      uni.reLaunch({ url });
      // #endif

      // #ifdef MP-WEIXIN
      uni.reLaunch({ url: `/subpackages/pages/login-weixin/login-weixin?redirect=${encodeURIComponent(fullPath)}` });
      // #endif
    }

  } catch (error) {
    uni.showToast({
      title: t('Mobile.Header.logoutFailed'),
      icon: 'none'
    })
    return
  }
}

</script>

<style lang="scss" scoped>
  @import "./history-conversation-popup.scss";
</style>

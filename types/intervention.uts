/**
 * 干预相关类型定义
 * 对齐 nuwax Web 版 AgentIntervention 模块
 */

// ============ ACP Permission（工具权限审批） ============

/** 权限选项类型 */
export type AcpPermissionOptionKind =
  | "allow_once"
  | "allow_always"
  | "reject_once"
  | "reject_always";

/** 干预状态 */
export type InterventionStatus =
  | "pending"
  | "submitting"
  | "submitted"
  | "failed"
  | "cancelled"
  | "skipped"
  | "timeout";

/** 权限选项 */
export interface AcpPermissionOption {
  optionId: string;
  kind: AcpPermissionOptionKind;
  name: string;
}

/** 工具调用信息 */
export interface AcpToolCallInfo {
  toolCallId: string;
  title?: string;
  kind?: string;
}

/** 权限请求 */
export interface AcpPermissionRequest {
  sessionId: string;
  toolCall: AcpToolCallInfo;
  options: AcpPermissionOption[];
}

/** 权限审批交互状态 */
export interface AcpPermissionInteraction {
  id: string;
  request: AcpPermissionRequest;
  responseStatus: InterventionStatus;
  selectedOptionId?: string;
  errorMessage?: string;
}

/** 权限审批响应 */
export interface AcpPermissionResponse {
  outcome: {
    outcome: "selected" | "cancelled";
    optionId?: string;
  };
}

// ============ MCP Ask（结构化提问） ============

/** 表单展示模式 */
export type McpAskPresentation = "modal" | "inline" | "wizard" | "table";

/** 表单字段 widget 类型 */
export type McpAskWidget =
  | "radio"
  | "checkboxes"
  | "select"
  | "text"
  | "textarea"
  | "radio-with-custom"
  | "file"
  | "list";

/** MCP Ask 工具名 */
export type McpAskToolName = "nuwax_ask_question";

/** 表单分步配置 */
export interface InteractionUiStep {
  id: string;
  title: string;
  description?: string;
  fields: string[];
}

/** UI Schema 选项 */
export interface InteractionUiOptions {
  allowSkip?: boolean;
  skipLabel?: string;
  allowCustom?: boolean;
  otherValue?: string;
  otherField?: string;
  enumNames?: string[];
  placeholder?: string;
  accept?: string;
  multiple?: boolean;
}

/** UI Schema */
export interface InteractionUiSchema {
  version: string;
  presentation: McpAskPresentation;
  title: string;
  description?: string;
  schema: Record<string, unknown>;
  uiSchema?: Record<string, unknown>;
  table?: Record<string, unknown>;
  steps?: InteractionUiStep[];
  initialValue?: Record<string, unknown>;
  submitLabel?: string;
  cancelLabel?: string;
  skipLabel?: string;
  fallback?: {
    text: string;
    webUrl?: string;
    mobileUrl?: string;
  };
}

/** MCP Ask 交互状态 */
export interface McpAskInteraction {
  toolName?: McpAskToolName;
  schemaVersion?: string;
  requestId: string;
  revision?: number;
  sessionId: string;
  toolCallId?: string;
  title: string;
  description?: string;
  ui: InteractionUiSchema;
  responseStatus: InterventionStatus;
  formData?: Record<string, unknown>;
  errorMessage?: string;
  triggeredAt?: number;
}

/** MCP Ask 响应 payload */
export interface McpAskRespondPayload {
  interventionId?: string;
  toolCallId?: string;
  revision?: number;
  source?: "mcp_ask";
  protocol?: "mcp";
  action: "submit" | "cancel" | "skip" | "timeout";
  formData?: Record<string, unknown>;
  answeredBy?: {
    kind: "web" | "mobile";
    userId?: string;
    clientId?: string;
  };
  answeredAt?: number;
}

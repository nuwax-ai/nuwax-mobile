<template>
  <view class="mcp-ask-card" v-if="interaction">
    <!-- 标题区 -->
    <view class="card-header">
      <text class="card-eyebrow">{{ t('Mobile.Intervention.McpAsk.eyebrow') }}</text>
      <text class="card-title">{{ interaction.title }}</text>
      <text v-if="interaction.description" class="card-desc">{{
        interaction.description
      }}</text>
    </view>

    <!-- 状态标签（对齐 PC 端：failed 状态不显示标签，仅底部展示 errorMessage）-->
    <view v-if="interaction.responseStatus !== 'pending' && interaction.responseStatus !== 'failed'" class="status-tag">
      <text
        v-if="interaction.responseStatus === 'submitted'"
        class="iconfont icon-a-Checkcircle status-icon status-icon-success"
      />
      <text
        v-else-if="interaction.responseStatus === 'cancelled'"
        class="iconfont icon-a-Xcircle status-icon status-icon-cancelled"
      />
      <text
        v-else-if="interaction.responseStatus === 'skipped'"
        class="iconfont icon-attention status-icon status-icon-skipped"
      />
      <text class="status-tag-text">{{ statusLabel }}</text>
    </view>

    <!-- 表单区 -->
    <view v-if="interaction.responseStatus === 'pending'" class="card-form">
      <!-- 步骤进度条（对齐 PC antd Steps） -->
      <view v-if="isWizard && steps.length > 1" class="wizard-steps-block">
        <view class="wizard-step-row">
          <view
            v-for="(step, index) in steps"
            :key="step.id"
            class="wizard-step-cell"
          >
            <view class="step-icon-row">
              <!-- 左侧连接线（第一步不显示） -->
              <view
                v-if="index > 0"
                class="step-connector-half"
                :class="{ 'step-connector-active': index <= currentStep }"
              />
              <!-- 步骤圆圈 -->
              <view
                class="step-circle"
                :class="{
                  'step-circle-done': index < currentStep,
                  'step-circle-active': index === currentStep,
                }"
              >
                <text
                  v-if="index < currentStep"
                  class="iconfont icon-Check step-check-icon"
                />
                <text v-else class="step-num-text">{{ index + 1 }}</text>
              </view>
              <!-- 右侧连接线（最后一步不显示） -->
              <view
                v-if="index < steps.length - 1"
                class="step-connector-half"
                :class="{ 'step-connector-active': index < currentStep }"
              />
            </view>
            <text
              class="step-label"
              :class="{
                'step-label-active': index === currentStep,
                'step-label-done': index < currentStep,
              }"
            >{{ step.title }}</text>
          </view>
        </view>
        <!-- 当前步骤描述（对齐 PC stepCallout） -->
        <view v-if="activeStepDescription" class="step-callout">
          <text class="step-callout-text">{{ activeStepDescription }}</text>
        </view>
      </view>
      <scroll-view
        class="card-form-scroll"
        direction="vertical"
        :show-scrollbar="false"
      >
        <view
          v-for="field in visibleFields"
          :key="field.name"
          class="form-field"
        >
          <text class="field-label"
            >{{ field.label
            }}<text v-if="field.required" class="field-required">{{
              requiredMark
            }}</text></text
          >

          <!-- text 输入 -->
          <input
            v-if="field.widget === 'text'"
            class="field-input"
            :value="(formData[field.name] as string) || ''"
            @input="onTextInput(field.name, $event)"
            :placeholder="field.placeholder || field.label"
          />

          <!-- textarea 输入 -->
          <textarea
            v-else-if="field.widget === 'textarea'"
            class="field-textarea"
            :value="(formData[field.name] as string) || ''"
            @input="onTextInput(field.name, $event)"
            :placeholder="field.placeholder || field.label"
          />

          <!-- number 数字输入 -->
          <input
            v-else-if="field.widget === 'number'"
            class="field-input"
            :type="field.isInteger ? 'number' : 'digit'"
            :value="formatNumberValue(formData[field.name])"
            @input="onNumberInput(field.name, $event)"
            :placeholder="field.placeholder || field.label"
          />

          <!-- radio / select / list / radio-with-custom — 单选列表 -->
          <view
            v-else-if="
              field.widget === 'radio' ||
              field.widget === 'select' ||
              field.widget === 'list' ||
              field.widget === 'radio-with-custom'
            "
            class="field-list-group"
          >
            <view
              v-for="opt in field.options"
              :key="opt.value"
              class="list-option"
              @tap="onRadioSelect(field.name, opt.value)"
            >
              <view
                class="list-radio-dot"
                :class="{ 'dot-selected': formData[field.name] === opt.value }"
              >
                <text
                  v-if="formData[field.name] === opt.value"
                  class="iconfont icon-Check dot-check-icon"
                />
              </view>
              <text class="list-label">{{ opt.label }}</text>
            </view>
            <view
              v-if="field.widget === 'radio-with-custom'"
              class="list-option"
              @tap="onRadioSelect(field.name, field.otherValue)"
            >
              <view
                class="list-radio-dot"
                :class="{
                  'dot-selected': formData[field.name] === field.otherValue,
                }"
              >
                <text
                  v-if="formData[field.name] === field.otherValue"
                  class="iconfont icon-Check dot-check-icon"
                />
              </view>
              <text class="list-label">{{
                t("Mobile.Intervention.McpAsk.customOption")
              }}</text>
            </view>
            <input
              v-if="
                field.widget === 'radio-with-custom' &&
                formData[field.name] === field.otherValue
              "
              class="field-input custom-input"
              :value="(formData[field.otherField] as string) || ''"
              @input="onTextInput(field.otherField, $event)"
              :placeholder="
                field.placeholder ||
                t('Mobile.Intervention.McpAsk.customPlaceholder')
              "
            />
          </view>

          <!-- checkboxes 多选 -->
          <l-checkbox-group
            v-else-if="field.widget === 'checkboxes'"
            :modelValue="(formData[field.name] as string[]) || []"
            @update:modelValue="(val: string[]) => formData[field.name] = val"
            direction="vertical"
            icon="rectangle"
            checkedColor="#1677ff"
            gap="12rpx"
          >
            <l-checkbox
              v-for="opt in field.options"
              :key="opt.value"
              :value="opt.value"
              :label="opt.label"
            />
          </l-checkbox-group>

          <!-- file 文件上传 -->
          <view v-else-if="field.widget === 'file'" class="field-file-area">
            <!-- 已上传文件列表 -->
            <view v-if="getFileList(field.name).length" class="file-list">
              <view
                v-for="file in getFileList(field.name)"
                :key="file.uid"
                class="file-item"
              >
                <image
                  v-if="file.type?.includes('image/')"
                  :src="file.url"
                  class="file-thumb"
                  mode="aspectFill"
                />
                <view v-else class="file-doc">
                  <text class="iconfont icon-a-Filetext file-doc-icon" />
                  <text class="file-doc-name">{{ file.name }}</text>
                </view>
                <view
                  class="file-remove"
                  @tap="removeFile(field.name, file.uid!)"
                >
                  <text class="iconfont icon-closeempty" />
                </view>
                <!-- 上传中遮罩 -->
                <view
                  v-if="file.status === 'uploading'"
                  class="file-uploading-mask"
                >
                  <text class="file-uploading-text">{{
                    getUploadPercentText(file)
                  }}</text>
                </view>
              </view>
            </view>
            <!-- 上传按钮 -->
            <view class="file-upload-actions">
              <view
                class="file-upload-btn"
                @tap="chooseAndUpload(field, 'image')"
              >
                <text class="iconfont icon-tupian" />
                <text class="file-upload-btn-text">{{
                  t("Mobile.Intervention.McpAsk.uploadImage")
                }}</text>
              </view>
              <view
                class="file-upload-btn"
                @tap="chooseAndUpload(field, 'file')"
              >
                <text class="iconfont icon-a-Filetext" />
                <text class="file-upload-btn-text">{{
                  t("Mobile.Intervention.McpAsk.uploadFile")
                }}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 操作按钮 -->
      <view class="form-actions">
        <l-button
          v-if="isWizard && currentStep > 0"
          class="action-button"
          type="default"
          variant="light"
          radius="12rpx"
          @click="handlePrev"
        >
          {{ t("Mobile.Intervention.McpAsk.prev") }}
        </l-button>
        <l-button
          class="action-button"
          type="default"
          variant="light"
          radius="12rpx"
          @click="handleCancel"
        >
          {{
            interaction.ui?.cancelLabel ||
            t("Mobile.Intervention.McpAsk.cancel")
          }}
        </l-button>
        <l-button
          v-if="allowSkip"
          class="action-button"
          type="default"
          variant="light"
          radius="12rpx"
          @click="handleSkip"
        >
          {{ skipLabel }}
        </l-button>
        <l-button
          v-if="isWizard && !isLastStep"
          class="action-button action-button-primary"
          type="primary"
          radius="12rpx"
          @click="handleNext"
        >
          {{ t("Mobile.Intervention.McpAsk.next") }}
        </l-button>
        <l-button
          v-else
          class="action-button action-button-primary"
          type="primary"
          radius="12rpx"
          @click="handleSubmit"
        >
          {{
            interaction.ui?.submitLabel ||
            t("Mobile.Intervention.McpAsk.submit")
          }}
        </l-button>
      </view>
    </view>

    <!-- 失败错误消息（对齐 PC 端 isFailed errorMessage 展示）-->
    <text
      v-if="interaction.responseStatus === 'failed' && interaction.errorMessage"
      class="card-error-msg"
    >{{ interaction.errorMessage }}</text>
  </view>
</template>

<script lang="uts">
  /**
   * MCP Ask 结构化提问卡片
   *
   * 示例页面：
   *   路由  /pages/test-intervention/test-intervention
   *   H5    {域名}/m/#/pages/test-intervention/test-intervention
   * 详见 components/agent-intervention/README.md
   */
  import { t } from "@/utils/i18n.uts";
  import type {
    InteractionUiStep,
    McpAskFormField,
    McpAskInteraction,
    McpAskRespondPayload,
  } from "@/types/intervention";
  import { uploadSingleFile, generateFileUid } from "@/utils/fileUploader";
  import { UploadFileInfo } from "@/types/interfaces/common.uts";
  import { UploadFileStatus } from "@/types/enums/common.uts";
  import type { AttachmentFile } from "@/types/interfaces/conversationInfo.uts";
  import {
    getInteractionSteps,
    getSkipLabel,
    isSkipAllowed,
    isWizardPresentation,
    parseInteractionFields,
  } from "@/utils/mcpAskSchema.uts";
  import type { ParsedMcpAskField } from "@/utils/mcpAskSchema.uts";

  interface ParsedField {
    name: string;
    label: string;
    widget: string;
    options: { label: string; value: string }[];
    required: boolean;
    placeholder: string;
    otherValue: string;
    otherField: string;
    multiple: boolean;
    minimum?: number;
    maximum?: number;
    isInteger: boolean;
  }

  export default {
    name: "McpAskQuestionCard",
    props: {
      interaction: {
        type: Object as () => McpAskInteraction,
        required: true,
      },
    },
    emits: ["respond"],
    data() {
      return {
        formData: {} as Record<string, unknown>,
        fileData: {} as Record<string, UploadFileInfo[]>,
        currentStep: 0,
      };
    },
    mounted() {
      this.initializeFormData();
    },
    watch: {
      "interaction.requestId"() {
        this.currentStep = 0;
        this.initializeFormData();
      },
      "interaction.revision"() {
        this.currentStep = 0;
        this.initializeFormData();
      },
    },
    computed: {
      parsedFields(): ParsedField[] {
        const ui = this.interaction?.ui;
        if (!ui) return [];

        return parseInteractionFields(ui).map(
          (field: ParsedMcpAskField): ParsedField => this.toParsedField(field),
        );
      },
      steps(): InteractionUiStep[] {
        const ui = this.interaction?.ui;
        if (!ui) return [];
        return getInteractionSteps(ui);
      },
      isWizard(): boolean {
        const ui = this.interaction?.ui;
        if (!ui) return false;
        return (
          isWizardPresentation(ui) && this.steps.length > 1
        );
      },
      activeStepTitle(): string {
        return (
          this.steps[this.currentStep]?.title ||
          this.interaction.ui?.title ||
          ""
        );
      },
      wizardProgressText(): string {
        return `${this.currentStep + 1}/${this.steps.length}`;
      },
      requiredMark(): string {
        return "*";
      },
      activeStepDescription(): string {
        return this.steps[this.currentStep]?.description || "";
      },
      visibleFields(): ParsedField[] {
        if (!this.isWizard) return this.parsedFields;
        const activeStep = this.steps[this.currentStep];
        if (!activeStep) return this.parsedFields;
        const names = activeStep.fields || [];
        return this.parsedFields.filter((field: ParsedField): boolean =>
          names.includes(field.name),
        );
      },
      isLastStep(): boolean {
        return this.currentStep >= this.steps.length - 1;
      },
      allowSkip(): boolean {
        const ui = this.interaction?.ui;
        if (!ui) return false;
        return isSkipAllowed(ui);
      },
      skipLabel(): string {
        const ui = this.interaction?.ui;
        if (!ui) return t("Mobile.Intervention.McpAsk.skip");
        return (
          getSkipLabel(ui) ||
          t("Mobile.Intervention.McpAsk.skip")
        );
      },
      statusLabel(): string {
        const status = this.interaction?.responseStatus;
        if (status === "submitted")
          return t("Mobile.Intervention.McpAsk.submitted");
        if (status === "cancelled")
          return t("Mobile.Intervention.McpAsk.cancelled");
        if (status === "skipped")
          return t("Mobile.Intervention.McpAsk.skipped");
        if (status === "timeout")
          return t("Mobile.Intervention.McpAsk.timeout");
        // failed 状态不展示标签（对齐 PC 端），但防御性保留文字
        if (status === "failed")
          return this.interaction?.errorMessage || "";
        return "";
      },
    },
    methods: {
      t,
      toParsedField(field: ParsedMcpAskField): ParsedField {
        const options = field.enumValues.map(
          (value: string, index: number) => ({
            label: field.enumLabels[index] || value,
            value: value,
          }),
        );
        return {
          name: field.name,
          label: field.property.title || field.name,
          widget: field.widget,
          options: options,
          required: field.required,
          placeholder: field.options.placeholder || "",
          otherValue: field.options.otherValue || "__custom__",
          otherField: field.options.otherField || `${field.name}Custom`,
          multiple:
            field.options.multiple === true || field.property.type === "array",
          minimum:
            typeof field.property.minimum === "number"
              ? field.property.minimum
              : undefined,
          maximum:
            typeof field.property.maximum === "number"
              ? field.property.maximum
              : undefined,
          isInteger: field.isInteger,
        };
      },
      formatNumberValue(value: unknown): string {
        if (value === null || value === undefined || value === "") {
          return "";
        }
        return String(value);
      },
      initializeFormData() {
        const ui = this.interaction?.ui;
        const rawFields = ui?.fields;
        const fields = Array.isArray(rawFields)
          ? (rawFields as McpAskFormField[])
          : [];
        const fieldInitials = {} as Record<string, unknown>;
        fields.forEach((f: McpAskFormField) => {
          if (f.initialValue !== undefined && f.initialValue !== null) {
            fieldInitials[f.name] = f.initialValue;
          }
        });
        const initial =
          (Object.keys(fieldInitials).length > 0
            ? fieldInitials
            : this.interaction?.formData) || {};
        this.formData = { ...initial };
        this.fileData = {};
      },
      onTextInput(name: string, event: any) {
        this.formData[name] = event.detail?.value || event.target?.value || "";
      },
      onNumberInput(name: string, event: any) {
        const raw = (
          event.detail?.value ??
          event.target?.value ??
          ""
        ).trim();
        if (raw === "") {
          this.formData[name] = "";
          return;
        }
        const num = Number(raw);
        this.formData[name] = Number.isNaN(num) ? raw : num;
      },
      onRadioSelect(name: string, value: string) {
        this.formData[name] = value;
      },

      // ==================== 文件上传 ====================

      getFileList(fieldName: string): UploadFileInfo[] {
        return this.fileData[fieldName] || [];
      },

      getUploadCount(field: ParsedField): number {
        const existingCount = this.getFileList(field.name).length;
        if (!field.multiple && existingCount > 0) return 0;
        return field.multiple ? Math.max(9 - existingCount, 0) : 1;
      },

      chooseAndUpload(field: ParsedField, type: "image" | "file") {
        const count = this.getUploadCount(field);
        if (count <= 0) {
          uni.showToast({
            title: t("Mobile.Intervention.McpAsk.singleFileOnly"),
            icon: "none",
          });
          return;
        }

        if (type === "image") {
          uni.chooseImage({
            count,
            sizeType: ["original", "compressed"],
            sourceType: ["album", "camera"],
            success: (res) => {
              this.uploadFiles(field.name, res.tempFilePaths);
            },
          });
        } else {
          uni.chooseFile({
            count,
            success: (res) => {
              this.uploadFiles(field.name, res.tempFilePaths);
            },
          });
        }
      },

      async uploadFiles(fieldName: string, filePaths: string[]) {
        // 初始化字段文件列表
        if (!this.fileData[fieldName]) {
          this.fileData[fieldName] = [];
        }

        for (const filePath of filePaths) {
          const uid = generateFileUid();
          const fileName = filePath.split("/").pop() || "file";

          // 添加上传中的占位条目
          const placeholder: UploadFileInfo = {
            key: "",
            name: fileName,
            type:
              filePath.includes(".png") ||
              filePath.includes(".jpg") ||
              filePath.includes(".jpeg") ||
              filePath.includes(".gif")
                ? "image/jpeg"
                : "application/octet-stream",
            size: 0,
            url: filePath,
            uid: uid,
            status: UploadFileStatus.uploading,
            percent: 0,
          };
          this.fileData[fieldName] = [...this.fileData[fieldName], placeholder];

          // 执行上传
          const result = await uploadSingleFile(filePath, uid, (percent) => {
            const list = this.fileData[fieldName];
            if (!list) return;
            const idx = list.findIndex((f) => f.uid === uid);
            if (idx >= 0) {
              list[idx] = { ...list[idx], percent: percent };
              this.fileData[fieldName] = [...list];
            }
          });

          // 更新条目状态
          const list = this.fileData[fieldName];
          if (!list) continue;
          const idx = list.findIndex((f) => f.uid === uid);
          if (idx >= 0) {
            if (result.success && result.file) {
              list[idx] = result.file;
            } else {
              list[idx] = { ...list[idx], status: UploadFileStatus.error };
            }
            this.fileData[fieldName] = [...list];
          }
        }
      },

      removeFile(fieldName: string, uid: string) {
        const list = this.fileData[fieldName] || [];
        this.fileData[fieldName] = list.filter((f) => f.uid !== uid);
      },

      getUploadPercentText(file: UploadFileInfo): string {
        return `${file.percent || 0}%`;
      },

      /**
       * 将文件数据转换为 AttachmentFile 格式存入 formData
       */
      syncFileDataToForm() {
        for (const fieldName of Object.keys(this.fileData)) {
          const files = this.fileData[fieldName] || [];
          const doneFiles = files.filter(
            (f) => f.status === UploadFileStatus.done,
          );
          if (doneFiles.length > 0) {
            const attachments: AttachmentFile[] = doneFiles.map((f) => ({
              fileKey: f.key || "",
              fileUrl: f.url || "",
              fileName: f.name || "",
              mimeType: f.type || "",
              fileSize: f.size || 0,
            }));
            this.formData[fieldName] = attachments;
          }
        }
      },

      isEmptyValue(value: unknown): boolean {
        if (value === null || value === undefined || value === "") return true;
        if (Array.isArray(value) && value.length === 0) return true;
        return false;
      },

      validateFields(fields: ParsedField[]): boolean {
        for (const field of fields) {
          if (field.required && this.isEmptyValue(this.formData[field.name])) {
            uni.showToast({
              title: `${field.label}${t("Mobile.Intervention.McpAsk.requiredSuffix")}`,
              icon: "none",
            });
            return false;
          }
          if (
            field.widget === "number" &&
            !this.isEmptyValue(this.formData[field.name])
          ) {
            const num = Number(this.formData[field.name]);
            if (Number.isNaN(num)) {
              uni.showToast({
                title: `${field.label}${t("Mobile.Intervention.McpAsk.invalidNumberSuffix")}`,
                icon: "none",
              });
              return false;
            }
            if (field.isInteger && !Number.isInteger(num)) {
              uni.showToast({
                title: `${field.label}${t("Mobile.Intervention.McpAsk.integerNumberSuffix")}`,
                icon: "none",
              });
              return false;
            }
            if (field.minimum != null && num < field.minimum) {
              uni.showToast({
                title: `${field.label}${t("Mobile.Intervention.McpAsk.minNumberSuffix")}${field.minimum}`,
                icon: "none",
              });
              return false;
            }
            if (field.maximum != null && num > field.maximum) {
              uni.showToast({
                title: `${field.label}${t("Mobile.Intervention.McpAsk.maxNumberSuffix")}${field.maximum}`,
                icon: "none",
              });
              return false;
            }
          }
          if (
            field.widget === "radio-with-custom" &&
            this.formData[field.name] === field.otherValue &&
            this.isEmptyValue(this.formData[field.otherField])
          ) {
            uni.showToast({
              title: `${field.label}${t("Mobile.Intervention.McpAsk.requiredSuffix")}`,
              icon: "none",
            });
            return false;
          }
        }
        return true;
      },

      handleNext() {
        if (!this.validateFields(this.visibleFields)) return;
        this.currentStep = Math.min(
          this.currentStep + 1,
          this.steps.length - 1,
        );
      },

      handlePrev() {
        this.currentStep = Math.max(this.currentStep - 1, 0);
      },

      handleSubmit() {
        this.syncFileDataToForm();
        if (!this.validateFields(this.parsedFields)) return;
        this.$emit(
          "respond",
          this.buildRespondPayload("submit", { ...this.formData }),
        );
      },
      handleCancel() {
        this.$emit("respond", this.buildRespondPayload("cancel"));
      },
      handleSkip() {
        this.$emit("respond", this.buildRespondPayload("skip"));
      },
      /**
       * 构建 MCP Ask 响应 payload，统一 submit / cancel / skip 公共字段
       */
      buildRespondPayload(
        action: "submit" | "cancel" | "skip",
        formData?: Record<string, unknown>,
      ): McpAskRespondPayload {
        const payload: McpAskRespondPayload = {
          interventionId: this.interaction.requestId,
          toolCallId: this.interaction.toolCallId,
          revision: this.interaction.revision || 1,
          source: "mcp_ask",
          protocol: "mcp",
          action: action,
          answeredBy: { kind: "mobile" },
          answeredAt: Date.now(),
        };
        if (formData != null) {
          payload.formData = formData;
        }
        return payload;
      },
    },
  };
</script>

<style lang="scss" scoped>
  // 卡片容器及公共布局变量
  $card-bg-color: #fff;
  $card-border-radius: 16rpx;
  $card-padding: 24rpx;
  $card-margin: 8rpx;
  $card-box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  // 基础状态颜色
  $primary-color: #1677ff;
  $success-color: #52c41a;
  $warning-color: #faad14;
  $danger-color: #ff4d4f;
  $cancel-color: #999;

  // 灰色与辅助颜色背景
  $bg-gray-light: #f7f9fc;
  $bg-gray-tag: #f0f0f0;
  $bg-gray-file: #fafafa;
  $bg-mask: rgba(0, 0, 0, 0.5);

  // 字体颜色
  $text-color-primary: #1a1a1a;
  $text-color-secondary: #666;
  $text-color-light: #fff;
  $text-wizard-title: #1f2937;
  $text-wizard-desc: #6b7280;
  $text-field-label: #333;

  // 边框颜色
  $border-color: #e0e0e0;
  $border-color-light: #d0d0d0;

  // 尺寸与圆角倒角
  $field-border-radius: 12rpx;
  $button-border-radius: 12rpx;
  $button-border-radius-double: 24rpx;

  .mcp-ask-card {
    background-color: $card-bg-color;
    border-radius: $card-border-radius;
    padding: $card-padding;
    margin: $card-margin;
    box-shadow: $card-box-shadow;
    max-height: 50vh;
    display: flex;
    flex-direction: column;

    .card-error-msg {
      font-size: 24rpx;
      color: $danger-color;
      padding-top: 12rpx;
      display: block;
    }

    .card-header {
      margin-bottom: 20rpx;

      .card-eyebrow {
        font-size: 22rpx;
        font-weight: 500;
        color: $primary-color;
        margin-bottom: 6rpx;
        display: block;
      }

      .card-title {
        font-size: 32rpx;
        font-weight: 600;
        color: $text-color-primary;
      }

      .card-desc {
        font-size: 26rpx;
        color: $text-color-secondary;
        margin-top: 8rpx;
      }
    }

    .status-tag {
      display: flex;
      flex-direction: row;
      align-items: center;
      padding: 12rpx 16rpx;
      border-radius: 8rpx;
      background-color: $bg-gray-tag;
      margin-bottom: 16rpx;

      .status-icon {
        font-size: 28rpx;
        margin-right: 8rpx;

        &.status-icon-success {
          color: $success-color;
        }

        &.status-icon-cancelled {
          color: $cancel-color;
        }

        &.status-icon-skipped {
          color: $warning-color;
        }
      }

      .status-tag-text {
        font-size: 24rpx;
        color: $text-color-secondary;
      }
    }

    .card-form {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;

      .wizard-steps-block {
        margin-bottom: 16rpx;

        .wizard-step-row {
          display: flex;
          flex-direction: row;
          align-items: flex-start;

          .wizard-step-cell {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;

            .step-icon-row {
              width: 100%;
              display: flex;
              flex-direction: row;
              align-items: center;

              .step-connector-half {
                flex: 1;
                height: 2rpx;
                background-color: $border-color;

                &.step-connector-active {
                  background-color: $primary-color;
                }
              }

              .step-circle {
                flex-shrink: 0;
                width: 40rpx;
                height: 40rpx;
                border-radius: 20rpx;
                border: 2rpx solid $border-color-light;
                display: flex;
                align-items: center;
                justify-content: center;

                &.step-circle-done {
                  background-color: $primary-color;
                  border-color: $primary-color;
                }

                &.step-circle-active {
                  border-color: $primary-color;

                  .step-num-text {
                    color: $primary-color;
                    font-weight: 600;
                  }
                }

                .step-check-icon {
                  font-size: 22rpx;
                  color: $text-color-light;
                }

                .step-num-text {
                  font-size: 22rpx;
                  color: $text-color-secondary;
                }
              }
            }

            .step-label {
              margin-top: 8rpx;
              font-size: 20rpx;
              color: $text-color-secondary;
              text-align: center;

              &.step-label-active {
                color: $primary-color;
                font-weight: 500;
              }
            }
          }
        }

        .step-callout {
          margin-top: 12rpx;
          padding: 12rpx 16rpx;
          border-radius: $field-border-radius;
          background-color: $bg-gray-light;

          .step-callout-text {
            font-size: 24rpx;
            color: $text-wizard-desc;
          }
        }
      }

      .card-form-scroll {
        flex: 1;
        margin-bottom: 16rpx;
      }

      .form-field {
        margin-bottom: 24rpx;

        .field-label {
          font-size: 28rpx;
          color: $text-field-label;
          margin-bottom: 12rpx;
          font-weight: 500;

          .field-required {
            color: $danger-color;
            margin-left: 4rpx;
          }
        }

        .field-input {
          width: 100%;
          border: 2rpx solid $border-color;
          border-radius: $field-border-radius;
          padding: 16rpx 20rpx;
          font-size: 28rpx;

          &.custom-input {
            margin-top: 12rpx;
          }
        }

        .field-textarea {
          width: 100%;
          border: 2rpx solid $border-color;
          border-radius: $field-border-radius;
          padding: 16rpx 20rpx;
          font-size: 28rpx;
          min-height: 160rpx;
        }

        /* 单选列表（样式类似 checkboxes） */
        .field-list-group {
          display: flex;
          flex-direction: column;
          gap: 8rpx;

          .list-option {
            display: flex;
            flex-direction: row;
            align-items: center;
            padding: 8rpx 0;

            .list-radio-dot {
              width: 32rpx;
              height: 32rpx;
              border-radius: 50%;
              border: 2rpx solid $border-color-light;
              margin-right: 12rpx;
              display: flex;
              align-items: center;
              justify-content: center;

              &.dot-selected {
                border-color: $primary-color;
                background-color: $primary-color;
              }

              .dot-check-icon {
                font-size: 20rpx;
                color: $text-color-light;
                font-weight: bold;
                line-height: 1;
                padding: 0;
                margin: 0;
              }
            }

            .list-label {
              font-size: 28rpx;
              color: $text-field-label;
            }
          }
        }

        /* 文件上传 */
        .field-file-area {
          display: flex;
          flex-direction: column;
          gap: 16rpx;

          .file-list {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 16rpx;

            .file-item {
              position: relative;
              width: 160rpx;
              height: 160rpx;
              border-radius: $field-border-radius;
              overflow: hidden;
              border: 2rpx solid $border-color;

              .file-thumb {
                width: 100%;
                height: 100%;
              }

              .file-doc {
                width: 100%;
                height: 100%;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                background-color: $bg-gray-file;
                padding: 12rpx;

                .file-doc-icon {
                  font-size: 48rpx;
                  color: $primary-color;
                  margin-bottom: 8rpx;
                }

                .file-doc-name {
                  font-size: 20rpx;
                  color: $text-color-secondary;
                  text-align: center;
                  overflow: hidden;
                  text-overflow: ellipsis;
                  white-space: nowrap;
                  max-width: 100%;
                }
              }

              .file-remove {
                position: absolute;
                top: 4rpx;
                right: 4rpx;
                width: 40rpx;
                height: 40rpx;
                background-color: $bg-mask;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: $text-color-light;
                font-size: 24rpx;
              }

              .file-uploading-mask {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background-color: $bg-mask;
                display: flex;
                align-items: center;
                justify-content: center;

                .file-uploading-text {
                  color: $text-color-light;
                  font-size: 24rpx;
                  font-weight: 600;
                }
              }
            }
          }

          .file-upload-actions {
            display: flex;
            flex-direction: row;
            gap: 16rpx;

            .file-upload-btn {
              flex: 1;
              display: flex;
              flex-direction: row;
              align-items: center;
              justify-content: center;
              gap: 8rpx;
              padding: 20rpx 0;
              border: 2rpx dashed $border-color-light;
              border-radius: $field-border-radius;
              color: $text-color-secondary;
              font-size: 28rpx;

              .file-upload-btn-text {
                font-size: 28rpx;
                color: $text-color-secondary;
              }
            }
          }
        }
      }

      .form-actions {
        flex-shrink: 0;
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16rpx;
        margin-top: 24rpx;

        .action-button {
          flex: 1 1 0;
          min-width: 160rpx;
        }
      }
    }
  }

  /* #ifndef APP-ANDROID || APP-IOS || APP-HARMONY */
  ::v-deep .l-button {
    border: 0 !important;
    border-radius: $button-border-radius !important;
    overflow: visible !important;
  }
  ::v-deep .l-button::after {
    border-radius: $button-border-radius-double !important;
  }
  /* #endif */
</style>

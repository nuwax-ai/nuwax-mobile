<template>
  <acp-permission-card
    v-if="kind === 'acp_permission' && acpInteraction"
    :interaction="acpInteraction"
    @respond="handleAcpRespond"
  />
  <mcp-ask-question-card
    v-else-if="kind === 'mcp_ask' && mcpInteraction"
    :interaction="mcpInteraction"
    @respond="handleMcpRespond"
  />
</template>

<script lang="uts">
/**
 * 干预卡片调度器
 * 按 kind 分发到 ACP 权限审批或 MCP Ask 子卡片
 * 对齐 Web 版 InterventionDockPanel.renderCard
 * 详见 components/agent-intervention/README.md
 */
import AcpPermissionCard from '@/components/agent-intervention/acp-permission-card/acp-permission-card.uvue'
import McpAskQuestionCard from '@/components/agent-intervention/mcp-ask-question-card/mcp-ask-question-card.uvue'
import type {
  AcpPermissionInteraction,
  AcpPermissionResponse,
  McpAskInteraction,
  McpAskRespondPayload,
} from '@/types/intervention'

export type InterventionCardKind = 'acp_permission' | 'mcp_ask'

export default {
  name: 'InterventionCard',
  components: {
    AcpPermissionCard,
    McpAskQuestionCard,
  },
  props: {
    kind: {
      type: String as () => InterventionCardKind,
      required: true,
    },
    acpInteraction: {
      type: Object as () => AcpPermissionInteraction | null,
      default: null,
    },
    mcpInteraction: {
      type: Object as () => McpAskInteraction | null,
      default: null,
    },
  },
  emits: ['respond-acp', 'respond-mcp'],
  methods: {
    handleAcpRespond(response: AcpPermissionResponse) {
      this.$emit('respond-acp', response)
    },
    handleMcpRespond(payload: McpAskRespondPayload) {
      this.$emit('respond-mcp', payload)
    },
  },
}
</script>

          color: rgba(21, 23, 31, 0.5);
          font-size: 28rpx;
          font-weight: 400;
        }

        .clear-icon {
          font-size: 32rpx;
          color: #999 !important;
          cursor: pointer;
        }
      }

      .cancel-text {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 76rpx;
        font-weight: 400;
        padding: 0 32rpx;
        color: rgba(21, 23, 31, 0.5);

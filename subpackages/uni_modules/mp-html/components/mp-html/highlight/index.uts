/**
 * @fileoverview highlight 插件 (UTS stub for app-android)
 * PrismJS 不兼容 UTS，原生端禁用语法高亮。实现 MpHtmlPlugin 以安全通过 parser 分发。
 */
import { MpHtmlPlugin, Parser } from '../parser.uts'

export default class Highlight implements MpHtmlPlugin {
  vm: UTSJSONObject

  constructor(vm: any) {
    this.vm = vm as UTSJSONObject
  }

  onUpdate(content: string, config: UTSJSONObject): string {
    return content
  }

  onParse(node: UTSJSONObject, parser: Parser): boolean {
    return true
  }
}

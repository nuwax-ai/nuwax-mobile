/**
 * @fileoverview latex 插件 (UTS stub for app-android)
 * KaTeX 不兼容 UTS，原生端禁用 LaTeX 渲染。实现 MpHtmlPlugin 以安全通过 parser 分发。
 */
import { MpHtmlPlugin, Parser } from '../parser.uts'

export default class Latex implements MpHtmlPlugin {
  constructor(vm: any) {}

  onUpdate(content: string, config: UTSJSONObject): string {
    return content
  }

  onParse(node: UTSJSONObject, parser: Parser): boolean {
    return true
  }
}

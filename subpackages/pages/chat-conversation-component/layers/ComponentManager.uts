import { nextTick } from 'vue'
import { MessageInfo } from '@/types/interfaces/conversationInfo'
import { MessageTypeEnum } from '@/types/enums/agent'
import { MessageStatusEnum } from '@/types/enums/common'
import AgentDetailData from './AgentDetailData'

/**
 * 组件管理层：负责组件的引用管理和更新
 */
export default class ComponentManager {
  private data: AgentDetailData;
  constructor(data: AgentDetailData) {
    this.data = data;
  }

  /**
   * 设置消息组件引用
   */
  setMessageRef(el: any, messageId: string): void {
    if (el != null) {
      (this.data.messageRefs.value as UTSJSONObject)[messageId] = el;
    }
  }

  /**
   * 移除消息组件引用
   */
  removeMessageRef(messageId: string): void {
    const refs = this.data.messageRefs.value as UTSJSONObject;
    const existing = refs[messageId];
    if (existing != null) {
      // UTS 不支持 delete 操作符，置 null 让响应式系统感知
      refs[messageId] = null;
    }
  }

  /**
   * 更新消息组件
   */
  async updateMessageComponent(messageId: string, newData: any): Promise<void> {
    const messageRef = (this.data.messageRefs.value as UTSJSONObject)[messageId];
    if (messageRef != null) {
      const refObj = messageRef as UTSJSONObject;
      const updater = refObj["updateMessage"];
      try {
        if (updater != null) {
          await (updater as (d: any) => Promise<void>)(newData);
        } else {
          // 备用方案：强制触发组件更新
          await nextTick();
          const message = this.findMessageById(messageId);
          if (message != null) {
            const msgObj = message as UTSJSONObject;
            msgObj["lastUpdateTime"] = new Date().getTime();
            this.data.messageList.value = this.data.messageList.value.slice();
          }
        }
      } catch (error) {
        console.error(`更新消息组件 ${messageId} 失败:`, error);
        // 错误恢复：使用备用方案
        try {
          await nextTick();
          const message = this.findMessageById(messageId);
          if (message != null) {
            const msgObj = message as UTSJSONObject;
            msgObj["lastUpdateTime"] = new Date().getTime();
            this.data.messageList.value = this.data.messageList.value.slice();
          }
        } catch (backupError) {
          console.error('备用方案也失败了:', backupError);
        }
      }
    }
  }

  findMessageById(messageId: string): MessageInfo | null {
    const list = this.data.messageList.value;
    if (list == null) {
      return null;
    }
    const len = list.length;
    for (let i = 0; i < len; i++) {
      if (list[i].id == messageId) {
        return list[i];
      }
    }
    return null;
  }

  /**
   * 根据状态枚举确定状态
   */
  determineState(status: MessageStatusEnum): number {
    if (status == MessageStatusEnum.Loading) {
      return 1;
    } else if (status == MessageStatusEnum.Incomplete) {
      return 2;
    } else if (status == MessageStatusEnum.Complete) {
      return 3;
    } else {
      const statusStr = `${status}`;
      if (statusStr == "error" || statusStr == "Error") {
        return 4;
      }
      return 3;
    }
  }

  /**
   * 将MessageInfo转换为MsgItem格式
   */
  convertMessageInfoToMsgItem(messageInfo: MessageInfo): any {
    const idStr = messageInfo.id != null ? `${messageInfo.id}` : '';
    const thinkStr = (messageInfo.think != null && (messageInfo.think as string).length > 0) ? (messageInfo.think as string) : '';
    const textStr = (messageInfo.text != null && (messageInfo.text as string).length > 0) ? (messageInfo.text as string) : '';
    const timeStr = (messageInfo.time != null && (messageInfo.time as string).length > 0) ? (messageInfo.time as string) : `${new Date().getTime()}`;
    const processingArr = messageInfo.processingList != null ? (messageInfo.processingList as any[]) : ([] as any[]);
    const result: UTSJSONObject = {
      _id: idStr,
      from_uid: messageInfo.messageType == MessageTypeEnum.ASSISTANT ? 'uni-ai' : 'user',
      thinkContent: thinkStr,
      body: textStr,
      create_time: new Date(timeStr).getTime(),
      state: messageInfo.status != null ? this.determineState(messageInfo.status as MessageStatusEnum) : 3,
      chat_id: `chat-${this.data.conversationId.value}`,
      rendered: false,
      processingList: processingArr,
    };
    return result;
  }
}

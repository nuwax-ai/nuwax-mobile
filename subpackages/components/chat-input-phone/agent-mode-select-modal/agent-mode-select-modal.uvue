<template>
  <radio-list-drawer
    :visible="visible"
    :title="t('Mobile.Chat.agentModeSelect')"
    :list="agentModeOptions"
    :current-value="currentAgentMode"
    :readonly="readonly"
    @onClose="handleClose"
    @onChange="handleAgentModeChange"
  />
</template>

<script lang="uts" setup>
  import { RadioListItem } from "@/types/interfaces/radio";
  import RadioListDrawer from "@/components/radio-list-drawer/radio-list-drawer.uvue";
  import { useI18n } from "@/utils/i18n";

  type AgentMode = "ask" | "yolo";

  const { t } = useI18n();

  const props = withDefaults(
    defineProps<{
      visible: boolean;
      currentAgentMode?: AgentMode;
      readonly?: boolean;
    }>(),
    {
      visible: false,
      currentAgentMode: "yolo",
      readonly: false,
    },
  );

  const emit = defineEmits<{
    onClose: () => void;
    onAgentModeChange: (mode: AgentMode) => void;
  }>();

  const agentModeOptions = computed((): RadioListItem[] => {
    return [
      {
        value: "yolo",
        label: t("Mobile.Chat.agentModeYoloLabel"),
        desc: t("Mobile.Chat.agentModeYoloDescription"),
      },
      {
        value: "ask",
        label: t("Mobile.Chat.agentModeAskLabel"),
        desc: t("Mobile.Chat.agentModeAskDescription"),
      },
    ];
  });

  const handleClose = () => {
    emit("onClose");
  };

  const handleAgentModeChange = (value: string) => {
    if (value === "yolo" || value === "ask") {
      emit("onAgentModeChange", value as AgentMode);
    }
  };
</script>

<style lang="scss" scoped>
</style>

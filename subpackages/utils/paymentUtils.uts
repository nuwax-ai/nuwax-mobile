/**
 * 将 h5OrderId 拼接至指定的 URL 中（自动判定并解析 hash 或 search 参数位置）
 */
export function appendH5OrderIdToUrl(url: string, orderId: number): string {
  const hashIndex = url.indexOf("#");
  if (hashIndex !== -1) {
    const baseUrlPart = url.substring(0, hashIndex);
    const hashPart = url.substring(hashIndex);
    const qIndex = hashPart.indexOf("?");
    if (qIndex !== -1) {
      return baseUrlPart + hashPart + "&h5OrderId=" + orderId;
    } else {
      return baseUrlPart + hashPart + "?h5OrderId=" + orderId;
    }
  } else {
    const qIndex = url.indexOf("?");
    if (qIndex !== -1) {
      return url + "&h5OrderId=" + orderId;
    } else {
      return url + "?h5OrderId=" + orderId;
    }
  }
}

/**
 * 在 H5 端渲染微信支付二维码 Modal，并在后台发起结算状态轮询
 */
export async function renderQrCodeModal(
  qrCodeContent: string,
  orderId: number,
  t: (key: string) => string,
  onSuccess?: () => void,
  onClose?: () => void,
): Promise<void> {
  const overlay = document.createElement("div");
  overlay.id = "pay-qrcode-modal";
  overlay.style.position = "fixed";
  overlay.style.top = "0";
  overlay.style.left = "0";
  overlay.style.right = "0";
  overlay.style.bottom = "0";
  overlay.style.backgroundColor = "rgba(0, 0, 0, 0.65)";
  overlay.style.display = "flex";
  overlay.style.justifyContent = "center";
  overlay.style.alignItems = "center";
  overlay.style.zIndex = "999999";
  overlay.style.backdropFilter = "blur(4px)";
  overlay.style.transition = "opacity 0.2s ease";
  overlay.style.opacity = "0";

  const card = document.createElement("div");
  card.style.backgroundColor = "#ffffff";
  card.style.borderRadius = "16px";
  card.style.padding = "24px";
  card.style.display = "flex";
  card.style.flexDirection = "column";
  card.style.alignItems = "center";
  card.style.width = "280px";
  card.style.boxSizing = "border-box";
  card.style.position = "relative";
  card.style.boxShadow = "0 8px 30px rgba(0, 0, 0, 0.15)";
  card.style.transform = "scale(0.9)";
  card.style.transition = "transform 0.2s ease, opacity 0.2s ease";

  const closeBtn = document.createElement("span");
  closeBtn.innerHTML = "×";
  closeBtn.style.position = "absolute";
  closeBtn.style.top = "4px";
  closeBtn.style.right = "14px";
  closeBtn.style.fontSize = "28px";
  closeBtn.style.color = "#999999";
  closeBtn.style.cursor = "pointer";
  closeBtn.style.lineHeight = "1";

  const title = document.createElement("h3");
  title.innerHTML = t("Mobile.MySubscriptions.wechatPay");
  title.style.margin = "0 0 16px 0";
  title.style.fontSize = "16px";
  title.style.fontWeight = "600";
  title.style.color = "#111111";

  const img = document.createElement("img");
  const encodedData = encodeURIComponent(qrCodeContent);
  img.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodedData}`;
  img.style.width = "200px";
  img.style.height = "200px";
  img.style.marginBottom = "16px";
  img.style.borderRadius = "8px";

  const desc = document.createElement("p");
  desc.innerHTML = t("Mobile.MySubscriptions.qrCodeUnsupported");
  desc.style.margin = "0";
  desc.style.fontSize = "13px";
  desc.style.color = "#666666";
  desc.style.textAlign = "center";
  desc.style.lineHeight = "1.5";

  card.appendChild(closeBtn);
  card.appendChild(title);
  card.appendChild(img);
  card.appendChild(desc);
  overlay.appendChild(card);
  document.body.appendChild(overlay);

  setTimeout(() => {
    overlay.style.opacity = "1";
    card.style.transform = "scale(1)";
  }, 10);

  const closeHandler = () => {
    card.style.transform = "scale(0.9)";
    overlay.style.opacity = "0";
    setTimeout(() => {
      if (document.body.contains(overlay)) {
        document.body.removeChild(overlay);
      }
    }, 200);
    onClose?.();
  };

  closeBtn.onclick = closeHandler;
  overlay.onclick = (e) => {
    if (e.target === overlay) {
      closeHandler();
    }
  };

  uni.showLoading({
    title: t("Mobile.MySubscriptions.payPending"),
    mask: true,
  });
  const payStatus = await pollPayResult(orderId);
  uni.hideLoading();

  closeHandler();
}

/**
 * 校验并提示 URL 中的支付结果（如第三方渠道回跳回来的结果）
 */
export function checkPayResult(
  t: (key: string) => string,
  onSuccess?: () => void,
): void {
  const { payResult, orderId } = parsePayResultFromUrl();
  if (payResult !== "") {
    const alertKey = `${orderId}_${payResult}`;
    if (alertedKeys.has(alertKey)) return;
    alertedKeys.add(alertKey);

    handlePayResultToast(payResult, t, onSuccess);
    cleanUrlParams();
  }
}

/**
 * 校验微信公众号授权回跳的支付流程与自动轮询状态
 */
export async function checkWechatOaPayCallback(
  processingId: Ref<number | null>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  const search = window.location.search;
  const hash = window.location.hash;
  let code = "";
  let state = "";

  // 优先从 main search 中解析
  if (search !== "") {
    const searchParams = new URLSearchParams(search);
    code = searchParams.get("code") || "";
    state = searchParams.get("state") || "";
  }

  // 若无，从 hash search 中解析
  if (code === "") {
    const qIndex = hash.indexOf("?");
    if (qIndex !== -1) {
      const hashSearch = hash.substring(qIndex);
      const hashParams = new URLSearchParams(hashSearch);
      code = hashParams.get("code") || "";
      state = hashParams.get("state") || "";
    }
  }

  if (code !== "" && state !== "") {
    const orderId = parseInt(state);
    if (isNaN(orderId)) return;

    const lockKey = `wx_pay_lock_${orderId}_${code}`;
    if (uni.getStorageSync(lockKey) === "1") return;
    uni.setStorageSync(lockKey, "1");

    // 清除 URL 中的 wechat code 和 state 参数（避免刷新重复发起支付）
    cleanWechatOaParams();

    processingId.value = orderId;
    uni.showLoading({
      title: t("Mobile.MySubscriptions.payPending"),
      mask: true,
    });

    try {
      const payParamsRes = await apiPayWechatJsapi({
        wxOAuthCode: code,
        orderId: orderId,
      });

      if (
        payParamsRes.code === SUCCESS_CODE &&
        payParamsRes.data?.wxPayParams != null
      ) {
        const wxPayParams = payParamsRes.data.wxPayParams;
        uni.hideLoading();

        // 调起微信 JSAPI 支付
        const payCallRes = (await invokeJsapi(wxPayParams)) as Record<
          string,
          any
        >;
        const errMsg = (payCallRes["err_msg"] as string) || "";

        if (errMsg.indexOf("ok") !== -1) {
          uni.showLoading({
            title: t("Mobile.MySubscriptions.payPending"),
            mask: true,
          });
          // 轮询结果
          const result = await pollPayResult(orderId);
          uni.hideLoading();
          handlePayResultToast(result, t, onSuccess);
        } else if (errMsg.indexOf("cancel") !== -1) {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payCancelled"),
            icon: "none",
          });
        } else {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payFailed"),
            icon: "none",
          });
        }
      } else {
        uni.hideLoading();
        uni.showToast({
          title: payParamsRes.message || t("Mobile.MySubscriptions.payFailed"),
          icon: "none",
        });
      }
    } catch (e) {
      uni.hideLoading();
      uni.showToast({
        title: t("Mobile.MySubscriptions.payFailed"),
        icon: "none",
      });
    } finally {
      processingId.value = null;
    }
  }
}

/**
 * 校验 H5 网页微信支付回跳的支付流程与自动轮询状态
 */
export async function checkH5PayCallback(
  processingId: Ref<number | null>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  const search = window.location.search;
  const hash = window.location.hash;
  let h5OrderIdStr = "";

  if (search !== "") {
    const searchParams = new URLSearchParams(search);
    h5OrderIdStr = searchParams.get("h5OrderId") || "";
  }

  if (h5OrderIdStr === "") {
    const qIndex = hash.indexOf("?");
    if (qIndex !== -1) {
      const hashSearch = hash.substring(qIndex);
      const hashParams = new URLSearchParams(hashSearch);
      h5OrderIdStr = hashParams.get("h5OrderId") || "";
    }
  }

  if (h5OrderIdStr !== "") {
    const orderId = parseInt(h5OrderIdStr);
    if (isNaN(orderId)) return;

    const lockKey = `h5_pay_lock_${orderId}`;
    if (uni.getStorageSync(lockKey) === "1") return;
    uni.setStorageSync(lockKey, "1");

    cleanH5Params();

    processingId.value = orderId;
    uni.showLoading({
      title: t("Mobile.MySubscriptions.payPending"),
      mask: true,
    });

    try {
      const result = await pollPayResult(orderId);
      uni.hideLoading();
      handlePayResultToast(result, t, onSuccess);
    } catch (e) {
      uni.hideLoading();
      uni.showToast({
        title: t("Mobile.MySubscriptions.payFailed"),
        icon: "none",
      });
    } finally {
      processingId.value = null;
    }
  }
}

/**
 * 双重保险：校验并触发当前正在支付的本地活跃订单轮询状态
 * 解决 H5/Chrome 唤起第三方 App 支付切回时 URL 没发生改变以及 bfcache 阻断 onMounted 的极端兼容性问题
 */
export async function checkActiveOrderCallback(
  processingId: Ref<number | null>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  const activeOrderIdStr = uni.getStorageSync("ACTIVE_PAY_ORDER_ID");
  if (activeOrderIdStr) {
    const orderId = parseInt(activeOrderIdStr as string);
    if (isNaN(orderId)) return;

    // 一旦提取成功，立即清除该订单的支付中缓存，避免重复拉起轮询
    uni.removeStorageSync("ACTIVE_PAY_ORDER_ID");

    const lockKey = `h5_pay_lock_${orderId}`;
    if (uni.getStorageSync(lockKey) === "1") return;
    uni.setStorageSync(lockKey, "1");

    // 确保 URL 干净，清除可能存在的 H5 拼接参数
    cleanH5Params();

    processingId.value = orderId;
    uni.showLoading({
      title: t("Mobile.MySubscriptions.payPending"),
      mask: true,
    });

    try {
      const result = await pollPayResult(orderId);
      uni.hideLoading();
      handlePayResultToast(result, t, onSuccess);
    } catch (e) {
      uni.hideLoading();
      uni.showToast({
        title: t("Mobile.MySubscriptions.payFailed"),
        icon: "none",
      });
    } finally {
      processingId.value = null;
    }
  }
}

/**
 * 网页端（H5 / 微信公众号）支付流程统一处理入口
 */
export async function executeWebPayFlow(
  orderId: number,
  processingId: Ref<number | null>,
  loading: Ref<boolean>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  const clientEnv = detectClientEnv();
  if (clientEnv.isWeChat) {
    // 暂时不支持微信内置浏览器支付，给予友好提示并引导用户
    // await executeWebWxPayFlow(orderId, processingId, loading, t);
    uni.hideLoading();
    processingId.value = null;
    uni.showModal({
      title: t("Mobile.Common.tip"),
      content: t("Mobile.MySubscriptions.wechatBrowserPayUnsupported"),
      showCancel: false,
      confirmText: t("Mobile.Common.confirm"),
    });
  } else {
    await executeWebH5PayFlow(orderId, processingId, loading, t, onSuccess);
  }
}

/**
 * 微信公众号网页授权支付流程具体调起
 */
async function executeWebWxPayFlow(
  orderId: number,
  processingId: Ref<number | null>,
  loading: Ref<boolean>,
  t: (key: string) => string,
): Promise<void> {
  loading.value = true;
  try {
    const currentUrl = window.location.href;
    const urlObj = new URL(currentUrl);
    urlObj.searchParams.delete("code");
    urlObj.searchParams.delete("state");
    const frontReturnUrl = urlObj.toString();

    // 解决微信内置浏览器回调前端 hash 地址截断问题：先回调至后端中转，由后端重定向回 hash 页
    const callbackBase = `${window.location.origin}/api/wechat/oa/callback`;
    const redirectUri = `${callbackBase}?returnUrl=${encodeURIComponent(frontReturnUrl)}`;

    const oauthRes = await apiGetWechatOaOauthUrl({
      redirectUri,
      state: String(orderId),
    });

    if (oauthRes.code === SUCCESS_CODE && oauthRes.data != null) {
      const authorizeUrl = oauthRes.data.authorizeUrl;
      uni.hideLoading();
      window.location.href = authorizeUrl;
      setTimeout(() => {
        processingId.value = null;
      }, 300);
    } else {
      uni.hideLoading();
      uni.showToast({
        title: oauthRes.message || t("Mobile.MySubscriptions.payFailed"),
        icon: "none",
      });
      processingId.value = null;
    }
  } catch (e) {
    uni.hideLoading();
    uni.showToast({
      title: t("Mobile.MySubscriptions.payFailed"),
      icon: "none",
    });
    processingId.value = null;
  } finally {
    loading.value = false;
  }
}

/**
 * H5 网页端微信支付核心拉起逻辑（含 Form 表单自动提交、二维码展示、外部跳转）
 */
async function executeWebH5PayFlow(
  orderId: number,
  processingId: Ref<number | null>,
  loading: Ref<boolean>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  uni.hideLoading();
  uni.showActionSheet({
    itemList: [
      t("Mobile.MySubscriptions.wechatPay"),
      t("Mobile.MySubscriptions.alipay"),
    ],
    success: async (res) => {
      let payChannel = PayChannel.WxPay;
      if (res.tapIndex === 1) {
        payChannel = PayChannel.AliPay;
      }

      loading.value = true;
      uni.showLoading({
        title: t("Mobile.MySubscriptions.payPending"),
        mask: true,
      });

      try {
        const frontNotifyUrl = appendH5OrderIdToUrl(
          window.location.href,
          orderId,
        );

        // 发起支付前，将正在支付的订单 ID 写入缓存，双重保障 Chrome 唤起 App 切回或 bfcache 恢复
        uni.setStorageSync("ACTIVE_PAY_ORDER_ID", String(orderId));

        const payRes = await apiPayH5Web({
          orderId,
          payChannel,
          frontNotifyUrl,
        });

        uni.hideLoading();

        if (payRes.code === SUCCESS_CODE && payRes.data != null) {
          const payData = payRes.data as Record<string, any>;
          const invokeType = payData["invokeType"] as string;
          const formHtml = payData["formHtml"] as string | null;
          const redirectUrl = payData["redirectUrl"] as string | null;
          const qrCodeContent = payData["qrCodeContent"] as string | null;

          if (invokeType === "FORM_HTML") {
            if (formHtml == null || formHtml === "") {
              throw new Error("formHtml is empty");
            }

            const isFullHtml =
              formHtml.indexOf("<html") !== -1 ||
              formHtml.indexOf("<HTML") !== -1 ||
              formHtml.indexOf("<!DOCTYPE") !== -1 ||
              formHtml.indexOf("<!doctype") !== -1;

            if (isFullHtml) {
              document.write(formHtml);
              document.close();
              const form = document.querySelector(
                "form",
              ) as HTMLFormElement | null;
              if (form != null) {
                form.submit();
              } else {
                throw new Error("formHtml has no valid form");
              }
            } else {
              const container = document.createElement("div");
              container.style.display = "none";
              container.innerHTML = formHtml;
              document.body.appendChild(container);
              const form = container.querySelector(
                "form",
              ) as HTMLFormElement | null;
              if (form != null) {
                form.submit();
              } else {
                throw new Error("formHtml has no valid form");
              }
            }
            setTimeout(() => {
              processingId.value = null;
            }, 300);
          } else if (invokeType === "REDIRECT_URL") {
            if (redirectUrl == null || redirectUrl === "") {
              throw new Error("redirectUrl is empty");
            }
            window.location.href = redirectUrl;
            setTimeout(() => {
              processingId.value = null;
            }, 300);
          } else if (invokeType === "QRCODE_FALLBACK") {
            if (qrCodeContent != null && qrCodeContent !== "") {
              await renderQrCodeModal(
                qrCodeContent,
                orderId,
                t,
                onSuccess,
                () => {
                  processingId.value = null;
                },
              );
            } else {
              uni.showToast({
                title: t("Mobile.MySubscriptions.qrCodeUnsupported"),
                icon: "none",
              });
              processingId.value = null;
            }
          } else {
            throw new Error("unknown invokeType: " + invokeType);
          }
        } else {
          uni.showToast({
            title: payRes.message || t("Mobile.MySubscriptions.payFailed"),
            icon: "none",
          });
          processingId.value = null;
        }
      } catch (e) {
        uni.hideLoading();
        uni.showToast({
          title: t("Mobile.MySubscriptions.payFailed"),
          icon: "none",
        });
        processingId.value = null;
      } finally {
        loading.value = false;
      }
    },
    fail: () => {
      processingId.value = null;
    },
  });
}
// #endif

// ========== MP-WEIXIN 工具函数 ==========
// #ifdef MP-WEIXIN

/**
 * 获取微信登录码，每次支付前调用一次
 */
export function getWxLoginCode(): Promise<string> {
  return new Promise((resolve, reject) => {
    uni.login({
      provider: "weixin",
      success: (res) => {
        resolve(res.code);
      },
      fail: (err) => {
        reject(err);
      },
    });
  });
}

/**
 * 调起微信支付面板，返回是否支付成功
 * 取消支付和其他失败均 resolve(false)，不抛异常
 */
export function requestWxPayment(
  params: WxPayParams,
  t: (key: string) => string,
): Promise<boolean> {
  return new Promise((resolve) => {
    uni.requestPayment({
      provider: "wxpay",
      timeStamp: params.timeStamp,
      nonceStr: params.nonceStr,
      package: params.packageValue,
      signType: params.signType || "RSA",
      paySign: params.paySign,
      success: () => {
        resolve(true);
      },
      fail: (err) => {
        if (err.errCode === 700601 || err.errMsg?.includes("cancel")) {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payCancelled"),
            icon: "none",
          });
        } else {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payFailed"),
            icon: "none",
          });
          console.error("WeChat payment failed:", err);
        }
        resolve(false);
      },
    });
  });
}

/**
 * 小程序支付主流程封装：获取登录码 → 请求小程序支付参数 → 调起微信原生支付 → 后台轮询结果
 */
export async function executeMinipayFlow(
  orderId: number,
  processingId: Ref<number | null>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  processingId.value = orderId;
  uni.showLoading({
    title: t("Mobile.MySubscriptions.payPending"),
    mask: true,
  });

  try {
    const wxLoginCode = await getWxLoginCode();

    const minipayRes = await apiPayMinipay({
      orderId,
      payChannel: PayChannel.WxPay,
      wxLoginCode,
    });

    if (
      minipayRes.code !== SUCCESS_CODE ||
      minipayRes.data == null ||
      minipayRes.data!.wxPayParams == null
    ) {
      uni.hideLoading();
      uni.showToast({
        title: t("Mobile.MySubscriptions.payParamsFailed"),
        icon: "none",
      });
      return;
    }

    const wxPayParams = minipayRes.data!.wxPayParams!;
    uni.hideLoading();

    const paySuccess = await requestWxPayment(wxPayParams, t);
    if (!paySuccess) return;

    uni.showLoading({
      title: t("Mobile.MySubscriptions.payPending"),
      mask: true,
    });

    const result = await pollPayResult(orderId);
    uni.hideLoading();
    handlePayResultToast(result, t, onSuccess);
  } catch (e) {
    uni.hideLoading();
    uni.showToast({
      title: t("Mobile.MySubscriptions.payFailed"),
      icon: "none",
    });
    console.error("Mini-program payment flow error:", e);
  } finally {
    processingId.value = null;
  }
}
// #endif

// ========== 通用工具函数 ==========

/**
 * 跨端统一支付执行分流入口（自动自适应小程序或 H5/Web 环境并分发执行流程）
 */
export async function executePayFlow(
  orderId: number,
  processingId: Ref<number | null>,
  loading: Ref<boolean>,
  t: (key: string) => string,
  onSuccess?: () => void,
): Promise<void> {
  // #ifdef MP-WEIXIN
  await executeMinipayFlow(orderId, processingId, t, onSuccess);
  // #endif
  // #ifdef H5 || WEB
  await executeWebPayFlow(orderId, processingId, loading, t, onSuccess);
  // #endif
}

/**
 * 轮询结算状态，最多 10 次，间隔 2 秒
 * @returns "success" | "failed" | "pending"
 */
export async function pollPayResult(orderId: number): Promise<string> {
  const maxAttempts = 10;
  for (let i = 0; i < maxAttempts; i++) {
    await new Promise((resolve) => setTimeout(resolve, 2000));
    try {
      const res = await apiGetSettlementStatus({ orderId });
      if (res.code === SUCCESS_CODE && res.data != null) {
        const data = res.data!;
        if (
          data.settled ||
          data.orderStatus === OrderStatus.PAID ||
          data.payStatus === PayStatus.SUCCESS
        ) {
          return "success";
        }
        if (data.terminalFailed || data.orderStatus === OrderStatus.CANCELLED) {
          return "failed";
        }
      }
    } catch (e) {
      // 网络异常忽略，继续重试
    }
  }
  return "pending";
}

/**
 * 支付结果 Toast 提示，根据结果调用 onSuccess 回调
 * @param result "success" | "failed" | "pending"
 */
export function handlePayResultToast(
  result: string,
  t: (key: string) => string,
  onSuccess?: () => void,
): void {
  if (result === "success") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.paySuccess"),
      icon: "success",
    });
    onSuccess?.();
  } else if (result === "failed") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.payFailed"),
      icon: "none",
    });
  } else if (result === "pending") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.payPending"),
      icon: "none",
    });
  }
}

// 获取 payMode
export function getPayMode(): PayMode {
  // 默认是扫码
  let payMode = PayMode.scan;

  // 微信小程序
  // #ifdef MP-WEIXIN
  payMode = PayMode.minipay;
  // #endif

  // #ifdef H5 || WEB
  payMode = PayMode.h5;
  const env = detectClientEnv();
  if (env.isWeChat) {
    payMode = PayMode.minipay;
  }
  // #endif

  return payMode;
}

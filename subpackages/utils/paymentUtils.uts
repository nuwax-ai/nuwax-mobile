import { SUCCESS_CODE } from "@/constants/codes.constants.uts";
import {
  PayStatus,
  OrderStatus,
} from "@/subpackages/types/interfaces/subscription";
import type { WxPayParams } from "@/subpackages/types/interfaces/subscription";
import { apiGetSettlementStatus } from "@/subpackages/servers/subscription";
import {
  PayMode,
  PayChannel,
} from "@/subpackages/types/interfaces/subscription";

// ========== H5 / WEB 工具函数 ==========
// #ifdef H5 || WEB

/**
 * 清除 URL 中的 payResult / orderId 参数（search 和 hash 均处理）
 */
export function cleanUrlParams(): void {
  // 清空 window.location.search 中的参数
  const search = window.location.search;
  if (search !== "") {
    const params = new URLSearchParams(search);
    if (params.has("payResult") || params.has("orderId")) {
      params.delete("payResult");
      params.delete("orderId");
      const searchStr = params.toString();
      const newSearch = searchStr ? `?${searchStr}` : "";
      const newUrl =
        window.location.pathname + newSearch + window.location.hash;
      window.history.replaceState(null, "", newUrl);
    }
  }

  // 清空 window.location.hash 中的参数
  const hash = window.location.hash;
  const qIndex = hash.indexOf("?");
  if (qIndex !== -1) {
    const pathPart = hash.substring(0, qIndex);
    const hashSearch = hash.substring(qIndex);
    const params = new URLSearchParams(hashSearch);
    if (params.has("payResult") || params.has("orderId")) {
      params.delete("payResult");
      params.delete("orderId");
      const searchStr = params.toString();
      const newHash = pathPart + (searchStr ? `?${searchStr}` : "");
      const newUrl =
        window.location.pathname + window.location.search + newHash;
      window.history.replaceState(null, "", newUrl);
    }
  }
}

/**
 * 从 URL（search → hash）中解析 payResult 和 orderId
 */
export function parsePayResultFromUrl(): {
  payResult: string;
  orderId: string;
} {
  const hash = window.location.hash;
  const search = window.location.search;

  let payResult = "";
  let orderId = "";

  // 优先从 main search 上解析
  if (search !== "") {
    const searchParams = new URLSearchParams(search);
    payResult = searchParams.get("payResult") || "";
    orderId = searchParams.get("orderId") || "";
  }

  // 若无，从 hash search 中解析
  if (payResult === "") {
    const qIndex = hash.indexOf("?");
    if (qIndex !== -1) {
      const hashSearch = hash.substring(qIndex);
      const hashParams = new URLSearchParams(hashSearch);
      payResult = hashParams.get("payResult") || "";
      orderId = hashParams.get("orderId") || "";
    }
  }

  return { payResult, orderId };
}

/**
 * 检测浏览器环境（微信 / 支付宝 / 系统浏览器）
 */
export function detectClientEnv(): {
  isWeChat: boolean;
  isAlipay: boolean;
  isMobile: boolean;
  isSystemBrowser: boolean;
} {
  const ua = navigator.userAgent || "";
  const isWeChat = /MicroMessenger/i.test(ua);
  const isAlipay = /AlipayClient/i.test(ua);
  const isMobile = /Android|iPhone|iPad|iPod|Mobile/i.test(ua);

  return {
    isWeChat,
    isAlipay,
    isMobile,
    isSystemBrowser: isMobile && !isWeChat && !isAlipay,
  };
}

/**
 * 微信 JSAPI 支付唤起接口
 */
export function invokeJsapi(p: any): Promise<any> {
  const payload = {
    appId: p.appId,
    timeStamp: p.timeStamp,
    nonceStr: p.nonceStr,
    package: p.packageValue, // 注意这里要映射成 package
    signType: p.signType,
    paySign: p.paySign
  };
  return new Promise((resolve) => {
    const doInvoke = () => {
      // @ts-ignore
      if (typeof WeixinJSBridge !== 'undefined') {
        // @ts-ignore
        WeixinJSBridge.invoke('getBrandWCPayRequest', payload, (res) => {
          resolve(res);
        });
      } else {
        resolve({ err_msg: "get_brand_wcpay_request:fail" });
      }
    };
    // @ts-ignore
    if (typeof WeixinJSBridge === 'undefined') {
      document.addEventListener('WeixinJSBridgeReady', doInvoke, { once: true });
      // 超时保护
      setTimeout(() => {
        // @ts-ignore
        if (typeof WeixinJSBridge !== 'undefined') {
          doInvoke();
        } else {
          resolve({ err_msg: "get_brand_wcpay_request:fail" });
        }
      }, 3000);
    } else {
      doInvoke();
    }
  });
}

/**
 * 清除 URL 中的 wechat code 和 state 参数（避免刷新重复发起支付）
 */
export function cleanWechatOaParams(): void {
  // 清空 window.location.search 中的参数
  const search = window.location.search;
  if (search !== "") {
    const params = new URLSearchParams(search);
    if (params.has("code") || params.has("state")) {
      params.delete("code");
      params.delete("state");
      const searchStr = params.toString();
      const newSearch = searchStr ? `?${searchStr}` : "";
      const newUrl =
        window.location.pathname + newSearch + window.location.hash;
      window.history.replaceState(null, "", newUrl);
    }
  }

  // 清空 window.location.hash 中的参数
  const hash = window.location.hash;
  const qIndex = hash.indexOf("?");
  if (qIndex !== -1) {
    const pathPart = hash.substring(0, qIndex);
    const hashSearch = hash.substring(qIndex);
    const params = new URLSearchParams(hashSearch);
    if (params.has("code") || params.has("state")) {
      params.delete("code");
      params.delete("state");
      const searchStr = params.toString();
      const newHash = pathPart + (searchStr ? `?${searchStr}` : "");
      const newUrl =
        window.location.pathname + window.location.search + newHash;
      window.history.replaceState(null, "", newUrl);
    }
  }
}

/**
 * 在 H5 端渲染微信支付二维码 Modal，并在后台发起结算状态轮询
 */
export async function renderQrCodeModal(
  qrCodeContent: string,
  orderId: number,
  t: (key: string) => string,
  onSuccess?: () => void,
  onClose?: () => void
): Promise<void> {
  const overlay = document.createElement("div");
  overlay.id = "pay-qrcode-modal";
  overlay.style.position = "fixed";
  overlay.style.top = "0";
  overlay.style.left = "0";
  overlay.style.right = "0";
  overlay.style.bottom = "0";
  overlay.style.backgroundColor = "rgba(0, 0, 0, 0.65)";
  overlay.style.display = "flex";
  overlay.style.justifyContent = "center";
  overlay.style.alignItems = "center";
  overlay.style.zIndex = "999999";
  overlay.style.backdropFilter = "blur(4px)";
  overlay.style.transition = "opacity 0.2s ease";
  overlay.style.opacity = "0";

  const card = document.createElement("div");
  card.style.backgroundColor = "#ffffff";
  card.style.borderRadius = "16px";
  card.style.padding = "24px";
  card.style.display = "flex";
  card.style.flexDirection = "column";
  card.style.alignItems = "center";
  card.style.width = "280px";
  card.style.boxSizing = "border-box";
  card.style.position = "relative";
  card.style.boxShadow = "0 8px 30px rgba(0, 0, 0, 0.15)";
  card.style.transform = "scale(0.9)";
  card.style.transition = "transform 0.2s ease, opacity 0.2s ease";

  const closeBtn = document.createElement("span");
  closeBtn.innerHTML = "×";
  closeBtn.style.position = "absolute";
  closeBtn.style.top = "4px";
  closeBtn.style.right = "14px";
  closeBtn.style.fontSize = "28px";
  closeBtn.style.color = "#999999";
  closeBtn.style.cursor = "pointer";
  closeBtn.style.lineHeight = "1";

  const title = document.createElement("h3");
  title.innerHTML = t("Mobile.MySubscriptions.wechatPay");
  title.style.margin = "0 0 16px 0";
  title.style.fontSize = "16px";
  title.style.fontWeight = "600";
  title.style.color = "#111111";

  const img = document.createElement("img");
  const encodedData = encodeURIComponent(qrCodeContent);
  img.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodedData}`;
  img.style.width = "200px";
  img.style.height = "200px";
  img.style.marginBottom = "16px";
  img.style.borderRadius = "8px";

  const desc = document.createElement("p");
  desc.innerHTML = t("Mobile.MySubscriptions.qrCodeUnsupported");
  desc.style.margin = "0";
  desc.style.fontSize = "13px";
  desc.style.color = "#666666";
  desc.style.textAlign = "center";
  desc.style.lineHeight = "1.5";

  card.appendChild(closeBtn);
  card.appendChild(title);
  card.appendChild(img);
  card.appendChild(desc);
  overlay.appendChild(card);
  document.body.appendChild(overlay);

  setTimeout(() => {
    overlay.style.opacity = "1";
    card.style.transform = "scale(1)";
  }, 10);

  const closeHandler = () => {
    card.style.transform = "scale(0.9)";
    overlay.style.opacity = "0";
    setTimeout(() => {
      if (document.body.contains(overlay)) {
        document.body.removeChild(overlay);
      }
    }, 200);
    onClose?.();
  };

  closeBtn.onclick = closeHandler;
  overlay.onclick = (e) => {
    if (e.target === overlay) {
      closeHandler();
    }
  };

  uni.showLoading({
    title: t("Mobile.MySubscriptions.payPending"),
    mask: true,
  });
  const payStatus = await pollPayResult(orderId);
  uni.hideLoading();
  
  closeHandler();
  handlePayResultToast(payStatus, t, onSuccess);
}
// #endif

// ========== MP-WEIXIN 工具函数 ==========
// #ifdef MP-WEIXIN

/**
 * 获取微信登录码，每次支付前调用一次
 */
export function getWxLoginCode(): Promise<string> {
  return new Promise((resolve, reject) => {
    uni.login({
      provider: "weixin",
      success: (res) => {
        resolve(res.code);
      },
      fail: (err) => {
        reject(err);
      },
    });
  });
}

/**
 * 调起微信支付面板，返回是否支付成功
 * 取消支付和其他失败均 resolve(false)，不抛异常
 */
export function requestWxPayment(
  params: WxPayParams,
  t: (key: string) => string,
): Promise<boolean> {
  return new Promise((resolve) => {
    uni.requestPayment({
      provider: "wxpay",
      timeStamp: params.timeStamp,
      nonceStr: params.nonceStr,
      package: params.packageValue,
      signType: params.signType || "RSA",
      paySign: params.paySign,
      success: () => {
        resolve(true);
      },
      fail: (err) => {
        if (err.errCode === 700601 || err.errMsg?.includes("cancel")) {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payCancelled"),
            icon: "none",
          });
        } else {
          uni.showToast({
            title: t("Mobile.MySubscriptions.payFailed"),
            icon: "none",
          });
          console.error("WeChat payment failed:", err);
        }
        resolve(false);
      },
    });
  });
}
// #endif

// ========== 通用工具函数 ==========

/**
 * 轮询结算状态，最多 10 次，间隔 2 秒
 * @returns "success" | "failed" | "pending"
 */
export async function pollPayResult(orderId: number): Promise<string> {
  const maxAttempts = 10;
  for (let i = 0; i < maxAttempts; i++) {
    await new Promise((resolve) => setTimeout(resolve, 2000));
    try {
      const res = await apiGetSettlementStatus({ orderId });
      if (res.code === SUCCESS_CODE && res.data != null) {
        const data = res.data!;
        if (
          data.settled ||
          data.orderStatus === OrderStatus.PAID ||
          data.payStatus === PayStatus.SUCCESS
        ) {
          return "success";
        }
        if (data.terminalFailed || data.orderStatus === OrderStatus.CANCELLED) {
          return "failed";
        }
      }
    } catch (e) {
      // 网络异常忽略，继续重试
    }
  }
  return "pending";
}

/**
 * 支付结果 Toast 提示，根据结果调用 onSuccess 回调
 * @param result "success" | "failed" | "pending"
 */
export function handlePayResultToast(
  result: string,
  t: (key: string) => string,
  onSuccess?: () => void,
): void {
  if (result === "success") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.paySuccess"),
      icon: "success",
    });
    onSuccess?.();
  } else if (result === "failed") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.payFailed"),
      icon: "none",
    });
  } else if (result === "pending") {
    uni.showToast({
      title: t("Mobile.MySubscriptions.payPending"),
      icon: "none",
    });
  }
}

/**
 * 通用订单创建并支付流程
 *
 * 统一 handlePaySubscription / handlePayCredits 的公共逻辑：
 *  1. 防重复点击 + showLoading
 *  2. 调用 createOrderFn 创建订单，解析 orderId
 *  3. 通过 executePay 回调处理平台特定支付流程
 *  4. 异常统一处理（hideLoading + toast + 重置 processingId）
 *
 * @param processingId   hook 内的处理中 ID ref
 * @param targetId       当前操作目标 ID（planId / packageId）
 * @param createOrderFn  创建订单的异步函数，返回 { code, data }
 * @param executePay     平台特定支付执行函数，接收 orderId
 * @param t              i18n 翻译函数
 */
export async function handleCreateAndPay(
  processingId: { value: number | string | null },
  targetId: number,
  createOrderFn: () => Promise<any>,
  executePay: (orderId: number) => Promise<void>,
  t: (key: string) => string,
): Promise<void> {
  if (processingId.value != null) return;
  processingId.value = targetId;
  uni.showLoading({
    title: t("Mobile.MySubscriptions.payPending"),
    mask: true,
  });

  try {
    const orderRes = await createOrderFn();
    
    if (orderRes.code === SUCCESS_CODE && orderRes.data) {
      const orderId = orderRes.data.id ?? orderRes.data;
      await executePay(orderId as number);
    } else {
      uni.hideLoading();
      uni.showToast({
        title: t("Mobile.MySubscriptions.orderIdNotFound"),
        icon: "none",
      });
      processingId.value = null;
    }
  } catch (e) {
    uni.hideLoading();
    uni.showToast({
      title: t("Mobile.MySubscriptions.loadFailed"),
      icon: "none",
    });
    processingId.value = null;
  }
}

// 获取 payMode
export function getPayMode(): PayMode {
  // 默认是扫码
  let payMode = PayMode.scan;

  // 微信小程序
  // #ifdef MP-WEIXIN
  payMode = PayMode.minipay;
  // #endif

  // #ifdef H5 || WEB
  payMode = PayMode.h5;
  const env = detectClientEnv();
  if (env.isWeChat) {
    payMode = PayMode.minipay;
  }
  // #endif

  return payMode;
}

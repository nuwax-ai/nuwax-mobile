/** 每页加载消息数量 */
const MESSAGE_LIST_SIZE = 10;

/** 变量参数映射类型 */
type VariableParamsMap = UTSJSONObject;

/** 发送消息参数类型 */
type SendMessageData = {
  messageInfo?: string;
  files?: UploadFileInfo[];
  selectedComponents?: AgentSelectedComponentInfo[];
  variableParams?: VariableParamsMap;
  skillIds?: number[];
};

/** 获取已发布代理信息参数类型 */
type GetPublishedAgentInfoParams = {
  messageInfo?: string;
  files?: UploadFileInfo[];
  selectedComponents?: AgentSelectedComponentInfo[];
};

const handleMessageProcess = (text: string): string => {
  return text; // 目前由于方案 已经整体切换到 mp-html内处理 所这里都关闭了
};

// 统一提取流式文本（兼容不同协议格式）
const extractTextFromChunk = (payload: any): string => {
  if (payload == null) return "";
  if (typeof payload === "string") return (payload as string).trim();

  const obj = payload as UTSJSONObject
  const textVal = obj['text'] as string | null
  const contentVal = obj['content'] as string | null
  const direct = strOr(textVal, strOr(contentVal, "")).trim();
  if (hasLen(direct)) return direct;

  const deltaObj = obj['delta'] as UTSJSONObject | null
  const deltaContent = deltaObj != null ? (deltaObj['content'] as string | null) : null
  const delta = strOr(deltaContent, "").trim();
  if (hasLen(delta)) return delta;

  const choicesArr = obj['choices'] as any[] | null
  if (choicesArr != null && choicesArr.length > 0) {
    const choice = choicesArr[0] as UTSJSONObject
    const choiceDeltaObj = choice['delta'] as UTSJSONObject | null
    const choiceMessageObj = choice['message'] as UTSJSONObject | null
    const deltaContentVal = choiceDeltaObj != null ? (choiceDeltaObj['content'] as string | null) : null
    const messageContentVal = choiceMessageObj != null ? (choiceMessageObj['content'] as string | null) : null
    const choiceText = strOr(deltaContentVal, strOr(messageContentVal, "")).trim()
    if (hasLen(choiceText)) return choiceText;
  }

  return "";
};

const normalizeConversationEventType = (
  eventType: any,
): ConversationEventTypeEnum | string => {
  const normalized = strOr(eventType as string | null, "")
    .trim()
    .replace(/-/g, "_")
    .toUpperCase();
  return normalized;
};

/**
 * 服务层：负责业务逻辑和API调用
 */
export default class AgentDetailService {
  private data: AgentDetailData;
  private isAllowSuggest: boolean = true;
  constructor(data: AgentDetailData) {
    this.data = data;
  }

  /**
   * 处理查询会话
   */
  async handleQueryConversation(
    result: RequestResponse<ConversationInfo>,
  ): Promise<void> {
    this.data.isLoadingConversation.value = true;
    const { data: responseData } = result;

    this.data.conversationInfo.value =
      responseData as ConversationInfo;
    this.data.agentInfo.value = responseData?.agent as AgentDetailDto | null;
    // 确保 agentId 被设置
    if (responseData?.agentId != null) {
      this.data.agentId.value = responseData.agentId;
    }
    // 确保会话ID被设置，临时会话加载历史记录同样需要该 ID
    if (responseData?.id != null) {
      this.data.conversationId.value = responseData.id;
    }
    // 是否开启问题建议,可用值:Open,Close
    this.data.isSuggest.value =
      responseData?.agent?.openSuggest === OpenCloseEnum.Open;
    // 可用组件列表
    this.data.manualComponents.value = responseData?.agent?.manualComponents ?? [];
    // 如果变量参数存在,则禁用变量参数
    if (responseData?.variables != null) {
      this.data.isSendMessageRef.value = true;
    }
    // 变量参数
    const _variables = responseData?.agent?.variables ?? [];
    this.data.variables.value = _variables;
    // 用户填充变量
    this.data.userFillVariables.value = responseData?.variables ?? {};
    // 消息列表
    const _messageList = responseData?.messageList ?? [];
    // 排除预置问题
    const len = _messageList.filter((item: MessageInfo): boolean => item.id != null && (item.id as string).length > 0).length;
    if (len > 0) {
      // 处理消息文本，先适配历史消息格式（PC端HTML标签转移动端Markdown语法）
      const processedMessageList = _messageList.map((message: MessageInfo) => {
        // 适配历史消息：将PC端自定义HTML标签转换为移动端Markdown容器语法
        // 同时将componentExecutedList转换为processingList
        const adaptedMessage = adaptHistoryMessage(message);

        // 确保 text 字段始终有值，避免 undefined 导致渲染错误
        const rawText = adaptedMessage.text ?? "";
        adaptedMessage.text = handleMessageProcess(rawText);
        // 使用同步方法生成ID，兼容所有平台
        adaptedMessage.id = strOr(adaptedMessage.id as string | null, generateUniqueId());

        return adaptedMessage;
      });

      this.data.autoToLastMsg.value = true;
      // 一次性设置消息列表，避免逐条渲染产生动态效果
      this.data.messageList.value = processedMessageList;

      // 无论初始返回多少条，只要有消息就认为可能有历史消息，保证向上滑动时至少调用一次分页接口
      this.data.hasMoreMessages.value = len > 0;

      // 处理问题建议
      const lastMessage = processedMessageList[len - 1];
      // 最后一条消息为"问答"时，获取问题建议
      if (
        lastMessage.type === MessageModeEnum.QUESTION &&
        lastMessage.ext != null && lastMessage.ext.length > 0
      ) {
        const emptyGuids: GuidQuestionDto[] = []
        const suggestList = valOr(lastMessage.ext.map((item): GuidQuestionDto => {
          return { type: GuidQuestionSetTypeEnum.Question, info: strOr(item.content, "") } as GuidQuestionDto;
        }), emptyGuids);
        this.data.chatSuggestList.value = suggestList as GuidQuestionDto[];
      } else if (len === 1) {
        // 如果消息列表大于1时，说明已开始会话，就不显示预置问题，反之显示
        // 如果存在预置问题，显示预置问题
        const questions = responseData?.agent?.openingGuidQuestions;
        this.data.chatSuggestList.value = questions != null
          ? questions.map((q: string): GuidQuestionDto => {
            return { type: GuidQuestionSetTypeEnum.Question, info: q } as GuidQuestionDto;
          })
          : [];
      }
    }
    // 不存在会话消息时，才显示开场白预置问题
    else {
      const emptyDtos: GuidQuestionDto[] = []
      const agentObj = responseData?.agent
      if (agentObj != null) {
        const guidDtos = (agentObj as UTSJSONObject)['guidQuestionDtos'] as GuidQuestionDto[] | null
        this.data.chatSuggestList.value = guidDtos != null ? guidDtos.slice(0, 5) : emptyDtos
      } else {
        this.data.chatSuggestList.value = emptyDtos
      }
    }
    this.data.isLoadingConversation.value = false;

    // 获取沙盒列表
    this.handleGetSandboxList();

    // 初始化当前模型ID
    if (responseData?.agent != null) {
      const respObj = responseData as UTSJSONObject
      const modelIdVal = respObj['modelId'] as number | null
      this.data.currentModelId.value = modelIdVal != null ? modelIdVal : 0;
    }
  }

  /**
   * 加载更多历史消息
   * 用户上滑到顶部时触发，向消息列表头部追加更多历史消息
   */
  async handleLoadMoreMessages(): Promise<void> {
    const conversationId = this.data.conversationId.value;

    // 前置校验
    if (
      conversationId == null ||
      this.data.isLoadingMoreMessages.value ||
      this.data.hasMoreMessages.value === false ||
      this.data.messageList.value.length === 0
    ) {
      return;
    }

    // 取消息列表第一条的 index 作为查询游标
    const firstMessage = this.data.messageList.value[0];
    const currentIndex = firstMessage?.index ?? 0;

    // 如果 index 为 0，说明已经是最早的消息
    if (currentIndex <= 0) {
      this.data.hasMoreMessages.value = false;
      return;
    }

    this.data.isLoadingMoreMessages.value = true;

    try {
      const res = await apiAgentConversationMessageList({
        conversationId: conversationId as number,
        index: currentIndex,
        size: MESSAGE_LIST_SIZE,
      });

      if (res.code === SUCCESS_CODE && res.data != null) {
        const olderMessages = res.data;

        if (olderMessages.length > 0) {
          // 处理消息格式（与 handleQueryConversation 保持一致）
          const processedMessages = olderMessages.map(
            (message: MessageInfo) => {
              const adaptedMessage = adaptHistoryMessage(message);
              const rawText = adaptedMessage.text ?? "";
              adaptedMessage.text = handleMessageProcess(rawText);
              adaptedMessage.id = strOr(adaptedMessage.id as string | null, generateUniqueId());
              return adaptedMessage;
            },
          );

          // 前插到消息列表头部
          this.data.messageList.value = processedMessages.concat(this.data.messageList.value);

          // 判断是否还有更多消息
          this.data.hasMoreMessages.value =
            olderMessages.length >= MESSAGE_LIST_SIZE;
        } else {
          // 返回空数组，没有更多消息
          this.data.hasMoreMessages.value = false;
        }
      }
    } catch (error) {
      console.error("[AgentDetailService] 加载更多消息失败:", error);
    } finally {
      this.data.isLoadingMoreMessages.value = false;
    }
  }

  /**
   * 修改消息列表
   */
  async handleChangeMessageList(
    res: ConversationChatResponse,
    currentMessageId: string,
  ): Promise<void> {
    // 添加空值检查
    if (res == null) {
      console.warn("[AgentDetailService] handleChangeMessageList 收到空响应");
      return;
    }

    // 忽略心跳包 (HEART_BEAT 不包含 data)
    if (normalizeConversationEventType(res.eventType) === "HEART_BEAT") {
      return;
    }

    // 检查 res.data 是否存在
    if (res.data == null) {
      console.warn(
        "[AgentDetailService] handleChangeMessageList 响应中缺少 data 字段:",
        res,
      );
      return;
    }

    const normalizedEventType = normalizeConversationEventType(res.eventType);
    const responseData = res.data as any;
    this.data.currentConversationRequestId.value = res.requestId;
    const respDataObj = responseData != null ? (responseData as UTSJSONObject) : null
    const outputTextVal = respDataObj != null ? (respDataObj['outputText'] as string | null) : null
    const outputText2Val = respDataObj != null ? (respDataObj['output_text'] as string | null) : null
    const debugText = strOr(
      extractTextFromChunk(responseData),
      strOr(outputTextVal, strOr(outputText2Val, "")),
    );
    console.log("[AgentDetailService][SSE-Debug] handleChangeMessageList", {
      eventType: normalizedEventType,
      requestId: res.requestId,
      hasData: res.data != null,
      textLen: debugText.length,
      textPreview:
        debugText.length > 120 ? `${debugText.slice(0, 120)}...` : debugText,
    });
    logFileDebug("AgentDetailService", "handleChangeMessageList", {
      eventType: normalizedEventType,
      requestId: res.requestId,
      hasData: res.data != null,
      textLen: debugText.length,
      textPreview:
        debugText.length > 120 ? `${debugText.slice(0, 120)}...` : debugText,
    });

    // 调试日志：追踪流式过程
    // console.log(`[Stream] Event: ${eventType}, MessageId: ${currentMessageId}, Text: ${responseData?.text?.substring(0, 50)}...`)

    if (!hasLen(this.data.messageList.value)) return;

    const list = ([] as MessageInfo[]).concat(this.data.messageList.value);
    const index = list.findIndex((item) => item.id === currentMessageId);
    let arraySpliceAction = 1;

    const currentMessage = list.find(
      (item) => item.id === currentMessageId,
    ) as MessageInfo;
    if (currentMessage == null) return;

    // 检查是否是新的对话开始（第一个消息块）
    const isNewConversation = !hasLen(currentMessage.text);

    // 确保流式过程中消息始终可见
    if (currentMessage.status === MessageStatusEnum.Loading) {
      currentMessage.status = MessageStatusEnum.Incomplete;
      // console.log(`[Stream] Message ${currentMessageId} status changed from Loading to Incomplete`)
    }

    let newMessage: MessageInfo | null = null;

    // 处理不同的事件类型
    if (normalizedEventType === ConversationEventTypeEnum.PROCESSING) {
      const respObj = responseData as UTSJSONObject
      const processingResult = respObj['result'] as UTSJSONObject | null
      const execId = processingResult != null ? (processingResult['executeId'] as string | null) : null
      respObj['executeId'] = execId;

      const toolCallData = {
        type: respObj['type'] != null ? `${respObj['type']}` : '',
        name: respObj['name'] != null ? `${respObj['name']}` : '',
        executeId: execId != null ? execId : '',
        status: respObj['status'] != null ? `${respObj['status']}` : '',
      } as ToolCallData
      const accumulatedText = getCustomBlock(
        strOr(currentMessage.text, ""),
        toolCallData,
      );

      currentMessage.text = accumulatedText;
      currentMessage.status = MessageStatusEnum.Loading;
      currentMessage.processingList = (currentMessage.processingList != null ? currentMessage.processingList : []).concat([responseData]) as ProcessingInfo[];
      newMessage = currentMessage;

      // 长任务型任务处理
      const conversationId = this.data.conversationId.value;

      // 长任务型任务处理(刷新文件树)
      const respType = respObj['type'] != null ? `${respObj['type']}` : ''
      if (
        respType === (AgentComponentTypeEnum.ToolCall as string) &&
        conversationId != null
      ) {
        CustomActionService.refreshFileList(`${conversationId}`);
      }
    }

    if (normalizedEventType === ConversationEventTypeEnum.MESSAGE) {
      const msgObj = responseData as UTSJSONObject
      const text = strOr(msgObj['text'] as string | null, '')
      const type = strOr(msgObj['type'] as string | null, '')
      const ext = msgObj['ext'] as MessageQuestionExtInfo[] | null
      const id = msgObj['id'] as string | null
      const finished = msgObj['finished'] === true
      // 如果会话结束，则设置会话状态为不活跃
      if (finished) {
        this.data.isConversationActive.value = false;
      }

      if (type === (MessageModeEnum.THINK as string)) {
        currentMessage.think = `${currentMessage.think}${text}`;
        currentMessage.status = MessageStatusEnum.Incomplete;
        newMessage = currentMessage;
      } else if (type === (MessageModeEnum.QUESTION as string)) {
        // 问题内容累积 - 新对话时从头开始，否则累积
        const accumulatedText = handleMessageProcess(
          isNewConversation ? text : `${currentMessage.text}${text}`,
        );
        currentMessage.text = accumulatedText;
        currentMessage.status = finished ? MessageStatusEnum.Complete : MessageStatusEnum.Incomplete;
        newMessage = currentMessage;

        if (ext != null && ext.length > 0) {
          const emptyGuids2: GuidQuestionDto[] = []
          this.data.chatSuggestList.value =
            valOr(ext.map((extItem: MessageQuestionExtInfo): GuidQuestionDto => {
              return { type: GuidQuestionSetTypeEnum.Question, info: strOr(extItem.content, "") } as GuidQuestionDto;
            }), emptyGuids2) as GuidQuestionDto[];
        }
      } else {
        // 工作流过程输出
        if (
          this.data.messageIdRef.value != null &&
          this.data.messageIdRef.value !== id &&
          finished === true
        ) {
          // 新对话时从头开始，否则累积
          const accumulatedText = handleMessageProcess(
            isNewConversation ? text : `${currentMessage.text}${text}`,
          );
          // INSERT case: create new message object with different ID
          const insertedMsg = {
            id: id != null ? (id as string) : '',
            role: currentMessage.role,
            type: currentMessage.type,
            text: accumulatedText,
            think: currentMessage.think,
            time: currentMessage.time,
            attachments: currentMessage.attachments,
            ext: currentMessage.ext,
            finished: currentMessage.finished,
            metadata: currentMessage.metadata,
            messageType: currentMessage.messageType,
            requestId: currentMessage.requestId,
            index: currentMessage.index,
            status: MessageStatusEnum.Complete,
            finalResult: currentMessage.finalResult,
            processingList: currentMessage.processingList,
            markdownElList: currentMessage.markdownElList,
          } as MessageInfo;
          newMessage = insertedMsg;
          arraySpliceAction = 0;
        } else {
          this.data.messageIdRef.value = id != null ? (id as string) : '';
          // 新对话时从头开始，否则累积
          const accumulatedText = handleMessageProcess(
            isNewConversation ? text : `${currentMessage.text}${text}`,
          );
          currentMessage.text = accumulatedText;
          currentMessage.status = MessageStatusEnum.Incomplete;
          newMessage = currentMessage;
        }
      }
    }

    if (normalizedEventType === ConversationEventTypeEnum.FINAL_RESULT) {
      currentMessage.status = MessageStatusEnum.Complete;
      currentMessage.finalResult = responseData as ConversationFinalResult;
      currentMessage.requestId = res.requestId;
      newMessage = currentMessage;
      this.data.requestId.value = res.requestId;
    }

    if (normalizedEventType === ConversationEventTypeEnum.ERROR) {
      currentMessage.status = 'error' as MessageStatusEnum;
      newMessage = currentMessage;
      this.data.isConversationActive.value = false;
    }

    // 更新消息列表
    if (newMessage != null) {
      list.splice(index, arraySpliceAction, newMessage as MessageInfo);
    }

    // 确保消息列表更新是同步的
    this.data.messageList.value = list.concat([] as MessageInfo[]);

    // 流式渲染过程中触发自动滚动到底部
    // 确保 autoToLastMsg 为 true，这样 watch 触发后会执行滚动
    if (this.data.autoToLastMsg.value) {
      // 通过事件总线通知主组件执行滚动，兼容微信小程序和 H5
      uni.$emit("streamMessageUpdate");
    }

    // 调试日志：状态更新
    // if (newMessage) {
    // 	console.log(`[Stream] Message ${currentMessageId} updated: status=${newMessage.status}, textLength=${newMessage.text?.length || 0}`)
    // }

    // 使用优化更新方法，只更新需要更新的组件
    if (newMessage != null && newMessage.messageType === MessageTypeEnum.ASSISTANT) {
      await nextTick();
      // 通过uni事件总线更新 - 现在直接传递文本内容给 mp-html 组件
      const emitData = newMessage as UTSJSONObject;
      emitData["body"] = handleMessageProcess(strOr(newMessage.text, ""));
      uni.$emit("updateMessageComponent", {
        messageId: `${currentMessageId}_${newMessage.index}`,
        data: emitData,
      });

      // 打开页面首页
      const responseDataObj = responseData as UTSJSONObject;
      if (
        responseDataObj['status'] === ProcessingEnum.EXECUTING &&
        responseDataObj['type'] === "Page"
      ) {
        uni.$emit("page_preview_executing", responseData);
      }
    }
  }

  // 获取文件树列表
  async fetchFileList(cId: number): Promise<void> {
    try {
      this.data.isLoadingFiles.value = true;
      const result = await apiGetStaticFileList(cId);
      this.data.isLoadingFiles.value = false;
      if (result.code === SUCCESS_CODE) {
        const data = result.data as UTSJSONObject | null;
        if (data == null) return;

        const files = data['files'] as any[] | null;

        let treeData: FileNode[] = [];

        // 检查是否是新的扁平格式
        if (files != null && Array.isArray(files) && files.length > 0) {
          const firstFile = files[0] as UTSJSONObject;
          if (firstFile['name'] != null) {
            treeData = transformFlatListToTree(files);
          } else {
            // 如果是原有的树形格式，直接使用
            treeData = files as FileNode[];
          }
        }

        this.data.fileList.value = treeData;
      }
    } catch (error) {
      console.error("[AgentDetailService] 获取文件树列表失败:", error);
    } finally {
      this.data.isLoadingFiles.value = false;
    }
  }

  /**
   * 会话处理
   */
  async handleConversation(
    params: ConversationChatParams | TempConversationChatParams,
    currentMessageId: string,
    // 是否是临时会话
    isTempChat: boolean = false,
    // 超时回调
    onTimeout?: () => void,
  ): Promise<void> {
    try {
      // 清空问题建议列表
      this.data.chatSuggestList.value = [];
      // 开始会话后，允许获取问题建议
      this.isAllowSuggest = true;

      // 标记是否已经更新过主题，确保只更新一次
      let hasUpdatedTopic = false;
      let debugChunkCount = 0;

      await chatService.sendMessage(
        params,
        // 处理流式数据
        (chunk: string) => {
          debugChunkCount += 1;
          const rawChunk = strOr(chunk, "").trim();
          if (debugChunkCount <= 8 || debugChunkCount % 20 === 0) {
            console.log("[AgentDetailService][SSE-Debug] chunk in", {
              chunkNo: debugChunkCount,
              len: rawChunk.length,
              preview:
                rawChunk.length > 160
                  ? `${rawChunk.slice(0, 160)}...`
                  : rawChunk,
            });
            logFileDebug("AgentDetailService", "chunk in", {
              chunkNo: debugChunkCount,
              len: rawChunk.length,
              preview:
                rawChunk.length > 160
                  ? `${rawChunk.slice(0, 160)}...`
                  : rawChunk,
            });
          }
          if (!hasLen(rawChunk) || rawChunk === "[DONE]") {
            return;
          }

          // 兼容部分端或网关透传 "data: xxx" 的情况
          const normalizedChunk = rawChunk.startsWith("data:")
            ? rawChunk.slice(5).trim()
            : rawChunk;

          try {
            const parsed = JSON.parse(normalizedChunk);

            // 标准结构：对象
            if (parsed != null && typeof parsed === "object") {
              const result = parsed as ConversationChatResponse;
              const normalizedEventType = normalizeConversationEventType(result.eventType) as ConversationEventTypeEnum;
              const resultObj = result as UTSJSONObject;
              const hasDataField = resultObj.toMap().has("data");
              console.log("[AgentDetailService][SSE-Debug] parsed object", {
                eventType: normalizedEventType,
                hasData: hasDataField,
              });
              logFileDebug("AgentDetailService", "parsed object", {
                eventType: normalizedEventType,
                hasData: hasDataField,
              });

              // 验证解析结果
              if (result == null || typeof result !== "object") {
                console.warn(
                  "[AgentDetailService] 解析结果无效, type:",
                  typeof result,
                  "value:",
                  result,
                );
                return;
              }
              // 验证是否包含必要字段（或可提取文本）
              if (hasDataField === false) {
                const plainText = extractTextFromChunk(result as any);
                if (plainText.length > 0) {
                  const fallbackRes = {
                    completed: false,
                    error: "",
                    requestId: this.data.currentConversationRequestId.value,
                    eventType: normalizedEventType,
                    data: {
                      id: currentMessageId,
                      type: MessageModeEnum.QUESTION,
                      text: plainText,
                      finished: false,
                      ext: "",
                      messageType: MessageTypeEnum.ASSISTANT,
                      metadata: {},
                      role: AssistantRoleEnum.ASSISTANT,
                      think: "",
                      time: Date.now(),
                    },
                  } as ConversationChatResponse;
                  this.handleChangeMessageList(fallbackRes, currentMessageId);
                  return;
                }
                console.warn(
                  "[AgentDetailService] 解析结果缺少 data 字段",
                );
                return;
              }

              // 流式数据开始时，第一次收到数据时更新主题（只执行一次）
              if (
                hasUpdatedTopic === false &&
                isTempChat === false &&
                this.data.needUpdateTopicRef.value
              ) {
                hasUpdatedTopic = true;
                const chatParams = params as ConversationChatParams;
                this.handleUpdateTopic(chatParams.conversationId.toString(), chatParams.message);
              }

              this.handleChangeMessageList(result, currentMessageId);
              return;
            }

            // 兜底：JSON 解析成功但不是对象（如字符串分块）
            if (parsed != null) {
              const textChunk = extractTextFromChunk(parsed);
            if (textChunk.length > 0) {
              console.log(
                "[AgentDetailService][SSE-Debug] parsed non-object text fallback",
                {
                  len: textChunk.length,
                  preview:
                    textChunk.length > 120
                      ? `${textChunk.slice(0, 120)}...`
                      : textChunk,
                },
              );
              logFileWarn("AgentDetailService", "parsed non-object text fallback", {
                len: textChunk.length,
                preview:
                  textChunk.length > 120
                    ? `${textChunk.slice(0, 120)}...`
                    : textChunk,
              });
              const fallbackRes = {
                completed: false,
                error: "",
                requestId: this.data.currentConversationRequestId.value,
                eventType: ConversationEventTypeEnum.MESSAGE,
                data: {
                  id: currentMessageId,
                  type: MessageModeEnum.QUESTION,
                  text: textChunk,
                  finished: false,
                  ext: "",
                  messageType: MessageTypeEnum.ASSISTANT,
                  metadata: {},
                  role: AssistantRoleEnum.ASSISTANT,
                  think: "",
                  time: Date.now(),
                },
              } as ConversationChatResponse;
              this.handleChangeMessageList(fallbackRes, currentMessageId);
            }
            }
          } catch (error) {
            // 兜底：非 JSON 分块（例如直接返回文本 token）
            const textChunk = extractTextFromChunk(normalizedChunk);
            if (textChunk.length > 0) {
              console.log(
                "[AgentDetailService][SSE-Debug] parse-error text fallback",
                {
                  len: textChunk.length,
                  preview:
                    textChunk.length > 120
                      ? `${textChunk.slice(0, 120)}...`
                      : textChunk,
                },
              );
              logFileWarn("AgentDetailService", "parse-error text fallback", {
                len: textChunk.length,
                preview:
                  textChunk.length > 120
                    ? `${textChunk.slice(0, 120)}...`
                    : textChunk,
              });
              const fallbackRes = {
                completed: false,
                error: "",
                requestId: this.data.currentConversationRequestId.value,
                eventType: ConversationEventTypeEnum.MESSAGE,
                data: {
                  id: currentMessageId,
                  type: MessageModeEnum.QUESTION,
                  text: textChunk,
                  finished: false,
                  ext: "",
                  messageType: MessageTypeEnum.ASSISTANT,
                  metadata: {},
                  role: AssistantRoleEnum.ASSISTANT,
                  think: "",
                  time: Date.now(),
                },
              } as ConversationChatResponse;
              this.handleChangeMessageList(fallbackRes, currentMessageId);
              return;
            }

            // 验证解析结果
            console.error(
              "[AgentDetailService] 解析SSE数据失败:",
              error,
              "原始数据长度:",
              normalizedChunk?.length,
              "前100字符:",
              normalizedChunk?.substring(0, 100),
            );
            logFileError("AgentDetailService", "parse chunk failed", {
              error: `${error}`,
              len: normalizedChunk?.length ?? 0,
              preview: strOr(normalizedChunk?.substring(0, 100), ""),
            });
          }
        },
        // 完成回调
        () => {
          console.log("[AgentDetailService][SSE-Debug] stream complete callback");
          logFileInfo("AgentDetailService", "stream complete callback");
          // 流式消息完成，设置会话状态为不活跃
          this.data.isConversationActive.value = false;

          // 如果不是临时会话,则处理问题建议，临时会话，不需要处理问题建议
          if (!isTempChat) {
            if (this.data.isSuggest.value && this.isAllowSuggest) {
              apiAgentConversationChatSuggest(
                params as ConversationChatSuggestParams,
              ).then((responseData: any) => {
                // 更新问题建议列表
                const suggestData = (responseData as UTSJSONObject)['data'] as Array<string> | null;
                this.data.chatSuggestList.value = suggestData != null
                  ? suggestData.map((q: string): GuidQuestionDto => {
                    return { type: GuidQuestionSetTypeEnum.Question, info: q } as GuidQuestionDto;
                  })
                  : [];
              }, null);
            }
          }
          // 会话完成后根据消息列表中的最后一条消息 判断是否存在 <task-result> 标签
          const lastMessage =
            this.data.messageList.value[this.data.messageList.value.length - 1];

          const taskResult = extractTaskResult(lastMessage.text ?? "");
          if (taskResult.hasTaskResult && taskResult.file != null) {
            const conversationIdStr = this.data.conversationId.value.toString();
            const filePathStr = taskResult.file!;
            getFileProxyUrlByConversationIdAndFilePath(
              conversationIdStr,
              filePathStr,
            ).then((fileProxyUrl) => {
              if (fileProxyUrl != null) {
                jumpToFilePreviewPage(conversationIdStr, fileProxyUrl as string);
              }
            }, null);
          }
        },
        // 错误回调
        (error: any) => {
          console.error(
            "[AgentDetailService] Chat stream error callback:",
            error,
          );
          logFileError("AgentDetailService", "chat stream error callback", {
            error: `${error}`,
          });
          onTimeout?.();
        },
        isTempChat,
        // 超时回调
        () => {
          console.warn("[AgentDetailService][SSE-Debug] stream timeout callback");
          logFileWarn("AgentDetailService", "stream timeout callback");
          onTimeout?.();
        },
      );
    } catch (error) {
      console.error("[AgentDetailService] Chat handling failed:", error);
    }
  }

  /**
   * 停止会话
   * @param isTempChat 是否是临时会话
   */
  async handleStopConversation(isTempChat: boolean = false): Promise<void> {
    // 停止会话后，不再允许获取问题建议
    this.isAllowSuggest = false;

    // 如果会话已经不活跃，说明会话已经结束，无需调用 stop 接口
    if (this.data.isConversationActive.value == null) {
      this.data.isStoppingConversation.value = false;
      return;
    }

    // 如果普通会话，并且任务正在执行，则更新任务状态为 CANCEL
    if (this.data.conversationInfo.value?.taskStatus === TaskStatus.EXECUTING) {
      const convInfo = this.data.conversationInfo.value;
      if (convInfo != null) {
        convInfo.taskStatus = TaskStatus.CANCEL;
      }
    }

    // 会话消息请求ID
    const requestId = this.data.currentConversationRequestId.value;

    // 对于临时会话，必须要有 requestId 才能停止
    if (isTempChat && requestId == null) {
      this.data.isStoppingConversation.value = false;
      this.data.isConversationActive.value = false;
      return;
    }

    // 对于普通会话，即使没有 requestId 也可以通过 conversationId 停止
    // 显示停止会话loading
    this.data.isStoppingConversation.value = true;
    let res : RequestResponse<any> | null = null;
    try {
      if (isTempChat) {
        res = await apiTempChatConversationStop(requestId);
      } else {
        res = await apiAgentConversationChatStop(
          `${this.data.conversationId.value}`,
        );
      }
      const { code, data: responseData, message } = res;
      this.data.isStoppingConversation.value = false;
      // 停止会话成功
      if (code === SUCCESS_CODE) {
        this.data.isConversationActive.value = false;
        console.log("[AgentDetailService] stop 接口调用成功");
      } else {
        uni.showToast({
          title: message,
          icon: "none",
        });
      }
    } catch (error) {
      console.error("[AgentDetailService] stop 接口调用失败:", error);
      this.data.isStoppingConversation.value = false;
      this.data.isConversationActive.value = false;
    }
  }

  /**
   * 将正在执行的工具调用状态更新为失败
   * 用于超时或异常中断时的状态更新
   */
  updateProcessingListToFailed(): void {
    console.log("[AgentDetailService] 开始更新工具调用状态为 FAILED");

    const messageList = this.data.messageList.value;
    if (!hasLen(messageList)) {
      console.log("[AgentDetailService] 消息列表为空，无需更新");
      return;
    }

    // 查找正在处理中的消息（状态为 Loading 或 Incomplete）
    for (let j = 0; j < messageList.length; j++) {
      const message = messageList[j];
      // 只处理正在进行中的助手消息
      if (
        (message.status === MessageStatusEnum.Loading ||
          message.status === MessageStatusEnum.Incomplete) &&
        message.processingList != null &&
        message.processingList.length > 0
      ) {
        console.log(
          `[AgentDetailService] 更新消息 ${message.id} 的工具调用状态`,
        );

        // 更新 processingList 中的状态
        for (let i = 0; i < message.processingList.length; i++) {
          const processing = message.processingList[i];
          // 将所有 EXECUTING 状态的工具调用改为 FAILED
          if (processing.status === ProcessingEnum.EXECUTING) {
            console.log(
              `[AgentDetailService] 工具 ${processing.name} 状态从 EXECUTING 改为 FAILED`,
            );
            processing.status = ProcessingEnum.FAILED;
          }
        }
      }
    }
    console.log("[AgentDetailService] 工具调用状态更新完成");
  }

  /**
   * 获取沙盒列表 (严格模式 - 移动端重构 Phase 9)
   */
  async handleGetSandboxList(useAgentSelected: boolean = true): Promise<void> {
    try {
      const res = await apiGetSandboxList();
      if (res.code === SUCCESS_CODE && res.data != null) {
        this.data.sandboxList.value = res.data.sandboxes ?? [];
        this.data.agentSelectedSandbox.value = useAgentSelected ? (res.data.agentSelected ?? {}) : {};

        const sandboxList = this.data.sandboxList.value;
        const conversationInfo = this.data.conversationInfo.value;
        const agentInfo = this.data.agentInfo.value;
        // 优先使用 data.agentId，其次使用 agentInfo.agentId
        const agentId = `${this.data.agentId.value ?? this.data.agentInfo.value?.agentId ?? 0}`;

        // 2.1 权限判断 (UI层已处理置灰，这里主要处理状态)
        if (agentInfo?.hasPermission === false) {
          this.data.isSandboxSwitchDisabled.value = true;
          // this.data.wholeDisabled.value = true;
          // 提示语由UI层 maskText 控制，或者在这里设置 disabledText?
          // 根据需求描述 "置灰对话框，提示：您无该智能体权限"
          // 查看 chat-input-phone 组件，maskText 可能是 prop，但这里好像没有直接控制 maskText 的变量？
          // 假设 UI 层 `chat-input-phone` 的 `has-permission` 属性已经控制了提示。
          // 我们主要确保 switch disabled
          return;
        }

        // 2.2.1 个人电脑 (Priority 1)
        if (agentInfo != null && agentInfo.sandboxId != null) {
          const personalSandboxId = `${agentInfo.sandboxId}`;
          const exists = sandboxList.some(
            (s) => s.sandboxId === personalSandboxId,
          );

          if (exists === false) {
            // 2.2.1.1 不在列表中 -> 展示“个人电脑不可用”
            this.data.currentSandboxId.value = personalSandboxId; // 或者是空？通常显示名字需要ID匹配，或者UI显示"不可用"
            this.data.isSandboxSwitchDisabled.value = true;
            this.data.isSandboxUnavailable.value = true;
            this.data.sandboxDisabledText.value = t(
              "Mobile.Sandbox.unavailable",
            );
            // this.data.wholeDisabled.value = true;
          } else {
            // 2.2.1.2 在列表中 -> 展示对应的电脑名称且不可切换
            this.data.currentSandboxId.value = personalSandboxId;
            this.data.isSandboxSwitchDisabled.value = true;
            this.data.isSandboxUnavailable.value = false;
            this.data.sandboxDisabledText.value = "";
            // this.data.wholeDisabled.value = false;
          }
          return;
        }

        // 2.2.2 电脑列表为空 (Priority 2)
        if (sandboxList.length === 0) {
          this.data.currentSandboxId.value = "";
          this.data.isSandboxSwitchDisabled.value = true;
          this.data.isSandboxUnavailable.value = true;
          this.data.sandboxDisabledText.value = t(
            "Mobile.Sandbox.noneAvailable",
          );
          // this.data.wholeDisabled.value = true;
          return;
        }

        // 2.2.3 共享电脑 (Priority 3)
        if (conversationInfo != null && conversationInfo.sandboxServerId != null) {
          const sharedSandboxId = `${conversationInfo.sandboxServerId}`;
          const exists = sandboxList.some(
            (s) => s.sandboxId === sharedSandboxId,
          );

          if (exists === false) {
            // 2.2.3.1 不在列表中 -> 展示“电脑不可用”
            this.data.currentSandboxId.value = sharedSandboxId;
            this.data.isSandboxSwitchDisabled.value = true;
            this.data.isSandboxUnavailable.value = true;
            this.data.sandboxDisabledText.value = t(
              "Mobile.Sandbox.unavailable",
            );
            // this.data.wholeDisabled.value = true;
          } else {
            // 2.2.3.2 在列表中 -> 展示对应的电脑名称且不可切换
            this.data.currentSandboxId.value = sharedSandboxId;
            this.data.isSandboxSwitchDisabled.value = true;
            this.data.isSandboxUnavailable.value = false;
            this.data.sandboxDisabledText.value = "";
            // this.data.wholeDisabled.value = false;
          }
          return;
        }

        // 2.2.4 默认选择 (Priority 4)
        // conversationInfo?.sandboxServerId 和 conversationInfo?.agent?.sandboxId 都为空
        this.data.isSandboxSwitchDisabled.value = false;
        this.data.isSandboxUnavailable.value = false;
        this.data.sandboxDisabledText.value = "";
        // this.data.wholeDisabled.value = false;

        let initialId = "";
        const selectedSandbox = this.data.agentSelectedSandbox.value[agentId];
        if (selectedSandbox != null) {
          // agentSelected 优先
          initialId = selectedSandbox as string;
          // 校验是否存在，不存在默认第一个
          if (sandboxList.some((s) => s.sandboxId === initialId) === false) {
            initialId = sandboxList[0].sandboxId;
          }
        } else {
          // 默认第一个
          initialId = sandboxList[0].sandboxId;
        }
        this.data.currentSandboxId.value = initialId;
      }
    } catch (error) {
      console.error("[AgentDetailService] 获取沙盒列表失败:", error);
    }
  }

  /**
   * 切换沙盒
   */
  async handleSelectSandbox(sandboxId: string): Promise<void> {
    // 如果禁止切换，直接返回
    if (this.data.isSandboxSwitchDisabled.value) {
      console.warn("[AgentDetailService] 当前不允许切换沙盒");
      return;
    }

    const agentId = `${this.data.agentId.value ?? this.data.agentInfo.value?.agentId ?? 0}`;

    try {
      // 调用 API 更新选中记录
      await apiUpdateSelectedSandbox(agentId, sandboxId);

      // 更新本地状态
      this.data.currentSandboxId.value = sandboxId;
      this.data.agentSelectedSandbox.value[agentId] = sandboxId;

      // uni.showToast({
      //   title: "切换成功",
      //   icon: "none",
      // });
    } catch (error) {
      console.error("[AgentDetailService] 切换沙盒失败:", error);
      uni.showToast({
        title: t("Mobile.Sandbox.switchFailed"),
        icon: "none",
      });
    }
  }

  /**
   * 切换模型
   */
  handleSelectModel(modelId: number, modelName: string = ""): void {
    this.data.currentModelId.value = modelId;
    if (modelName != null && modelName.length > 0) {
      this.data.currentModelName.value = modelName;
    }
    this.data.modelSelectVisible.value = false;
  }

  /**
   * 恢复会话状态
   * 用于页面从后台唤醒后检测并恢复会话
   *
   * 检测异常中断的条件：最后一条 ASSISTANT 消息状态为 Loading/Incomplete 且无 finalResult
   *
   * @returns 是否需要恢复（true 表示检测到异常中断并已恢复）
   */
  async resumeConversationState(): Promise<boolean> {
    // 1. 检查会话ID
    const conversationId = this.data.conversationId.value;
    if (conversationId == null) {
      return false;
    }

    // 2. 获取最后一条 ASSISTANT 消息
    const messageList = this.data.messageList.value;
    const lastAssistantMessage = ([] as MessageInfo[]).concat(messageList)
      .reverse()
      .find(
        (msg) => msg.messageType === MessageTypeEnum.ASSISTANT && msg.status != null,
      );

    // 3. 获取前端状态
    const isConversationActive = this.data.isConversationActive.value;
    const isStreaming = chatService.isCurrentlyStreaming;
    const isStoppingConversation = this.data.isStoppingConversation.value;

    // 4. 异常中断检测
    // 条件：最后一条助手消息状态为 Loading/Incomplete 且无 finalResult
    const isAbnormalInterruption =
      lastAssistantMessage != null &&
      (lastAssistantMessage.status === MessageStatusEnum.Loading ||
        lastAssistantMessage.status === MessageStatusEnum.Incomplete) &&
      (lastAssistantMessage.finalResult == null || (lastAssistantMessage.finalResult as boolean) !== true);

    // 5. 如果用户正在主动停止，不是异常中断
    if (isStoppingConversation) {
      return false;
    }

    // 6. 如果 SSE 仍在工作，无需恢复
    if (isStreaming) {
      return false;
    }

    // 7. 检测到异常中断
    if (!isAbnormalInterruption) {
      return false;
    }

    console.log("[SessionResume] 检测到异常中断，正在查询后端会话状态", {
      lastMessageStatus: lastAssistantMessage?.status,
      conversationId,
    });

    try {
      // 8. 查询后端会话状态并刷新
      const res = await apiAgentConversation(conversationId);
      if (res.code === SUCCESS_CODE) {
        const taskStatus = res.data?.taskStatus;
        // 更新会话状态
        if (taskStatus != null && taskStatus.toString() === "EXECUTING") {
          // 任务仍在后端执行，保持活跃状态
          this.data.isConversationActive.value = true;
        } else {
          // 任务已完成或取消，更新前端状态
          this.data.isConversationActive.value = false;
        }

        // 更新消息列表（刷新页面数据）
        this.handleQueryConversation(res);
        console.log(
          "[SessionResume] 会话状态已恢复，后端任务状态:",
          taskStatus,
        );
      }

      return true;
    } catch (error) {
      console.error("[SessionResume] 恢复会话状态失败:", error);
      // 恢复失败时，重置前端状态
      this.data.isConversationActive.value = false;
      return false;
    }
  }

  /**
   * 发送消息
   *
   * @param data 消息数据
   * @param isTempChat 是否是临时会话
   */
  async handleSendMessage(
    data: SendMessageData,
    isTempChat: boolean = false,
    // 超时回调
    onTimeout?: () => void,
  ): Promise<void> {
    const { messageInfo, files, selectedComponents, variableParams } = data;
    // 安全检查：确保this.data存在
    if (this.data == null) {
      return;
    }

    const attachments: AttachmentFile[] = [];
    if (files != null) {
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        attachments.push({
          fileKey: strOr(file.key, ""),
          fileUrl: strOr(file.url, ""),
          fileName: strOr(file.name, ""),
          mimeType: strOr(file.type, ""),
          fileSize: file.size != null ? (file.size as number) : 0,
        } as AttachmentFile);
      }
    }

    // 参数验证
    if ((messageInfo == null || messageInfo.trim().length === 0) && attachments.length === 0) {
      return;
    }

    // 是否是临时会话
    if (isTempChat) {
      // 链接Key 或 会话唯一标识为空
      if (!hasLen(this.data.chatKey.value)) {
        uni.showToast({
          title: t("Mobile.Conversation.chatKeyRequired"),
          icon: "none",
        });
        return;
      }
    } else {
      if (this.data.conversationId.value == null) {
        uni.showToast({
          title: t("Mobile.Conversation.idRequired"),
          icon: "none",
        });
        return;
      }
    }

    // #ifdef WEB || H5
    // 如果不是临时会话页面，并且url中不包含conversationId，则修改url
    if (!isTempChat && !location.href.includes("conversationId")) {
      let newUrl = "";

      // 如果是应用详情页，则跳转至应用详情页
      if (location.href.includes("app-details")) {
        newUrl = `/subpackages/pages/app-details/app-details?id=${this.data.agentId.value}&conversationId=${this.data.conversationId.value}`;
      } else {
        newUrl = `/subpackages/pages/agent-detail/agent-detail?id=${this.data.agentId.value}&conversationId=${this.data.conversationId.value}`;
      }

      // 修改url参数且不刷新页面
      const url = new URL(location.href);
      url.hash = newUrl; // 修改参数
      history.replaceState(null, "", url.toString()); // 替换当前历史记录
    }
    // #endif

    // 使用同步方法生成唯一ID（兼容所有平台）
    const chatMessageId = generateUniqueId();
    const currentMessageId = generateUniqueId();

    // 构造消息
    const chatMessage = {
      role: AssistantRoleEnum.USER,
      type: MessageModeEnum.CHAT,
      text: messageInfo,
      time: new Date().toISOString(),
      attachments,
      id: chatMessageId,
      messageType: MessageTypeEnum.USER,
    };

    // 当前助手信息
    const currentMessage = {
      role: AssistantRoleEnum.ASSISTANT,
      type: MessageModeEnum.CHAT,
      text: "",
      think: "",
      time: new Date().toISOString(),
      id: currentMessageId,
      messageType: MessageTypeEnum.ASSISTANT,
      status: MessageStatusEnum.Loading,
    } as MessageInfo;

    // 将Incomplete状态的消息改为Complete状态，并清理旧的消息状态
    const currentMessageList = this.data.messageList.value;
    const completeMessageList: Array<MessageInfo> = [];
    if (currentMessageList != null) {
      for (let i = 0; i < currentMessageList.length; i++) {
        const item = currentMessageList[i];
        if (item.status === MessageStatusEnum.Incomplete) {
          item.status = MessageStatusEnum.Complete;
        }
        completeMessageList.push(item);
      }
    }

    // 清理旧的消息状态，确保新对话开始时状态是干净的
    this.data.messageIdRef.value = "";
    this.data.currentConversationRequestId.value = "";

    // 更新消息列表
    const newMessageList = completeMessageList.concat([chatMessage, currentMessage]) as MessageInfo[];
    // AgentDetailUtils.checkConversationActive(newMessageList, this.data)
    this.data.isConversationActive.value = true;
    this.data.messageList.value = newMessageList;

    // 基础参数
    const baseParams = {
      variableParams,
      message: messageInfo,
      attachments,
      selectedComponents,
      skillIds: data.skillIds,
    };

    // 发送消息
    const params: ConversationChatParams | TempConversationChatParams =
      isTempChat
        ? ({
            chatKey: this.data.chatKey.value,
            conversationUid: this.data.conversationUid.value,
            variableParams,
            message: messageInfo ?? "",
            attachments,
            selectedComponents: selectedComponents ?? [],
            skillIds: data.skillIds,
          } as TempConversationChatParams)
        : ({
            conversationId: this.data.conversationId.value!,
            variableParams,
            message: messageInfo ?? "",
            attachments,
            selectedComponents: selectedComponents ?? [],
            skillIds: data.skillIds,
            debug: false,
            sandboxId: this.data.currentSandboxId.value,
          } as ConversationChatParams);
    this.handleConversation(params, currentMessageId, isTempChat, onTimeout);
  }

  // 根据用户消息更新会话主题
  async handleUpdateTopic(
    conversationId: string,
    messageInfo: string,
  ): Promise<void> {
    const params: AgentConversationUpdateParams = {
      id: parseInt(conversationId),
      firstMessage: messageInfo,
    };

    const {
      code,
      data: responseData,
      message,
    } = await apiAgentConversationUpdate(params);
    if (code === SUCCESS_CODE) {
      this.data.needUpdateTopicRef.value = responseData != null && (responseData as UTSJSONObject)['topicUpdated'] !== 1;
      // 更新会话主题
      const topicConvInfo = this.data.conversationInfo.value;
      if (topicConvInfo != null) {
        topicConvInfo.topic = strOr(responseData != null ? (responseData as UTSJSONObject)['topic'] as string | null : null, "");
      }
    } else {
      uni.showToast({
        title: message,
        icon: "none",
      });
    }
  }

  /**
   * 清空会话数据
   * @param isTempChat 是否是临时会话
   */
  clearConversationData(isTempChat: boolean = false): void {
    // 创建新会话后，问题建议列表改为空
    this.data.chatSuggestList.value = [];
    // 创建新会话后，是否正在加载会话改为false
    this.data.isLoadingConversation.value = false;
    // 创建新会话后，消息列表改为空
    this.data.messageList.value = [];
    // 创建新会话后，发送按钮禁用状态改为false
    this.data.wholeDisabled.value = false;
    // 创建新会话后，是否发送过消息改为false, 让对话设置框取消禁用状态
    this.data.isSendMessageRef.value = false;
    // 创建新会话后，用户填写变量参数改为空对象
    this.data.userFillVariables.value = {};

    if (!isTempChat) {
      // 创建新会话后，需要更新会话主题
      this.data.needUpdateTopicRef.value = true;
    }
  }

  /**
   * 创建新会话
   */
  async createNewConversation(isAppDetails: boolean = false): Promise<void> {
    if (this.data.agentId.value == null) {
      uni.showToast({
        title: t("Mobile.Conversation.agentIdMissing"),
        icon: "none",
      });
      return;
    }

    // 清空会话数据
    this.clearConversationData();

    // 如果普通会话，并且任务正在执行，则更新任务状态为 CANCEL
    if (this.data.conversationInfo.value?.taskStatus === TaskStatus.EXECUTING) {
      const restartConvInfo = this.data.conversationInfo.value;
      if (restartConvInfo != null) {
        restartConvInfo.taskStatus = TaskStatus.CANCEL;
      }
    }

    // 会话参数
    const conversationParams: ConversationCreateParams = {
      agentId: this.data.agentId.value,
      devMode: false, // 开发模式, 只有智能体编排页才会设置为true
    };

    // 获取引导问题
    this.getGuidQuestion(this.data.agentId.value);

    const {
      code,
      data: responseData,
      message,
    } = await apiAgentConversationCreate(conversationParams);
    if (code === SUCCESS_CODE && responseData != null && responseData.id != null) {
      this.data.conversationId.value = responseData.id;

      // 更新会话信息
      this.data.conversationInfo.value = responseData;
      if (responseData.agent != null) {
        this.data.agentInfo.value = responseData.agent as AgentDetailDto;
      }

      // 重新获取沙盒列表以更新状态
      const allowPrivate = responseData.agent != null && (responseData.agent as UTSJSONObject)['allowPrivateSandbox'] === 1;
      this.handleGetSandboxList(allowPrivate);

      let newUrl = "";

      // 如果是应用智能体页面，则跳转至应用智能体页面
      if (isAppDetails) {
        newUrl = `/subpackages/pages/app-details/app-details?id=${this.data.agentId.value}&conversationId=${responseData.id}`;
      } else {
        // 新会话页面URL
        newUrl = `/subpackages/pages/agent-detail/agent-detail?id=${this.data.agentId.value}&conversationId=${responseData.id}`;
      }

      // #ifdef WEB || H5
      // 修改rul参数且不刷新页面
      const url = new URL(location.href);
      url.hash = newUrl; // 修改参数
      history.replaceState(null, "", url.toString()); // 替换当前历史记录
      // #endif

      // #ifdef MP-WEIXIN
      uni.redirectTo({
        url: newUrl,
      });
      // #endif
    } else {
      uni.showToast({
        title: message,
        icon: "none",
      });
    }
  }

  /**
   * 获取引导问题
   * @param agentId 智能体id
   */
  async getGuidQuestion(agentId: number): Promise<void> {
    const {
      code,
      data: responseData,
      message,
    } = await apiPublishedAgentInfo(agentId);
    if (code === SUCCESS_CODE) {
      this.data.chatSuggestList.value =
        responseData?.guidQuestionDtos?.slice(0, 5) ?? [];
    }
  }

  /**
   * 获取基本信息
   * @param withConversationId 是否初始化会话id，默认false
   * @param messageInfo 消息信息，默认''
   * @param files 文件信息，默认[]
   */
  async getPublishedAgentInfo(
    withConversationId: boolean = false,
    params: GetPublishedAgentInfoParams,
  ): Promise<void> {
    const {
      code,
      data: responseData,
      message,
    } = await apiPublishedAgentInfo(
      this.data.agentId.value!,
      withConversationId,
    );
    if (code === SUCCESS_CODE) {
      this.data.agentInfo.value = responseData;
      // 判断是否开启问题建议
      this.data.isSuggest.value =
        responseData?.openSuggest === OpenCloseEnum.Open;
      // 引导问题建议（兼容旧版）
      const guidDtos = responseData?.guidQuestionDtos;
      const openQuestions = responseData?.openingGuidQuestions;
      if (guidDtos != null && guidDtos.length > 0) {
        this.data.chatSuggestList.value = guidDtos;
      } else if (openQuestions != null && openQuestions.length > 0) {
        this.data.chatSuggestList.value = openQuestions.slice(0, 5).map((q: string): GuidQuestionDto => {
          return { type: GuidQuestionSetTypeEnum.Question, info: q } as GuidQuestionDto;
        });
      } else {
        this.data.chatSuggestList.value = [];
      }
      // 首页页面URL
      const httpUrl = `${API_BASE_URL}${responseData?.pageHomeIndex ?? ""}`;
      // #ifdef H5 || WEB
      this.data.pageHomeUrl.value =
        process.env.NODE_ENV === "production"
          ? `${window.location.origin}${httpUrl}`
          : httpUrl;
      // #endif

      // #ifdef MP-WEIXIN
      this.data.pageHomeUrl.value = httpUrl;
      // #endif
      // this.data.pageHomeUrl.value = httpUrl

      // 如果默认展开扩展页面区域，且不隐藏聊天区域，则打开首页页面弹窗
      // if (responseData?.expandPageArea === ExpandPageAreaEnum.Yes && responseData?.hideChatArea === HideChatAreaEnum.No) {
      // 	this.data.popupPage.value && this.data.popupPage.value?.open()
      // }
      this.data.variables.value = responseData?.variables ?? [];
      // 获取会话ID
      if (withConversationId) {
        this.data.conversationId.value = responseData.conversationId as number | null;
        const { messageInfo, files } = params;
        // 如果存在消息或文件，则发送消息
        if ((messageInfo != null && hasLen(messageInfo.trim())) || (files != null && files.length > 0)) {
          // 初始化会话时，发送消息
          const sendData: SendMessageData = {
            messageInfo: messageInfo ?? "",
            files: files ?? [],
          };
          this.handleSendMessage(sendData, false, null);
        }
      }

      // 获取沙盒列表
      const allowPrivate = responseData.allowPrivateSandbox as number | null;
      this.handleGetSandboxList(allowPrivate != null && allowPrivate == 1);
    }
  }

  /**
   * 收藏/取消收藏
   */
  async handleCollect(): Promise<void> {
    if (this.data.agentInfo.value == null) return;

    if (this.data.agentInfo.value.collect) {
      const { code } = await apiUnCollectAgent(
        this.data.agentInfo.value.agentId,
      );
      if (code === SUCCESS_CODE) {
        uni.showToast({
          title: t("Mobile.Conversation.unfavoriteSuccess"),
          icon: "success",
          duration: 2000,
        });
        this.data.agentInfo.value.collect = false;
      }
    } else {
      const { code } = await apiCollectAgent(this.data.agentInfo.value.agentId);
      if (code === SUCCESS_CODE) {
        uni.showToast({
          title: t("Mobile.Conversation.favoriteSuccess"),
          icon: "success",
          duration: 2000,
        });
        this.data.agentInfo.value.collect = true;
      }
    }
  }

  /**
   * 查询临时会话信息
   * conversationUid: 会话唯一标识 (可选)
   */
  async queryTempConversation(conversationUid: string) {
    // 链接Key为空
    if (this.data.chatKey.value == null) {
      uni.showToast({
        title: t("Mobile.Conversation.chatKeyRequired"),
        icon: "none",
      });
      return;
    }
    const res = await apiTempChatConversationQuery({
      chatKey: this.data.chatKey.value,
      conversationUid,
    } as TempConversationQueryDto);
    if (res.code === SUCCESS_CODE) {
      // 临时会话页, 设置导航栏标题
      if (res.data?.agent != null) {
        const agentName = strOr(res.data?.agent?.name, "");
        uni.setNavigationBarTitle({
          title: t("Mobile.Conversation.startWithAgent") + agentName,
        });
      }

      // 处理消息列表
      this.handleQueryConversation(res);
    } else {
      this.data.isLoadingConversation.value = false;
      uni.showToast({
        title: res.message,
        icon: "none",
        duration: 2000,
      });
    }
  }

  /**
   * 创建临时会话
   * chatKey 链接Key
   * @param captchaVerifyParam 验证码参数 (可选)
   */
  async createTempChatConversation(captchaVerifyParam: string) {
    // 链接Key为空
    if (this.data.chatKey.value == null) {
      uni.showToast({
        title: t("Mobile.Conversation.chatKeyRequired"),
        icon: "none",
      });
      return;
    }
    const params = {
      chatKey: this.data.chatKey.value,
      captchaVerifyParam,
    } as TempConversationCreateDto;
    const res = await apiTempChatConversationCreate(params);
    const { data: resData, code, message } = res;
    // 创建临时会话成功
    if (code === SUCCESS_CODE) {
      this.data.conversationUid.value = resData.uid;
      uni.setStorageSync(TEMP_CONVERSATION_UID, resData.uid);
      // 查询临时会话详细
      this.queryTempConversation(resData.uid);
    } else {
      this.data.isLoadingConversation.value = false;
      uni.showToast({
        title: message,
        icon: "none",
        duration: 2000,
      });
    }
  }

  /**
   * 重启智能体
   */
  async handleRestartAgent(): Promise<void> {
    const conversationId = this.data.conversationId.value;
    if (conversationId == null) return;

    uni.showLoading({
      title: t("Mobile.Common.restarting"),
      mask: true,
    });
    try {
      const res = await apiRestartAgent(conversationId);
      uni.hideLoading();
      if (res.code === SUCCESS_CODE) {
        uni.showToast({
          title: t("Mobile.Sandbox.restartAgentSuccess"),
          icon: "success",
        });
      } else {
        uni.showToast({
          title: strOr(res.message, t("Mobile.Sandbox.restartAgentFailed")),
          icon: "none",
        });
      }
    } catch (error) {
      uni.hideLoading();
      console.error("[AgentDetailService] 重启智能体失败:", error);
    }
  }

  /**
   * 重启容器/客户端
   * @param isCloudComp 是否是云电脑 (currentSandboxId === '-1')
   */
  async handleRestartSandbox(isCloudComp: boolean): Promise<void> {
    const conversationId = this.data.conversationId.value;
    if (conversationId == null) return;

    uni.showLoading({
      title: t("Mobile.Common.restarting"),
      mask: true,
    });
    try {
      const res = await apiRestartSandbox(conversationId);
      uni.hideLoading();
      if (res.code === SUCCESS_CODE) {
        uni.showToast({
          title: isCloudComp ? t("Mobile.Sandbox.restartCloudCompSuccess") : t("Mobile.Sandbox.restartClientSuccess"),
          icon: "success",
        });
      } else {
        uni.showToast({
          title: strOr(res.message, t("Mobile.Common.operationFailed")),
          icon: "none",
        });
      }
    } catch (error) {
      uni.hideLoading();
      console.error("[AgentDetailService] 重启容器失败:", error);
    }
  }
}

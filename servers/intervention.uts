import { RequestResponse } from "@/types/interfaces/request"
import request from "@/servers/useRequest"

/** 权限审批回调参数 */
export interface AgentInterventionRespondParams {
  interventionId: string
  permission_resolve_request: {
    request_permission_response: {
      outcome: {
        Selected?: { option_id: string }
        Cancelled?: null
      }
    }
    session_id?: string
    tool_call_id?: string
    save_rule: boolean
  }
  conversation_id?: number
}

/**
 * 权限审批回调
 * 对齐 nuwax Web 版 apiAgentInterventionRespond
 */
export async function apiAgentInterventionRespond(params: AgentInterventionRespondParams) {
  return request<RequestResponse<null>>({
    url: `/api/agent-interventions/${params.interventionId}/respond`,
    method: "POST",
    data: params,
  })
}

<template>
  <view class="container page-container relative border-b">
    <!-- 导航栏 -->
    <custom-nav-bar :title="title">
      <!-- #ifdef MP-WEIXIN -->
      <template v-slot:left>
        <text class="iconfont icon-Search font-48" @click="handleSearch"></text>
      </template>
      <!-- #endif -->
      <!-- #ifndef MP-WEIXIN -->
      <template v-slot:right>
        <text class="iconfont icon-Search font-48" @click="handleSearch"></text>
      </template>
      <!-- #endif -->
    </custom-nav-bar>

    <!-- 分类导航 -->
    <view class="category-nav border-b">
      <scroll-view
        class="category-scroll"
        :scroll-with-animation="true"
        :scroll-into-view="scrollIntoView"
        :show-scrollbar="false"
        :scroll-x="true"
        :enable-flex="true"
      >
        <view class="category-scroll-content">
          <view
            :id="category.key"
            v-for="(category, index) in categories"
            :key="category.key"
            :class="`category-item ${activeCategory === category.key ? 'active' : ''}`"
            @click="handleCategoryClick(category.key, index)"
          >
            <text class="category-text">{{
              translate(category.label)
            }}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 滚动部分 -->
    <view class="scroll-section">
      <swiper
        class="h-full"
        :current="activeSwiperIndex"
        @change="handleSwiperChange"
        :indicator-dots="false"
        :circular="false"
        :duration="300"
        easing-function="easeOut"
      >
        <template v-for="(category, index) in categories" :key="category.key">
          <swiper-item>
            <!-- 只渲染当前页和相邻页，减少渲染压力 -->
            <view v-if="shouldRenderCategory(index)" class="h-full">
              <scroll-view
                class="h-full"
                :scroll-y="true"
                @scrolltolower="handleLoadMore"
                :refresher-enabled="true"
                :refresher-triggered="refreshingMap[category.key] == true"
                @refresherrefresh="handleRefresh"
                :show-scrollbar="false"
                scroll-with-animation
              >
                <template v-if="agentListMap[category.key] != null && (agentListMap[category.key] as SquarePublishedItemInfo[]).length > 0">
                  <template
                    v-for="info in agentListMap[category.key]"
                    :key="info.id"
                  >
                    <template v-if="agentType === 'PageApp'">
                      <page-card
                        :coverImg="info.icon"
                        :name="info.name"
                        :avatar="info.publishUser != null ? info.publishUser.avatar : ''"
                        :userName="
                          info.publishUser != null && info.publishUser.nickName != null && info.publishUser.nickName != ''
                            ? info.publishUser.nickName
                            : (info.publishUser != null ? info.publishUser.userName : '')
                        "
                        :created="info.created"
                        :userCount="info.statistics != null ? info.statistics.userCount : 0"
                        :collectCount="info.statistics != null ? info.statistics.collectCount : 0"
                        :collect="info.collect"
                        @click="handleAgentClick(info)"
                        @collect="handleToggleCollect(info, category.key)"
                      />
                    </template>
                    <template v-else>
                      <agent-component
                        :icon="info.icon"
                        :name="info.name"
                        :avatar="info.publishUser?.avatar"
                        :userName="
                          info.publishUser?.nickName != null && info.publishUser?.nickName != ''
                            ? info.publishUser?.nickName
                            : info.publishUser?.userName
                        "
                        :description="info.description"
                        :userCount="info.statistics?.userCount"
                        :convCount="info.statistics?.convCount"
                        :collectCount="info.statistics?.collectCount"
                        :collect="info.collect"
                        :paymentRequired="info.paymentRequired == true && enableSubscription === 1"
                        :subscribed="info.subscribed"
                        @click="handleAgentClick(info)"
                        @collect="handleToggleCollect(info, category.key)"
                      />
                    </template>
                  </template>
                </template>

                <!-- loading状态或刷新状态时隐藏空状态 -->
                <template
                  v-else-if="
                    loadingMap[category.key] != true && refreshingMap[category.key] != true
                  "
                >
                  <view class="empty-state">
                    <image
                      :src="noData"
                      class="empty-image"
                      :alt="t('Mobile.Common.noDataImageAlt')"
                    />
                    <text class="empty-text">{{
                      t("Mobile.Common.noData")
                    }}</text>
                  </view>
                </template>

                <!-- 刷新状态时隐藏加载状态 -->
                <template v-else-if="refreshingMap[category.key] != true">
                  <view class="loading-state">
                    <text class="loading-text">{{
                      t("Mobile.Page.loadingMore")
                    }}</text>
                  </view>
                </template>

                <!-- 加载状态时隐藏没有更多数据状态 -->
                <template
                  v-if="
                    loadingMap[category.key] != true &&
                    hasMoreMap[category.key] != true &&
                    (agentListMap[category.key] != null && (agentListMap[category.key] as SquarePublishedItemInfo[]).length > 6)
                  "
                >
                  <view class="no-more-state">
                    <text class="no-more-text">{{
                      t("Mobile.Common.noMoreData")
                    }}</text>
                  </view>
                </template>
              </scroll-view>
            </view>
            <!-- 未加载的页面显示占位 -->
            <view v-else class="h-full placeholder-view"></view>
          </swiper-item>
        </template>
      </swiper>
    </view>

    <!-- 登录弹窗 -->
    <auth-login-popup ref="loginPopupRef" />
  </view>
</template>

<script setup lang="uts">
  import { ref, computed, onMounted, onUnmounted } from 'vue';
  // #ifdef MP-WEIXIN
  import { onShow, onUnload } from "@dcloudio/uni-app";
  // #endif
  import { CONST_ALL } from "@/constants/common.constants";
  import { SquarePublishedItemInfo, SquareCategoryInfo, SquarePublishedListParams } from "@/types/interfaces/square";
  import type { AgentStatisticsInfo } from "@/types/interfaces/agent";
  import { apiPublishedCategoryList, apiPublishedAgentList } from "@/servers/square";
  import { SUCCESS_CODE, USER_NO_LOGIN, REDIRECT_LOGIN } from "@/constants/codes.constants";
  import { SquareAgentTypeEnum } from "@/types/enums/square";
  import { AgentComponentTypeEnum } from "@/types/enums/agent";
  import { Page, RequestResponse } from "@/types/interfaces/request";
  import AgentComponent from "@/components/agent-component/agent-component.uvue";
  import PageCard from "@/components/page-card/page-card.uvue";
  import noData from "@/static/assets/no_data.png";
  import { TENANT_CONFIG_INFO } from "@/constants/home.constants";
  import { apiTenantConfig } from "@/servers/account";
  import type { TenantConfigInfo } from "@/types/interfaces/login";
  import { getCurrentPagePath } from "@/utils/commonBusiness";
  import CustomNavBar from "@/components/custom-nav-bar/custom-nav-bar.uvue";
  import { apiUnCollectAgent, apiCollectAgent } from "@/servers/agentDev";
  import { useAuthInterceptor } from "@/hooks/useAuthInterceptor";
  import AuthLoginPopup from "@/components/auth-login-popup/auth-login-popup.uvue";
  import { t as _t, translateText } from "@/utils/i18n";

  const translate = (text : string) : string => {
    return translateText(text);
  };

  const _i18nParams = new Map<string, string | number>();
  const t = (key: string): string => _t(key, _i18nParams, "");

  const props = withDefaults(
    defineProps<{
      agentType: string;
      title: string;
    }>(),
    {
      agentType: "ChatBot",
      title: "Mobile.Nav.agent",
    },
  );

  // 使用登录拦截 composable
  const authInterceptor = useAuthInterceptor();
  const loginPopupRef = authInterceptor.loginPopupRef;
  const baseHandleAgentClick = authInterceptor.handleAgentClick as (info : any) => void;
  const checkAuthAndShowPopup = authInterceptor.checkAuthAndShowPopup as () => Promise<boolean>;

  // 当前分类
  const activeCategory = ref<string>(CONST_ALL);
  // 当前swiper索引
  const activeSwiperIndex = ref<number>(0);
  class PublishedCategoryItem {
    key : string = "";
    label : string = "";
    active : boolean = false;
    constructor(key : string, label : string, active : boolean) {
      this.key = key;
      this.label = label;
      this.active = active;
    }
  }
  // 分类列表
  const categories = ref<PublishedCategoryItem[]>([]);
  // 智能体列表
  const agentListMap = ref<Record<string, SquarePublishedItemInfo[]>>(new Map<string, SquarePublishedItemInfo[]>() as Record<string, SquarePublishedItemInfo[]>);
  // 加载状态
  const loadingMap = ref<Record<string, boolean>>(new Map<string, boolean>() as Record<string, boolean>);
  // 刷新状态
  const refreshingMap = ref<Record<string, boolean>>(new Map<string, boolean>() as Record<string, boolean>);
  // 页码
  const pageMap = ref<Record<string, number>>(new Map<string, number>() as Record<string, number>);
  // 是否还有更多
  const hasMoreMap = ref<Record<string, boolean>>(new Map<string, boolean>() as Record<string, boolean>);
  // 搜索关键词
  const searchKeyword = ref<string>("");
  // 滚动到对应的分类标签
  const scrollIntoView = ref<string>("");
  // 搜索定时器
  const searchTimeoutRef = ref<number>(0);
  // 租户信息
  const tenantConfigInfo = ref<TenantConfigInfo | null>(null);

  // 租户订阅限制强受控标志
  const enableSubscription = computed((): number => {
    if (tenantConfigInfo.value != null && tenantConfigInfo.value!.enableSubscription != null) {
      return tenantConfigInfo.value!.enableSubscription!;
    }
    return 0;
  });
  // 已渲染的分类索引集合（用于懒加载优化）
  const renderedCategoryIndexes = ref<Set<number>>(new Set([0]));

  // // 新增标志变量，用于区分首次加载
  // const isFirstLoad = ref<boolean>(true)

  /**
   * 判断是否应该渲染该分类
   * 只渲染当前页和相邻的前后各1页，减少DOM节点数量
   */
  const shouldRenderCategory = (index: number): boolean => {
    const currentIndex = activeSwiperIndex.value;
    // 渲染当前页、前一页、后一页
    const shouldRender = Math.abs(index - currentIndex) <= 1;
    if (shouldRender) {
      renderedCategoryIndexes.value.add(index);
    }
    // 已经渲染过的页面保持渲染状态，避免频繁创建销毁
    return renderedCategoryIndexes.value.has(index);
  };

  // 获取用户配置
  const fetchTenantConfig = async () => {
    const res = await apiTenantConfig();
    if (res.code === SUCCESS_CODE) {
      tenantConfigInfo.value = res.data;
      const siteName = res.data != null && res.data.siteName != null ? res.data.siteName : "";
      uni.setNavigationBarTitle({
        title: siteName,
      });
      uni.setStorageSync(TENANT_CONFIG_INFO, JSON.stringify(res.data));
    }
  };

  // 获取分类列表
  const fetchCategories = async () => {
    const response = await apiPublishedCategoryList();
    if (response.code === SUCCESS_CODE) {
      const data = response.data;
      //#ifdef MP-WEIXIN
      data.forEach((item : SquareCategoryInfo) => {
        if (item.type === SquareAgentTypeEnum.PageApp) {
          item.children = item.children.filter((child : SquareCategoryInfo) : boolean => {
            return child.key !== "Game";
          });
        }
      });
      //#endif

      let filterType = props.agentType === "ChatBot" ? SquareAgentTypeEnum.Agent : SquareAgentTypeEnum.PageApp;

      const found = data.find((item : SquareCategoryInfo) : boolean => item.type === filterType);
      const agentCategoryList = found != null && found.children != null ? found.children : [];
      const categoryData = agentCategoryList.map(
        (item : SquareCategoryInfo) : PublishedCategoryItem => {
          return new PublishedCategoryItem(item.key, item.label, false);
        },
      );
      categories.value = [
        new PublishedCategoryItem(CONST_ALL, "Mobile.Common.all", true),
        ...categoryData,
      ];
    } else if (response.code !== USER_NO_LOGIN && response.code !== REDIRECT_LOGIN) {
      uni.showToast({
        title: t("Mobile.AgentList.fetchCategoryFailed"),
        icon: "error",
      });
    }
  };

  // 获取智能体列表
  const fetchAgentList = async (
    category: string,
    pageNum: number,
    keyword: string,
  ) => {
    if (loadingMap.value[category] != null && loadingMap.value[category] == true) return;
    // 设置加载状态 - 使用直接赋值而非解构，减少响应式更新
    loadingMap.value[category] = true;
    const params = new Map<string, any>();
    params.set("targetType", AgentComponentTypeEnum.Agent);
    params.set("targetSubType", props.agentType);
    params.set("page", pageNum);
    params.set("pageSize", 10);
    params.set("category", category === CONST_ALL ? "" : category);
    params.set("kw", keyword);
    // 获取智能体列表
    const response = await apiPublishedAgentList(params as SquarePublishedListParams);
    // 成功
    if (response.code === SUCCESS_CODE) {
      const pageData = response.data;
      const records = pageData.records;
      //#ifdef MP-WEIXIN
      const filtered = records != null ? records.filter((item : SquarePublishedItemInfo) : boolean => {
        return item.category !== "Game";
      }) : [];
      //#endif
      const newList : SquarePublishedItemInfo[] = records != null ? records : [];
      if (pageNum > 1) {
        const raw = agentListMap.value[category];
        const existingList : SquarePublishedItemInfo[] = raw != null ? raw : [];
        agentListMap.value[category] = [...existingList, ...newList];
      } else {
        agentListMap.value[category] = newList;
      }
      hasMoreMap.value[category] = pageData.pages > pageNum;
      pageMap.value[category] = pageNum;
    } else if (response.code !== USER_NO_LOGIN && response.code !== REDIRECT_LOGIN) {
      uni.showToast({
        title: response.message != null && response.message != "" ? response.message : t("Mobile.AgentList.fetchAgentFailed"),
        icon: "error",
      });
    }
    loadingMap.value[category] = false;
  };

  const initData = async () => {
    // 获取分类列表
    fetchCategories();
    // 1. 首先尝试从本地缓存读取，以实现秒开级的初始渲染，防止 siteName 等标题闪烁
    const tenantConfigInfoString = uni.getStorageSync(TENANT_CONFIG_INFO) as string;
    if (tenantConfigInfoString != null && tenantConfigInfoString != "") {
      const parsed = JSON.parse(tenantConfigInfoString) as TenantConfigInfo;
      tenantConfigInfo.value = parsed;
      const siteName = parsed != null && parsed.siteName != null ? parsed.siteName : "";
      uni.setNavigationBarTitle({
        title: siteName,
      });
    }
    // 2. 然后必须发起强同步网络请求更新最新状态，防止缓存过期导致计费状态显示不准确
    await fetchTenantConfig();
  };

  // #ifdef MP-WEIXIN
  onShow(() => {
    initData();
    fetchAgentList(CONST_ALL, 1, searchKeyword.value);
  });

  onUnload(() => {
    if (searchTimeoutRef.value != 0) {
      clearTimeout(searchTimeoutRef.value);
    }
  });
  // #endif

  // #ifndef MP-WEIXIN
  onMounted(() => {
    initData();
    fetchAgentList(CONST_ALL, 1, searchKeyword.value);
  });

  onUnmounted(() => {
    if (searchTimeoutRef.value != 0) {
      clearTimeout(searchTimeoutRef.value);
    }
  });
  // #endif

  // 点击智能体分类标签
  const handleCategoryClick = (key: string, index: number) => {
    // 当前分类
    activeCategory.value = key;
    // 当前swiper索引
    activeSwiperIndex.value = index;
    // 滚动到对应的分类标签
    scrollIntoView.value = key;

    // 如果该分类还没有数据，则加载数据
    const rawList = agentListMap.value[key];
    if (rawList == null || rawList.length === 0) {
      pageMap.value[key] = 1;
      hasMoreMap.value[key] = true;
      fetchAgentList(key, 1, searchKeyword.value);
    }
  };

  // 处理Swiper切换
  const handleSwiperChange = (e: UniSwiperChangeEvent) => {
    const index = e.detail.current;
    const category = categories.value[index];
    if (category != null && category.key !== activeCategory.value) {
      // 当前分类
      activeCategory.value = category.key;
      // 当前swiper索引
      activeSwiperIndex.value = index;

      // 滚动到对应的分类标签
      const id = categories.value[index].key;
      scrollIntoView.value = id;

      // 如果该分类还没有数据，则加载数据
      const catRaw = agentListMap.value[category.key];
      if (catRaw == null || catRaw.length === 0) {
        pageMap.value[category.key] = 1;
        hasMoreMap.value[category.key] = true;
        fetchAgentList(category.key, 1, searchKeyword.value);
      }
    }
  };

  // 处理搜索
  const handleSearch = async () => {
    // 检查登录状态，如果未登录则显示登录弹窗
    const isLoggedIn = await checkAuthAndShowPopup();
    if (isLoggedIn != true) {
      return;
    }
    const currentUrl = getCurrentPagePath();
    uni.navigateTo({
      url:
        `/subpackages/pages/agent-search/agent-search?type=${props.agentType}&backUrl=` +
        encodeURIComponent(currentUrl),
    });
  };

  // 跳转到智能体详情页
  const handleAgentClick = (agentInfo: SquarePublishedItemInfo) => {
    // 使用登录拦截逻辑处理点击
    baseHandleAgentClick({
      targetId: agentInfo.targetId,
      name: agentInfo.name,
      agentType: agentInfo.agentType,
      icon: agentInfo.icon,
      description: agentInfo.description,
    });
  };

  // 处理收藏与取消收藏
  const handleToggleCollect = async (
    agentInfo: SquarePublishedItemInfo,
    category: string,
  ) => {
    const targetId = agentInfo.targetId;
    const collect = agentInfo.collect;
    // 获取当前分类列表
    const rawList = agentListMap.value[category];
    const existingList : SquarePublishedItemInfo[] = rawList != null ? rawList : [];
    // 更新列表收藏状态，并更新统计信息
    const updatedList = existingList.map((item : SquarePublishedItemInfo) : SquarePublishedItemInfo => {
      if (item.targetId === targetId) {
        const collectCount = item.statistics != null && item.statistics.collectCount != null ? item.statistics.collectCount : 0;
        const newCollectCount = collect ? collectCount - 1 : collectCount + 1;
        const newStatistics = JSON.parse(JSON.stringify(item.statistics)) as AgentStatisticsInfo;
        newStatistics.collectCount = newCollectCount;
        item.collect = collect != true;
        item.statistics = newStatistics;
      }
      return item;
    });
    agentListMap.value[category] = updatedList;
    // 更新数据库收藏状态
    if (collect == true) {
      const unCollectRes = await apiUnCollectAgent(targetId);
      if (unCollectRes.code !== SUCCESS_CODE) {
        agentListMap.value[category] = existingList;
        uni.showToast({
          title: t("Mobile.AgentList.unCollectFailed"),
          icon: "none",
        });
      }
    } else {
      const collectRes = await apiCollectAgent(targetId);
      if (collectRes.code !== SUCCESS_CODE) {
        agentListMap.value[category] = existingList;
        uni.showToast({
          title: t("Mobile.AgentList.collectFailed"),
          icon: "none",
        });
      }
    }
  };

  // 下拉刷新
  const handleRefresh = () => {
    const currentCategory = activeCategory.value;
    if (refreshingMap.value[currentCategory] == true) {
      return;
    }
    refreshingMap.value[currentCategory] = true;
    pageMap.value[currentCategory] = 1;
    hasMoreMap.value[currentCategory] = true;
    fetchAgentList(currentCategory, 1, searchKeyword.value).finally(() => {
      // 添加延迟，让loading效果更明显
      setTimeout(() => {
        refreshingMap.value[currentCategory] = false;
      }, 500);
    });
  };

  // 加载更多
  const handleLoadMore = () => {
    const currentPage : number = pageMap.value[activeCategory.value] != null ? pageMap.value[activeCategory.value] as number : 1;
    const currentHasMore = hasMoreMap.value[activeCategory.value] != false;
    const currentLoading = loadingMap.value[activeCategory.value];

    if (currentHasMore && currentLoading != true) {
      fetchAgentList(activeCategory.value, currentPage + 1, searchKeyword.value);
    }
  };
</script>

<style lang="scss" scoped>
  .container {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background-color: #fff;
    /* #ifdef MP-WEIXIN || APP */
    // padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
    /* #endif */

    .icon-Search {
      margin-left: 12rpx;
    }

    .category-nav {
      padding: 0 32rpx 16rpx 32rpx;

      /* 分类导航 */
      .category-scroll {
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
        height: 80rpx;
      }

      .category-scroll-content {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        /* #ifdef H5 */
        width: max-content;
        min-width: 100%;
        /* #endif */
        /* #ifndef H5 */
        min-width: 750rpx;
        /* #endif */
      }

      .category-item {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        height: 80rpx;
        padding: 0 32rpx;
        border-radius: 16rpx;
        cursor: pointer;
        transition: all 0.3s ease;
        user-select: none;
        color: #5e6470;
        font-size: 32rpx;
        font-weight: 400;

        &.active {
          background-color: #f2f2ff;

          .category-text {
            color: #5147ff;
          }
        }

        .category-text {
          font-size: 32rpx;
          font-weight: 400;
          color: #5e6470;
          transition: color 0.3s ease;
        }
      }
    }

    /* 滚动部分 */
    .scroll-section {
      flex: 1;
      overflow: hidden;
    }

    /* 空状态 */
    .empty-state {
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;

      .empty-image {
        width: 172rpx;
        height: 172rpx;
      }

      .empty-text {
        font-size: 28rpx;
        color: #999;
        margin-top: 32rpx;
      }
    }

    /* 加载状态 */
    .loading-state {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40rpx;
    }

    .loading-text {
      font-size: 28rpx;
      color: #666;
      display: flex;
      align-items: center;
    }

    /* #ifdef H5 */
    .loading-text::before {
      content: "";
      width: 32rpx;
      height: 32rpx;
      border: 4rpx solid #e8e8e8;
      border-top: 4rpx solid #8b5cf6;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-right: 16rpx;
    }

    @keyframes spin {
      0% {
        transform: rotate(0deg);
      }
      100% {
        transform: rotate(360deg);
      }
    }
    /* #endif */

    /* 没有更多数据状态 */
    .no-more-state {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40rpx;
    }

    .no-more-text {
      font-size: 24rpx;
      color: #999;
    }

    /* 占位视图 */
    .placeholder-view {
      background-color: #f8f9fa;
    }
  }
</style>

/**
 * 音频文件上传器
 * 处理音频文件上传和语音转文字功能
 */
import { ACCESS_TOKEN } from "@/constants/home.constants";
import { REDIRECT_LOGIN, SUCCESS_CODE } from "@/constants/codes.constants";
import { API_BASE_URL } from "../constants/config";
import { t } from "@/utils/i18n";
/**
 * 音频文件数据（UTS 使用 class 以支持 .uvue 中构造，避免 interface 对象字面量限制）
 */
export class AudioFile {
  tempFilePath: string;
  duration: number;
  fileSize: number;
  format: string;

  constructor(
    tempFilePath: string,
    duration: number,
    fileSize: number,
    format: string = "mp3",
  ) {
    this.tempFilePath = tempFilePath;
    this.duration = duration;
    this.fileSize = fileSize;
    this.format = format;
  }
}

/** 转录结果（class 构造，兼容 .uvue 返回值） */
export class TranscriptResult {
  success: boolean;
  text: string;
  confidence: number;
  duration: number;
  error: string;
  segments: any[];

  constructor(
    success: boolean,
    text: string,
    confidence: number,
    duration: number,
    error: string = "",
    segments: any[] = [],
  ) {
    this.success = success;
    this.text = text;
    this.confidence = confidence;
    this.duration = duration;
    this.error = error;
    this.segments = segments;
  }
}

// 上传配置（UTS 用 class，避免 interface 对象字面量初始化限制）
export class UploadConfig {
  apiUrl: string = "";
  timeout: number = 30000;
  language: string = "zh-CN";
  enableRetry: boolean = true;
  maxRetries: number = 1;
  retryDelay: number = 1000;
}

// 上传进度回调接口
export interface UploadProgress {

  loaded: number; // 已上传字节数
  total: number; // 总字节数
  percent: number; // 上传进度百分比
}

/**
 * 音频上传器类
 */
export class AudioUploader {
  private config: UploadConfig = new UploadConfig();

  constructor(config: UTSJSONObject | null = null) {
    this.config.apiUrl = API_BASE_URL + "/api/audio/stt";
    if (config != null) {
      const apiUrl = config["apiUrl"];
      if (apiUrl != null) {
        this.config.apiUrl = apiUrl as string;
      }
      const timeout = config["timeout"];
      if (timeout != null) {
        this.config.timeout = timeout as number;
      }
      const language = config["language"];
      if (language != null) {
        this.config.language = language as string;
      }
      const enableRetry = config["enableRetry"];
      if (enableRetry != null) {
        this.config.enableRetry = enableRetry as boolean;
      }
      const maxRetries = config["maxRetries"];
      if (maxRetries != null) {
        this.config.maxRetries = maxRetries as number;
      }
      const retryDelay = config["retryDelay"];
      if (retryDelay != null) {
        this.config.retryDelay = retryDelay as number;
      }
    }
  }

  /**
   * 上传音频文件并转换为文字
   */
  async uploadAudio(
    audioFile: AudioFile,
    onProgress?: any,
  ): Promise<TranscriptResult> {
    if (audioFile.tempFilePath.length == 0) {
      throw new Error(t("Mobile.AudioUploader.pathRequired"));
    }

    // #ifndef APP
    if (audioFile.fileSize == 0) {
      throw new Error(t("Mobile.AudioUploader.fileEmpty"));
    }

    // 检查文件大小限制（10MB）
    const maxFileSize = 10 * 1024 * 1024;
    if (audioFile.fileSize > maxFileSize) {
      throw new Error(t("Mobile.AudioUploader.fileTooLarge"));
    }

    // 检查录音时长（最短0.5秒，最长10分钟）
    // if (audioFile.duration < 0.5) {
    //   throw new Error('录音时长过短，至少需要0.5秒')
    // }

    /**
     * 此处的duration是录音停止时的duration，而不是录音开始时的duration, 单位为秒
     */
    if (audioFile.duration > 600) {
      throw new Error(t("Mobile.AudioUploader.durationTooLong"));
    }
    // #endif

    // 开始上传
    return this.performUpload(audioFile, onProgress);
  }

  /**
   * 执行上传操作
   */
  private async performUpload(
    audioFile: AudioFile,
    onProgress?: any,
    retryCount: number = 0,
  ): Promise<TranscriptResult> {
    try {
      // 模拟上传进度
      // if (Boolean(onProgress)) {
      //   this.simulateProgress(onProgress)
      // }

      // 暂时使用模拟实现，后续可替换为真实API调用
      // if (this.config.apiUrl == '/api/voice-to-text') {
      //   return await this.mockUpload(audioFile)
      // }

      // 真实的上传实现
      return await this.realUpload(audioFile, onProgress);
    } catch (error: any) {
      // console.error(`上传失败 (尝试 ${retryCount + 1}/${this.config.maxRetries + 1}):`, error)

      // // 如果启用重试且未达到最大重试次数
      // if (
      //   this.config.enableRetry &&
      //   retryCount < this.config.maxRetries! &&
      //   this.shouldRetry(error)
      // ) {
      //   // 等待一段时间后重试
      //   await this.delay(this.config.retryDelay! * Math.pow(2, retryCount))
      //   return this.performUpload(audioFile, onProgress, retryCount + 1)
      // }

      // 不重试或重试次数已达上限
      throw this.formatError(error);
    }
  }

  /**
   * 真实的上传实现
   */
  private async realUpload(
    audioFile: AudioFile,
    onProgress?: any,
  ): Promise<TranscriptResult> {
    return new Promise((resolve, reject) => {
      const accessToken = uni.getStorageSync(ACCESS_TOKEN);
      const header = {} as UTSJSONObject;
      if (accessToken != null && `${accessToken}` != '') {
        // #ifdef H5 || WEB
        if (process.env.NODE_ENV == "development") {
          header["Authorization"] = `Bearer ${accessToken}`;
        }
        // #endif

        // #ifdef MP-WEIXIN
        header["Authorization"] = `Bearer ${accessToken}`;
        // #endif
      }
      // uEnvProd
      if (process.env.NODE_ENV == "production") {
        // #ifdef H5
        //仅H5需要添加fragment参数
        const fragment = (window.location.hash || "#/").replace("#/", "/");
        if (Boolean(fragment)) {
          header["fragment"] = fragment;
        }
        // #endif
      }
      const uploadTask = uni.uploadFile({
        header,
        url: this.config.apiUrl,
        filePath: audioFile.tempFilePath,
        name: "file",
        // formData: any,
        timeout: this.config.timeout,
        success: (res) => {
          try {
            const parsed = JSON.parse(res.data) as UTSJSONObject;
            const code = parsed["code"];
            const data = parsed == null ? null : (parsed["data"] as UTSJSONObject);
            if (code == SUCCESS_CODE) {
              const dataText = data == null ? null : data["text"];
              if (dataText != null) {
                resolve(
                  new TranscriptResult(true, dataText as string, 0, 0, "", []),
                );
              } else {
                reject(
                  new Error(t("Mobile.AudioUploader.noTextRecognized")),
                );
              }
            } else {
              const codeParams = new Map<string, string | number>();
              codeParams.set("code", `${res.statusCode}`);
              reject(
                new Error(
                  t("Mobile.AudioUploader.requestFailedWithCode", codeParams),
                ),
              );
            }
          } catch (error) {
            reject(
              new Error(t("Mobile.AudioUploader.responseParseFailed")),
            );
          }
        },
        fail: (err) => {
          reject(
            new Error(
              err.errMsg != null && err.errMsg != '' ? err.errMsg : t("Mobile.AudioUploader.networkFailed"),
            ),
          );
        },
      });

      // 监听上传进度
      // if (Boolean(onProgress)) {
      //   uploadTask.onProgressUpdate((res) => {
      //     onProgress({
      //       loaded: res.totalBytesSent,
      //       total: res.totalBytesExpectedToSend,
      //       percent: res.progress
      //     })
      //   })
      // }
    });
  }


        },
      },
      required: ["target", "strategy"],
    } as Record<string, unknown>,
    uiSchema: {
      "ui:options": { allowSkip: true, skipLabel: "稍后处理" },
      target: { "ui:widget": "radio" },
      strategy: {
        "ui:widget": "radio-with-custom",
        "ui:options": {
          allowCustom: true,
          otherValue: "__custom__",
          otherField: "strategyCustom",
          placeholder: "输入自定义发布策略",
        },
      },
      notes: { "ui:widget": "textarea" },
    } as Record<string, unknown>,
    steps: [
      {
        id: "target",
        title: "选择目标",
        description: "先确认要发布到哪个环境",

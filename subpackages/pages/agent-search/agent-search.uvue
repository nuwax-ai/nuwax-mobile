<template>
  <view class="search-page-container flex flex-col">
    <!-- 微信安全区 -->
    <safety-zone></safety-zone>
    <!-- 搜索框 -->
    <view class="search-container border-b">
      <!-- #ifdef MP-WEIXIN -->
      <text class="cancel-text" @click="jumpNavigateBack">{{
        t("Mobile.Common.cancel")
      }}</text>
      <!-- #endif -->
      <view class="search-box" :class="{ focused: isFocused }">
        <text class="iconfont icon-Search"></text>
        <input
          ref="searchInputRef"
          class="search-input"
          :placeholder="searchPlaceholder"
          placeholder-class="placeholder-class"
          type="search"
          confirm-type="search"
          :value="searchKeyword"
          @confirm="onSearchConfirm"
          @input="onSearchInput"
          @focus="handleFocus"
          @blur="handleBlur"
          :auto-focus="shouldAutoFocus"
        />
        <text
          v-if="searchKeyword.length > 0"
          class="iconfont icon-a-Xcircle-fill clear-icon"
          @click="handleSearch('')"
        ></text>
      </view>
      <!-- #ifndef MP-WEIXIN -->
      <text class="cancel-text" @click="jumpNavigateBack">{{
        t("Mobile.Common.cancel")
      }}</text>
      <!-- #endif -->

      <!-- 微信胶囊按钮功能区 -->
      <!-- #ifdef MP-WEIXIN -->
      <view
        class="right-safety"
        :style="{
          width: clientRect.width + 13 + 'px',
          height: clientRect.height + 'px',
        }"
      ></view>
      <!-- #endif -->
    </view>
    <!-- 滚动部分 -->
    <view class="scroll-section flex-1">
      <scroll-view
        class="h-full"
        @scrolltolower="handleLoadMore"
        :refresher-enabled="isApiMode"
        :refresher-triggered="refreshing"
        @refresherrefresh="handleRefresh"
        :show-scrollbar="false"
      >
        <template v-if="hasList">
          <template v-for="info in agentList" :key="info.id">
            <!-- 页面应用 -->
            <page-card
              v-if="isPageApp"
              :coverImg="getCoverImg(info)"
              :name="info.name"
              :userName="getPublishUserName(info)"
              :created="info.created"
              @click="handleAgentClick(info)"
            />
            <!-- 首页 -->
            <recent-used-agent-item
              v-else-if="isHome"
              :icon="info.icon"
              :name="info.name"
              :description="getDescription(info)"
              :paymentRequired="needsPayment(info)"
              :subscribed="getSubscribed(info)"
              @click="handleRecentUsedAgentClick(info)"
            />
            <!-- 聊天机器人: 默认 cardComponentType 为 ChatBot -->
            <agent-component
              v-else
              :icon="info.icon"
              :name="info.name"
              :avatar="getPublishAvatar(info)"
              :userName="getPublishUserName(info)"
              :description="getDescription(info)"
              :userCount="info.statistics.userCount"
              :convCount="info.statistics.convCount"
              :collectCount="info.statistics.collectCount"
              :paymentRequired="needsPayment(info)"
              :subscribed="getSubscribed(info)"
              @click="handleAgentClick(info)"
            />
          </template>
        </template>

        <template v-if="loading">
          <view class="loading-state">
            <text class="loading-text">{{ t("Mobile.Page.loadingMore") }}</text>
          </view>
        </template>

        <template v-else-if="showEmpty">
          <view class="empty-state">
            <image
              :src="noData"
              class="empty-image"
              :alt="t('Mobile.Common.noDataImageAlt')"
            />
            <text class="empty-text">{{
              t("Mobile.AgentSearch.emptyResult")
            }}</text>
          </view>
        </template>

        <template v-if="showNoMore">
          <view class="no-more-state">
            <text class="no-more-text">{{
              t("Mobile.Common.noMoreData")
            }}</text>
          </view>
        </template>
      </scroll-view>
    </view>
  </view>
</template>

<script lang="uts" setup>
  import { apiPublishedAgentList } from "@/servers/square";
  import { apiUserUsedAgentList } from "@/servers/agentDev";
  import {
    SquarePublishedItemInfo,
  } from "@/types/interfaces/square";
  import { SquareAgentTypeEnum } from "@/types/enums/square";
  import { SUCCESS_CODE } from "@/constants/codes.constants";
  import { AgentComponentTypeEnum } from "@/types/enums/agent";
  import RecentUsedAgentItem from "@/components/recent-used-agent-item/recent-used-agent-item.uvue";
  import { apiTenantConfig } from "@/servers/account";
  import { TENANT_CONFIG_INFO } from "@/constants/home.constants";
  import type { TenantConfigInfo } from "@/types/interfaces/login";
  import {
    jumpToAgentDetailPage,
  } from "@/utils/commonBusiness";
  import noData from "@/static/assets/no_data.png";
  import type { CategoryItemInfo } from "@/types/interfaces/agentConfig";
  import { AllowCopyEnum } from "@/types/enums/agent";
  import { PluginTypeEnum } from "@/types/enums/plugin";
  import { isTabPage } from "@/utils/commonBusiness";
  import { setCurrentPageNavigationBarTitle } from "@/utils/system.uts";
  import { appGlobalState } from "@/utils/appGlobalState";
  import { useI18n, translateText } from "@/utils/i18n";

  const { t: tRaw } = useI18n();
  const t = (key: string): string => tRaw(key, new Map<string, any>(), "");

  const searchKeyword = ref<string>("");
  const searchTimeoutRef = ref<number | null>(null);
  const agentList = ref<SquarePublishedItemInfo[]>([]);
  const hasMore = ref<boolean>(true);
  const page = ref<number>(1);
  const loading = ref<boolean>(false);
  const refreshing = ref<boolean>(false);
  // 搜索输入框ref
  const searchInputRef = ref<UniInputElement | null>(null);
  const isFocused = ref<boolean>(false);
  const cardComponentType = ref<"Home" | "PageApp" | "ChatBot">("ChatBot");
  // 租户信息
  const tenantConfigInfo = ref<TenantConfigInfo | null>(null);

  // 租户订阅限制强受控标志
  const enableSubscription = computed((): number => {
    const info = tenantConfigInfo.value;
    if (info != null) {
      const sub = info.enableSubscription;
      if (sub != null) {
        return sub as number;
      }
    }
    return 0;
  });
  // 搜索模式：'api' 接口搜索模式，'local' 前端过滤模式
  const searchMode = ref<"api" | "local">("api");
  // 前端过滤模式下的原始列表数据
  const localAgentList = ref<CategoryItemInfo[]>([]);
  // 搜索框 placeholder key（运行时翻译，保证语言切换可生效）
  const searchPlaceholderSource = ref<string>("Mobile.AgentSearch.placeholder");
  const searchPlaceholder = computed((): string => {
    // 默认占位符 Key
    let placeholderKey = "Mobile.AgentSearch.placeholder";

    // 如果是 PageApp 类型，切换 Key
    if (cardComponentType.value == "PageApp") {
      placeholderKey = "Mobile.AgentSearch.pageAppPlaceholder";
    }

    // 如果 searchPlaceholderSource 有值且不是默认值（通常是 local 模式下从外部传入），则优先使用它
    let finalKey = placeholderKey;
    const sourceKey = searchPlaceholderSource.value;
    if (sourceKey.length > 0) {
      if (sourceKey != "Mobile.AgentSearch.placeholder") {
        finalKey = sourceKey;
      }
    }

    return translateText(finalKey);
  });
  // 小程序平台控制 auto-focus
  const shouldAutoFocus = ref<boolean>(false);
  // 返回地址
  const backUrl = ref<string>("");

  // #ifdef MP-WEIXIN
  const clientRect = uni.getMenuButtonBoundingClientRect();
  // #endif

  // 模板辅助：模式与卡片类型
  const isApiMode = computed((): boolean => searchMode.value == "api");
  const isPageApp = computed((): boolean => cardComponentType.value == "PageApp");
  const isHome = computed((): boolean => cardComponentType.value == "Home");
  const hasList = computed((): boolean => agentList.value.length > 0);
  const showEmpty = computed((): boolean => {
    if (loading.value) return false;
    if (searchKeyword.value.length == 0) return false;
    return agentList.value.length == 0;
  });

  // 模板辅助：取 item 字段（uvue 模板不支持 ?. 与 || 兜底）
  const getDescription = (info: SquarePublishedItemInfo): string => {
    const d = info.description;
    return d != null ? (d as string) : "";
  };
  const getSubscribed = (info: SquarePublishedItemInfo): boolean => {
    return info.subscribed == true;
  };
  const getCoverImg = (info: SquarePublishedItemInfo): string => {
    const obj = info as UTSJSONObject;
    const c = obj["coverImg"];
    return c != null ? (c as string) : "";
  };
  const getPublishUserName = (info: SquarePublishedItemInfo): string => {
    const pu = info.publishUser;
    if (pu == null) return "";
    const nick = pu.nickName;
    if (nick.length > 0) return nick;
    const uname = pu.userName;
    return uname != null ? uname : "";
  };
  const getPublishAvatar = (info: SquarePublishedItemInfo): string => {
    const pu = info.publishUser;
    if (pu == null) return "";
    const a = pu.avatar;
    return a != null ? (a as string) : "";
  };
  const needsPayment = (info: SquarePublishedItemInfo): boolean => {
    return info.paymentRequired == true && enableSubscription.value == 1;
  };

  const jumpNavigateBack = () => {
    let toUrl = "/pages/index/index";
    if (backUrl.value.length > 0) {
      toUrl = backUrl.value;
    }
    console.log(toUrl);

    if (isTabPage(toUrl)) {
      uni.switchTab({ url: toUrl });
    } else {
      uni.redirectTo({ url: toUrl });
    }
  };

  // 获取租户配置
  const fetchTenantConfig = async () => {
    const res = await apiTenantConfig();
    if (res.code == SUCCESS_CODE) {
      tenantConfigInfo.value = res.data;
      // 缓存租户信息
      uni.setStorageSync(TENANT_CONFIG_INFO, JSON.stringify(res.data));
    }
  };

  // 初始化租户配置数据
  const initTenantConfig = async () => {
    // 1. 首先尝试从本地缓存读取
    const stored = uni.getStorageSync(TENANT_CONFIG_INFO);
    if (stored != null) {
      const configStr = stored as string;
      if (configStr.length > 0) {
        tenantConfigInfo.value = JSON.parse(configStr) as TenantConfigInfo;
      }
    }
    // 2. 然后必须发起网络强同步请求，以获得最新的 enableSubscription 状态
    await fetchTenantConfig();
  };

  // onLoad 回调（async 逻辑拆出，避免 onLoad 签名返回 Promise 不匹配）
  const onLoaded = async (options: any) => {
    // 强同步获取并更新租户配置信息，保障收费 tag 状态的百分百实时受控
    await initTenantConfig();

    const optObj = options as UTSJSONObject;
    const typeRaw = optObj["type"];
    const type = typeRaw != null ? (typeRaw as string) : "";
    const modeRaw = optObj["searchMode"];
    const mode = modeRaw != null ? (modeRaw as string) : "";
    const backUrlRaw = optObj["backUrl"];
    if (backUrlRaw != null) {
      const rawBack = backUrlRaw as string;
      if (rawBack.length > 0) {
        const dec = decodeURIComponent(rawBack);
        if (dec != null) {
          backUrl.value = dec;
        }
      }
    }
    if (type == "Home") {
      cardComponentType.value = "Home";
    } else if (type == "PageApp") {
      cardComponentType.value = "PageApp";
    } else {
      cardComponentType.value = "ChatBot";
    }
    // 设置当前页面导航栏标题
    setCurrentPageNavigationBarTitle();
    // 检测 searchMode 参数，区分搜索模式
    if (mode == "local") {
      // 从共享状态获取列表数据和文案（替代 getApp().globalData）
      const localList = appGlobalState.localAgentList;
      if (localList.length > 0) {
        // 有数据，使用前端过滤模式
        searchMode.value = "local";
        localAgentList.value = localList;
        // 默认不显示全部列表，只有搜索时才显示
        agentList.value = [];
        hasMore.value = false;

        // 获取搜索文案，如果没有则使用默认值
        const placeholder = appGlobalState.searchPlaceholder;
        if (placeholder.length > 0) {
          searchPlaceholderSource.value = placeholder;
        }
      } else {
        // 没有数据，回退到 api 模式
        searchMode.value = "api";
      }
    } else {
      searchMode.value = "api";
    }
  };

  onLoad((options: any) => {
    onLoaded(options);
  });

  onMounted(() => {
    // 页面加载完成后自动获取输入框焦点
    // #ifndef MP-WEIXIN
    // 非小程序平台可以直接调用 focus
    nextTick(() => {
      const input = searchInputRef.value;
      if (input != null) {
        input.focus();
      }
    });
    // #endif
  });

  // 小程序平台使用 onReady 确保页面渲染完成后再聚焦
  onReady(() => {
    // #ifdef MP-WEIXIN
    // 小程序平台：通过设置 auto-focus 为 true 来触发聚焦
    shouldAutoFocus.value = true;
    // #endif
  });

  // 小程序页面显示时也尝试聚焦
  onShow(() => {
    // #ifdef MP-WEIXIN
    // 小程序平台：通过重置 auto-focus 来重新触发聚焦
    shouldAutoFocus.value = false;
    nextTick(() => {
      shouldAutoFocus.value = true;
    });
    // #endif
  });

  // 是否显示没有更多数据（前端过滤模式下不显示）
  const showNoMore = computed((): boolean => {
    if (searchMode.value == "local") {
      return false;
    }
    const isLoading = loading.value == true;
    const noMore = hasMore.value == false;
    const listLen = agentList.value.length;
    if (isLoading == true) {
      return false;
    }
    if (noMore == false) {
      return false;
    }
    return listLen > 8;
  });

  /**
   * 将 CategoryItemInfo 转换为 SquarePublishedItemInfo 格式
   */
  const convertCategoryItemsToSquareItems = (
    items: CategoryItemInfo[],
  ): SquarePublishedItemInfo[] => {
    const result: SquarePublishedItemInfo[] = [];
    const len = items.length;
    for (let i = 0; i < len; i++) {
      const item = items[i];
      let desc = "";
      if (item.description != null) {
        desc = item.description as string;
      }
      const itemObj = item as UTSJSONObject;
      const paymentRequiredRaw = itemObj["paymentRequired"];
      const subscribedRaw = itemObj["subscribed"];
      const obj = {
        id: item.targetId,
        tenantId: 0,
        spaceId: 0,
        targetType: item.targetType as SquareAgentTypeEnum,
        agentType: "ChatBot",
        targetId: item.targetId,
        name: item.name,
        description: desc,
        icon: item.icon,
        remark: "",
        modified: "",
        created: "",
        statistics: item.statistics,
        publishUser: item.publishUser,
        category: "",
        allowCopy: AllowCopyEnum.No,
        pluginType: PluginTypeEnum.HTTP,
        collect: item.collect,
        paymentRequired: paymentRequiredRaw != null ? (paymentRequiredRaw as boolean) : false,
        subscribed: subscribedRaw != null ? (subscribedRaw as boolean) : false,
      } as UTSJSONObject;
      result.push(obj as SquarePublishedItemInfo);
    }
    return result;
  };

  const handleFocus = () => {
    isFocused.value = true;
  };

  const handleBlur = () => {
    isFocused.value = false;
  };

  // 获取智能体、页面应用列表
  const fetchAgentList = async (
    pageNum: number,
    keyword: string,
  ) => {
    const params = {
      targetType: AgentComponentTypeEnum.Agent,
      targetSubType: cardComponentType.value == "PageApp" ? "PageApp" : "ChatBot",
      page: pageNum,
      pageSize: 10,
      category: "",
      kw: keyword,
    } as UTSJSONObject;
    // 获取智能体列表
    const response = await apiPublishedAgentList(params);
    const code = response.code;
    const data = response.data;
    const message = response.message;
    // 成功
    if (code == SUCCESS_CODE) {
      let newList: SquarePublishedItemInfo[] = [];
      if (data != null && data.records != null) {
        newList = data.records as SquarePublishedItemInfo[];
      }
      if (pageNum > 1) {
        const prev = agentList.value;
        const combined: SquarePublishedItemInfo[] = [];
        for (let i = 0; i < prev.length; i++) {
          combined.push(prev[i]);
        }
        for (let j = 0; j < newList.length; j++) {
          combined.push(newList[j]);
        }
        agentList.value = combined;
      } else {
        agentList.value = newList;
      }
      if (data != null) {
        hasMore.value = pageNum < data.pages;
      }
      page.value = pageNum;
      loading.value = false;
    } else {
      let toastTitle = t("Mobile.AgentSearch.fetchAgentFailed");
      if (message != null) {
        const msg = message as string;
        if (msg.length > 0) {
          toastTitle = msg;
        }
      }
      uni.showToast({
        title: toastTitle,
        icon: "error",
      });
      loading.value = false;
    }
  };

  // 查询用户最近使用过的智能体列表
  const fetchUserUsedAgentList = async (
    pageNum: number,
    keyword: string,
  ) => {
    const params = {
      pageIndex: pageNum,
      size: 20,
      keyword: keyword,
    } as UTSJSONObject;
    const res = await apiUserUsedAgentList(params);
    const code = res.code;
    const data = res.data;
    if (code == SUCCESS_CODE) {
      let newList: SquarePublishedItemInfo[] = [];
      if (data != null) {
        newList = data as SquarePublishedItemInfo[];
      }
      if (pageNum > 1) {
        const prev = agentList.value;
        const combined: SquarePublishedItemInfo[] = [];
        for (let i = 0; i < prev.length; i++) {
          combined.push(prev[i]);
        }
        for (let j = 0; j < newList.length; j++) {
          combined.push(newList[j]);
        }
        agentList.value = combined;
      } else {
        agentList.value = newList;
      }

      hasMore.value = newList.length > 0;
      page.value = pageNum;
      loading.value = false;
    } else {
      uni.showToast({
        title: t("Mobile.AgentSearch.fetchRecentUsedFailed"),
        icon: "none",
      });
      loading.value = false;
    }
  };

  // 获取智能体列表
  const fetchList = async (
    pageNum: number,
    keyword: string,
  ) => {
    // 前端过滤模式下不调用接口
    if (searchMode.value == "local") {
      return;
    }

    if (cardComponentType.value == "Home") {
      await fetchUserUsedAgentList(pageNum, keyword);
    } else {
      await fetchAgentList(pageNum, keyword);
    }
  };

  /**
   * 前端过滤搜索（本地过滤）
   */
  const filterLocalList = (keyword: string) => {
    if (keyword.length == 0) {
      agentList.value = [];
      return;
    }
    if (localAgentList.value.length == 0) {
      agentList.value = [];
      return;
    }

    const lowerKeyword = keyword.toLowerCase();
    const filtered: CategoryItemInfo[] = [];
    const source = localAgentList.value;
    const sourceLen = source.length;
    for (let i = 0; i < sourceLen; i++) {
      const item = source[i];
      let nameMatch = false;
      let descMatch = false;
      const itemName = item.name;
      if (itemName != null) {
        if (itemName.toLowerCase().indexOf(lowerKeyword) >= 0) {
          nameMatch = true;
        }
      }
      const itemDesc = item.description;
      if (itemDesc != null) {
        if (itemDesc.toLowerCase().indexOf(lowerKeyword) >= 0) {
          descMatch = true;
        }
      }
      if (nameMatch == true) {
        filtered.push(item);
      } else if (descMatch == true) {
        filtered.push(item);
      }
    }

    agentList.value = convertCategoryItemsToSquareItems(filtered);
  };

  // 处理搜索
  const handleSearch = (keyword: string) => {
    searchKeyword.value = keyword;
    // 清除之前的定时器
    const timer = searchTimeoutRef.value;
    if (timer != null) {
      clearTimeout(timer);
    }

    if (keyword.length == 0) {
      // 前端过滤模式和接口搜索模式都清空列表
      agentList.value = [];
      loading.value = false;
      // #ifdef H5 || WEB
      nextTick(() => {
        const input = searchInputRef.value;
        if (input != null) {
          input.focus();
        }
      });
      // #endif
      return;
    }

    // 根据搜索模式选择不同的处理方式
    if (searchMode.value == "local") {
      // 前端过滤模式：本地过滤
      loading.value = true;
      // 设置新的定时器，防抖500ms
      searchTimeoutRef.value = setTimeout(() => {
        filterLocalList(keyword);
        loading.value = false;
      }, 500);
    } else {
      // 接口搜索模式：调用接口
      loading.value = true;
      // 设置新的定时器，防抖500ms
      searchTimeoutRef.value = setTimeout(() => {
        page.value = 1;
        hasMore.value = true;
        fetchList(1, keyword);
      }, 500);
    }
  };

  // 从输入框事件中提取 value（uvue 模板不能直接 $event.detail.value）
  const extractEventValue = (e: any): string => {
    const ev = e as UTSJSONObject;
    const detailRaw = ev["detail"];
    if (detailRaw != null) {
      const detail = detailRaw as UTSJSONObject;
      const valRaw = detail["value"];
      if (valRaw != null) {
        return valRaw as string;
      }
    }
    return "";
  };

  const onSearchConfirm = (e: any) => {
    handleSearch(extractEventValue(e));
  };

  const onSearchInput = (e: any) => {
    handleSearch(extractEventValue(e));
  };

  // 加载更多
  const handleLoadMore = () => {
    // 前端过滤模式下禁用加载更多
    if (searchMode.value == "local") {
      return;
    }

    const canLoadMore = hasMore.value == true;
    const notLoading = loading.value == false;
    if (canLoadMore == true) {
      if (notLoading == true) {
        const nextPage = page.value + 1;
        fetchList(nextPage, searchKeyword.value);
      }
    }
  };

  // 下拉刷新
  const handleRefresh = () => {
    // 前端过滤模式下禁用下拉刷新
    if (searchMode.value == "local") {
      refreshing.value = false;
      return;
    }

    if (refreshing.value) {
      return;
    }
    refreshing.value = true;
    fetchList(1, searchKeyword.value).then((): void => {
      refreshing.value = false;
    }).catch((): void => {
      refreshing.value = false;
    });
  };

  // 跳转到智能体详情页
  const handleAgentClick = (info: SquarePublishedItemInfo) => {
    jumpToAgentDetailPage(info.targetId, null, info.agentType, info.name);
  };

  // 跳转到智能体详情页
  const handleRecentUsedAgentClick = (info: SquarePublishedItemInfo) => {
    jumpToAgentDetailPage(info.targetId, null, info.agentType, info.name);
  };
</script>

<style lang="scss" scoped>
  .search-page-container {
    /* #ifdef H5 */
    height: 100vh;
    /* #endif */
    /* #ifndef H5 */
    height: 100%;
    /* #endif */
    overflow: hidden;
    background-color: #fff;
    /* #ifdef MP-WEIXIN */
    // padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
    /* #endif */

    /* 搜索框 */
    .search-container {
      display: flex;
      flex-direction: row;
      align-items: center;
      padding: 10rpx 0 10rpx 32rpx;
      flex-shrink: 0;

      .search-box {
        flex: 1;
        gap: 16rpx;
        display: flex;
        align-items: center;

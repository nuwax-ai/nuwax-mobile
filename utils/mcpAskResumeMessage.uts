/**
 * MCP Ask resume 消息构建
 * 对齐 nuwax Web 版 buildMcpAskResumeMessage
 */
import type { McpAskInteraction, McpAskRespondPayload } from '@/types/intervention'

/**
 * 构建用户提交后的 resume 消息文本
 * 发送给 Agent 作为用户回答
 */
export function buildMcpAskResumeMessage(
  interaction: McpAskInteraction,
  payload: McpAskRespondPayload
): string {
  const { action, formData } = payload
  const title = interaction.title || ''

  if (action === 'cancel') {
    return `我取消了「${title}」。`
  }
  if (action === 'skip') {
    return `我跳过了「${title}」。`
  }
  if (action === 'timeout') {
    return `「${title}」已超时，没有收到表单答案。`
  }

  // submit — 格式化表单数据
  if (!formData || Object.keys(formData).length === 0) {
    return `我已填写「${title}」，但没有填写任何内容。`
  }

  const lines: string[] = []
  const schema = (interaction.ui?.schema as any) || {}
  const properties = schema.properties || {}

  for (const key of Object.keys(formData)) {
    const value = formData[key]
    const fieldSchema = properties[key] || {}
    const label = fieldSchema.title || key

    if (value === null || value === undefined || value === '') {
      lines.push(`${label}：未填写`)
    } else if (Array.isArray(value)) {
      // 检查是否为文件附件数组 (AttachmentFile[])
      if (value.length > 0 && typeof value[0] === 'object' && value[0] !== null && 'fileName' in (value[0] as any)) {
        const fileNames = value.map((f: any) => f.fileName || f.fileUrl || '未知文件')
        lines.push(`${label}：${fileNames.join('、')}`)
      } else {
        lines.push(`${label}：${(value as string[]).join('、')}`)
      }
    } else if (typeof value === 'boolean') {
      lines.push(`${label}：${value ? '是' : '否'}`)
    } else {
      lines.push(`${label}：${String(value)}`)
    }
  }

  return `我已填写「${title}」，表单内容如下：\n\n${lines.join('\n')}`
}
